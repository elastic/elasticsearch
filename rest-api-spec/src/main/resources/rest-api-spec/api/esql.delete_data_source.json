{
  "esql.delete_data_source": {
    "documentation": {
      "url": "https://www.elastic.co/docs/api/doc/elasticsearch/operation/operation-esql-data-source-delete",
      "description": "Delete an ES|QL data source. Fails with 409 if any dataset references it."
    },
    "stability": "experimental",
    "visibility": "public",
    "headers": {
      "accept": [
        "application/json"
      ],
      "content_type": [
        "application/json"
      ]
    },
    "url": {
      "paths": [
        {
          "path": "/_query/data_source/{name}",
          "methods": [
            "DELETE"
          ],
          "parts": {
            "name": {
              "type": "string",
              "description": "The name of the data source to delete"
            }
          }
        }
      ]
    }
  }
}

{
  "esql.delete_dataset": {
    "documentation": {
      "url": "https://www.elastic.co/docs/api/doc/elasticsearch/operation/operation-esql-dataset-delete",
      "description": "Delete one or more ES|QL datasets."
    },
    "stability": "experimental",
    "visibility": "public",
    "headers": {
      "accept": [
        "application/json"
      ],
      "content_type": [
        "application/json"
      ]
    },
    "url": {
      "paths": [
        {
          "path": "/_query/dataset/{name}",
          "methods": [
            "DELETE"
          ],
          "parts": {
            "name": {
              "type": "list",
              "description": "A comma-separated list of datasets to delete"
            }
          }
        }
      ]
    }
  }
}

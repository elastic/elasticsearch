{
  "esql.put_data_source": {
    "documentation": {
      "url": "https://www.elastic.co/docs/api/doc/elasticsearch/operation/operation-esql-data-source-put",
      "description": "Creates or replaces an ES|QL data source."
    },
    "stability": "experimental",
    "visibility": "public",
    "headers": {
      "accept": [
        "application/json"
      ],
      "content_type": [
        "application/json"
      ]
    },
    "url": {
      "paths": [
        {
          "path": "/_query/data_source/{name}",
          "methods": [
            "PUT"
          ],
          "parts": {
            "name": {
              "type": "string",
              "description": "The name of the data source to create or update"
            }
          }
        }
      ]
    },
    "body": {
      "description": "Data source definition: type, optional description, and type-specific settings map.",
      "required": true
    }
  }
}

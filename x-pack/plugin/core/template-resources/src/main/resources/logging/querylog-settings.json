{
  "template": {
    "data_stream_options": {
      "failure_store": {
        "enabled": true,
        "lifecycle": {
            "data_retention": "7d"
        }
      }
    },
    "lifecycle": {
      "data_retention": "2d"
    },
    "settings": {
      "index": {
        "lifecycle": {
          "prefer_ilm": false
        },
        "mode": "logsdb",
        "sort.field": [
          "@timestamp"
        ],
        "sort.order": [
          "desc"
        ]
      }
    }
  },
  "_meta": {
    "description": "Elasticsearch query activity log index template",
    "managed": true
  },
  "version": ${xpack.stack.querylog.template.version}
}

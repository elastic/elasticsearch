{
  "index_patterns": ["${xpack.stack.querylog.template.pattern}"],
  "priority": 1000,
  "data_stream": {
    "hidden": true
  },
  "composed_of": [
    "logs@mappings",
    "logs@settings",
    "ecs@mappings",
    ".query-logging-mappings",
    ".query-logging-settings"
  ],
  "allow_auto_create": true,
  "_meta": {
    "description": "Elasticsearch query activity log index template",
    "managed": true
  },
  "deprecated": ${xpack.stack.querylog.template.deprecated},
  "version": ${xpack.stack.querylog.template.version}
}

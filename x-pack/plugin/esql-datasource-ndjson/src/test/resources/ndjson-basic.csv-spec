// Tests for standalone NDJSON files
// Uses {{employees}} template that gets replaced with the actual path based on storage backend

simpleRow
ROW a = 1, b = "ndjson";

a:integer | b:keyword
1         | "ndjson"
;

// Employees dataset: 100+ rows, multiple columns with nested arrays and mixed types

readAllEmployees#[skip:-8.18.99, reason:EXTERNAL command requires dev mode]
EXTERNAL "http://foo.bar/employees.ndjson"
| KEEP emp_no, first_name, last_name, birth_date, gender, hire_date, languages, height, salary, still_hired
| SORT emp_no
| LIMIT 5;

emp_no:integer | first_name:keyword | last_name:keyword | birth_date:date          | gender:keyword | hire_date:date           | languages:integer | height:double | salary:integer | still_hired:keyword
10001          | "Georgi"           | "Facello"         | 1953-09-02T00:00:00.000Z | "M"            | 1986-06-26T00:00:00.000Z | 2                 | 2.03          | 57305          | "true"
10002          | "Bezalel"          | "Simmel"          | 1964-06-02T00:00:00.000Z | "F"            | 1985-11-21T00:00:00.000Z | 5                 | 2.08          | 56371          | "true"
10003          | "Parto"            | "Bamford"         | 1959-12-03T00:00:00.000Z | "M"            | 1986-08-28T00:00:00.000Z | 4                 | 1.83          | 61805          | "false"
10004          | "Chirstian"        | "Koblick"         | 1954-05-01T00:00:00.000Z | "M"            | 1986-12-01T00:00:00.000Z | 5                 | 1.78          | 36174          | "true"
10005          | "Kyoichi"          | "Maliniak"        | 1955-01-21T00:00:00.000Z | "M"            | 1989-09-12T00:00:00.000Z | 1                 | 2.05          | 63528          | "true"
;

testJobPositionsArray#[skip:-8.18.99, reason:EXTERNAL command requires dev mode]
EXTERNAL "{{employees}}"
| WHERE emp_no == 10001 OR emp_no == 10002 OR emp_no == 10004
| KEEP emp_no, first_name, job_positions
| SORT emp_no;

emp_no:integer | first_name:keyword | job_positions:keyword
10001          | "Georgi"           | ["Senior Python Developer","Accountant"]
10002          | "Bezalel"          | "Senior Team Lead"
10004          | "Chirstian"        | ["Reporting Analyst","Tech Lead","Head Human Resources","Support Engineer"]
;

testSalaryChangeArray#[skip:-8.18.99, reason:EXTERNAL command requires dev mode]
EXTERNAL "{{employees}}"
| WHERE emp_no IN (10001, 10002, 10003, 10004, 10005, 10006)
| KEEP emp_no, first_name, salary_change
| SORT emp_no;

emp_no:integer | first_name:keyword | salary_change:double
10001          | "Georgi"           | 1.19
10002          | "Bezalel"          | [-7.23,11.17]
10003          | "Parto"            | [14.68,12.82]
10004          | "Chirstian"        | [3.65,-0.35,1.13,13.48]
10005          | "Kyoichi"          | [-2.14,13.07]
10006          | "Anneke"           | -3.90
;

testIsRehiredMixedTypes#[skip:-8.18.99, reason:EXTERNAL command requires dev mode]
EXTERNAL "{{employees}}"
| WHERE emp_no IN (10001, 10002, 10004, 10005, 10007, 10008)
| KEEP emp_no, first_name, is_rehired
| SORT emp_no;

emp_no:integer | first_name:keyword | is_rehired:keyword
10001          | "Georgi"           | ["false","true"]
10002          | "Bezalel"          | ["false","false"]
10004          | "Chirstian"        | "true"
10005          | "Kyoichi"          | ["false","false","false","true"]
10007          | "Tzvetan"          | ["true","false","true","false"]
10008          | "Saniya"           | ["true","false"]
;

selectSpecificColumns#[skip:-8.18.99, reason:EXTERNAL command requires dev mode]
EXTERNAL "{{employees}}"
| KEEP emp_no, first_name, last_name, salary
| SORT emp_no
| LIMIT 3;

emp_no:integer | first_name:keyword | last_name:keyword | salary:integer
10001          | "Georgi"           | "Facello"         | 57305
10002          | "Bezalel"          | "Simmel"          | 56371
10003          | "Parto"            | "Bamford"         | 61805
;

filterBySalary#[skip:-8.18.99, reason:EXTERNAL command requires dev mode]
EXTERNAL "{{employees}}"
| WHERE salary > 60000
| KEEP emp_no, first_name, last_name, salary
| SORT salary DESC
| LIMIT 3;

emp_no:integer | first_name:keyword | last_name:keyword | salary:integer
10007          | "Tzvetan"          | "Zielinski"       | 74572
10009          | "Sumant"           | "Peac"            | 66174
10005          | "Kyoichi"          | "Maliniak"        | 63528
;

aggregateData#[skip:-8.18.99, reason:EXTERNAL command requires dev mode]
EXTERNAL "{{employees}}"
| STATS avg_salary = AVG(salary), max_height = MAX(height), employee_count = COUNT(*)
| EVAL avg_salary = ROUND(avg_salary, 2);

avg_salary:double | max_height:double | employee_count:long
55846.7           | 2.1               | 100
;


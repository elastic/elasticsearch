Approximate stats with commands before stats
required_capability: approximation_v7
request_stored: skip

SET approximation={"rows":10000}\;
FROM many_numbers
    | MV_EXPAND mv
    | EVAL value2 = 2 * mv
    | DROP mv
    | SORT value2 DESC
    | RENAME value2 AS value3
    | MV_EXPAND value3
    | EVAL value4 = TO_STRING(value3)
    | SORT value4 ASC
    | GROK value4 "%{NUMBER:value5}"
    | EVAL value5 = TO_INTEGER(value5)
    | KEEP value3, value5
    | STATS count=COUNT(), avg=AVG(value5), sum=SUM(value5)
;

count:long       | avg:double | sum:long               | _approximation_confidence_interval(count):long | _approximation_certified(count):boolean | _approximation_confidence_interval(avg):double | _approximation_certified(avg):boolean | _approximation_confidence_interval(sum):long    | _approximation_certified(sum):boolean
1000000..3000000 | 2500..2820 | 3400000000..7200000000 | [1000000..3000000,1000000..3000000]            | {any}                                   | [2500..2820,2500..2820]                        | {any}                                 | [3400000000..7200000000,3400000000..7200000000] | {any}
;


Approximate stats with commands after stats
required_capability: approximation_v7
request_stored: skip

SET approximation={"rows":10000}\;
FROM many_numbers
    | STATS count=COUNT(), avg=AVG(sv), sum=SUM(sv)
    | EVAL avg2 = 2 * avg
    | LIMIT 10
    | MV_EXPAND avg
    | SORT count ASC
    | KEEP avg, avg2
;

avg:double | avg2:double | _approximation_confidence_interval(avg):double | _approximation_certified(avg):boolean | _approximation_confidence_interval(avg2):double | _approximation_certified(avg2):boolean
440..490   | 880..980    | [440..490,440..490]                            | {any}                                 | [880..980,880..980]                             | {any}
;


Approximate stats with dependent variables that have confidence interval
required_capability: approximation_v7
request_stored: skip

SET approximation={"rows":10000}\;
FROM many_numbers
    | MV_EXPAND mv
    | STATS avg=AVG(mv)
    | EVAL x = 2*avg*avg + sin(avg), y = 1
    | KEEP x, y
    | EVAL plus_one = y + x + 1
    | RENAME plus1 = plus_one
    | DROP x
;

y:integer | plus1:double     | _approximation_confidence_interval(plus1):double | _approximation_certified(plus1):boolean
1         | 3000000..4000000 | [3000000..4000000,3000000..4000000]              | {any}
;



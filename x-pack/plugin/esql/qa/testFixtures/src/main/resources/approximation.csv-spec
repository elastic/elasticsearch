Warn on no stats
required_capability: approximation_v5

SET approximation=true\;
FROM many_numbers | KEEP mv | MV_EXPAND mv | SORT mv | LIMIT 5
;

warning:line 2:1: approximation not supported: query without [STATS] cannot be approximated

mv:integer

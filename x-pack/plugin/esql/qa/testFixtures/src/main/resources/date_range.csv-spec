// Requires range_within (TO_DATE_RANGE(keyword) support).
toDateRangeWithEval
required_capability: date_range_field_type_v6

ROW start_date = "2023-01-01T00:00:00.000Z", end_date = "2024-01-01T00:00:00.000Z"
| EVAL range_str = CONCAT(start_date, "..", end_date)
| EVAL range = TO_DATE_RANGE(range_str)
| KEEP start_date, end_date, range
;

start_date:keyword              | end_date:keyword                | range:date_range
2023-01-01T00:00:00.000Z        | 2024-01-01T00:00:00.000Z        | 2023-01-01T00:00:00.000Z..2024-01-01T00:00:00.000Z
;

// Requires range_within (TO_DATE_RANGE(keyword) support).
toDateRangeSingleDay
required_capability: date_range_field_type_v6

ROW str = "2024-07-04T00:00:00.000Z..2024-07-05T00:00:00.000Z"
| EVAL range = TO_DATE_RANGE(str)
;

str:keyword                                          | range:date_range
2024-07-04T00:00:00.000Z..2024-07-05T00:00:00.000Z   | 2024-07-04T00:00:00.000Z..2024-07-05T00:00:00.000Z
;


// TO_DATE_RANGE honors the query timezone via SET. Europe/Paris is UTC+1 in winter, so
// "2021-01-01" parses to 2020-12-31T23:00:00Z in millis; RANGE_MIN/MAX return datetimes (always
// serialised in UTC) and TO_STRING formats with the query timezone — both confirm end-to-end.
toDateRangeRespectsQueryTimezone
required_capability: date_range_field_type_v6
required_capability: type_conversion_timezone_support
SET time_zone="Europe/Paris"\;

ROW src = "2021-01-01..2021-01-02"
| EVAL r = TO_DATE_RANGE(src), min = RANGE_MIN(TO_DATE_RANGE(src)), max = RANGE_MAX(TO_DATE_RANGE(src)), formatted = TO_STRING(TO_DATE_RANGE(src))
| KEEP src, min, max, formatted
;

src:keyword            | min:datetime              | max:datetime              | formatted:keyword
2021-01-01..2021-01-02 | 2020-12-31T23:00:00.000Z  | 2021-01-01T23:00:00.000Z  | 2021-01-01T00:00:00.000+01:00..2021-01-02T00:00:00.000+01:00
;


toDateRangeMalformedInput
required_capability: date_range_field_type_v6

ROW s = "not-a-range"
| EVAL r = TO_DATE_RANGE(s)
;
warning:Line 2:12: evaluation of [TO_DATE_RANGE(s)] failed, treating result as null. Only first 20 failures recorded.
warning:Line 2:12: java.lang.IllegalArgumentException: expected date range in the form 'from..to', got [not-a-range]

s:keyword   | r:date_range
not-a-range | null
;


toDateRangeFromStringMultiValue

###############################################
# RANGE_WITHIN with disjunction / boundary (uses decades)
###############################################

// Multiple ranges in WHERE (OR) -- test disjunction
rangeWithinMultipleRangesInWhere
required_capability: date_range_field_type_v6

FROM decades
| WHERE RANGE_WITHIN(TO_DATETIME("1955-06-15"), date_range) OR RANGE_WITHIN(TO_DATETIME("1975-06-15"), date_range)
| KEEP decade, description
| SORT decade
;

decade:integer | description:keyword
1950           | Nifty Fifties
1970           | Groovy Seventies
;

// Boundary: point at inclusive start of range
rangeWithinBoundaryCondition
required_capability: date_range_field_type_v6

FROM decades
| WHERE RANGE_WITHIN(TO_DATETIME("1980-01-01"), date_range)
| KEEP decade, description
;

decade:integer | description:keyword
1980           | Radical Eighties
;

###############################################
# RANGE_WITHIN / RANGE_INTERSECTS without Lucene pushdown
# The second argument is built from a field via TO_DATE_RANGE(TO_STRING(...)), so it is not
# foldable and the optimizer cannot translate the predicate to a Lucene query. The scalar
# evaluator handles every row instead.
###############################################

// RANGE_WITHIN: point inside a range derived from the same field row — not pushed down.
rangeWithinNoPushdownPoint
required_capability: date_range_field_type_v6

FROM decades
| WHERE RANGE_WITHIN(TO_DATETIME("1985-06-01"), TO_DATE_RANGE(TO_STRING(date_range)))
| KEEP decade, description
;

decade:integer | description:keyword
1980           | Radical Eighties
;

// RANGE_WITHIN: small literal range inside a row's derived range — not pushed down.
rangeWithinNoPushdownRange
required_capability: date_range_field_type_v6

FROM decades
| WHERE RANGE_WITHIN(TO_DATE_RANGE("1955-01-01..1958-01-01"), TO_DATE_RANGE(TO_STRING(date_range)))
| KEEP decade, description
;

decade:integer | description:keyword
1950           | Nifty Fifties
;

// RANGE_INTERSECTS: point against a derived range — not pushed down (same result as RANGE_WITHIN for a point).
rangeIntersectsNoPushdownPoint
required_capability: date_range_field_type_v6

FROM decades
| WHERE RANGE_INTERSECTS(TO_DATETIME("1985-06-01"), TO_DATE_RANGE(TO_STRING(date_range)))
| KEEP decade, description
;

decade:integer | description:keyword
1980           | Radical Eighties
;

// RANGE_INTERSECTS: a range straddling two decades intersects both — not pushed down.
rangeIntersectsNoPushdownRange
required_capability: date_range_field_type_v6

FROM decades
| WHERE RANGE_INTERSECTS(TO_DATE_RANGE("1975-01-01..1985-01-01"), TO_DATE_RANGE(TO_STRING(date_range)))
| KEEP decade, description
| SORT decade
;

decade:integer | description:keyword
1970           | Groovy Seventies
1980           | Radical Eighties
;


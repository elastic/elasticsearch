rangeMin
required_capability: date_range_field_type_v5

// tag::range_min[]
FROM decades
| WHERE decade == 1900
| EVAL min_bound = RANGE_MIN(date_range)
| KEEP date_range, min_bound
// end::range_min[]
;

// tag::range_min-result[]
date_range:date_range  | min_bound:date
1900-01-01..1910-01-01 | 1900-01-01T00:00:00.000Z
// end::range_min-result[]
;

rangeMax
required_capability: date_range_field_type_v5

// tag::range_max[]
FROM decades
| WHERE decade == 1900
| EVAL max_bound = RANGE_MAX(date_range)
| KEEP date_range, max_bound
// end::range_max[]
;

// tag::range_max-result[]
date_range:date_range  | max_bound:date
1900-01-01..1910-01-01 | 1910-01-01T00:00:00.000Z
// end::range_max-result[]
;

rangeMinMaxReparse
required_capability: date_range_field_type_v5

FROM decades
| WHERE decade == 1900 OR decade == 2000
| EVAL min_bound = RANGE_MIN(date_range)
| EVAL max_bound = RANGE_MAX(date_range)
| EVAL new_range = TO_DATE_RANGE(CONCAT(min_bound::keyword, "..", max_bound::keyword))
| KEEP date_range, min_bound, max_bound, new_range
;

ignoreOrder:true
date_range:date_range  | min_bound:date           | max_bound:date           | new_range:date_range
1900-01-01..1910-01-01 | 1900-01-01T00:00:00.000Z | 1910-01-01T00:00:00.000Z | 1900-01-01..1910-01-01
2000-01-01..2010-01-01 | 2000-01-01T00:00:00.000Z | 2010-01-01T00:00:00.000Z | 2000-01-01..2010-01-01
;

// Multi-valued ranges. Single-value positions return the bound; multi-value positions warn and yield null.
rangeMinMultiValueWarns
required_capability: date_range_field_type_v5

FROM mv_decades
| EVAL m = RANGE_MIN(date_range)
| KEEP decade, m
| SORT decade
;
warningRegex:evaluation of \[RANGE_MIN\(date_range\)\] failed, treating result as null. Only first 20 failures recorded.
warningRegex:java.lang.IllegalArgumentException: single-value function encountered multi-value

decade:integer | m:date
1900           | 1900-01-01T00:00:00.000Z
1950           | null
2000           | null
;


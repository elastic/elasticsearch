rangeWithinOutsideRange
required_capability: range_within

FROM decades
| WHERE RANGE_WITHIN(TO_DATETIME("2050-01-01"), date_range)
| KEEP decade, description
;

decade:integer | description:keyword
;

rangeWithinWithEval
required_capability: range_within

FROM decades
| EVAL test_date = TO_DATETIME("1965-07-20")
| EVAL in_range = RANGE_WITHIN(test_date, date_range)
| WHERE in_range
| KEEP decade, description, in_range
;

decade:integer | description:keyword | in_range:boolean
1960           | Swinging Sixties    | true
;

rangeWithinMultipleMatches
required_capability: range_within

FROM employees
| WHERE RANGE_WITHIN(hire_date, TO_DATE_RANGE("1985-01-01..1986-01-01"))
| STATS count = COUNT(*)
;

count:long
11
;

rangeWithinWithNull
required_capability: range_within

FROM employees
| WHERE emp_no == 10040
| EVAL in_range = RANGE_WITHIN(birth_date, TO_DATE_RANGE("1960-01-01..1970-01-01"))
| KEEP emp_no, birth_date, in_range
;

emp_no:integer | birth_date:date | in_range:boolean
10040          | null            | null
;

rangeWithinWithStats
required_capability: range_within

FROM employees
| EVAL in_1985 = RANGE_WITHIN(hire_date, TO_DATE_RANGE("1985-01-01..1986-01-01"))
| STATS count_in_1985 = COUNT(*) WHERE in_1985, total = COUNT(*)
;

count_in_1985:long | total:long
11                  | 100
;

rangeWithinBeforeStart
required_capability: range_within

FROM decades

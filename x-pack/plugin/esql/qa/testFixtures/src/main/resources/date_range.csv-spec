rangeIntersectsTwoRanges
required_capability: fn_range_intersects

ROW a = TO_DATE_RANGE("1900-01-01..2000-01-01"),
    overlapping = TO_DATE_RANGE("1990-01-01..2010-01-01"),
    disjoint = TO_DATE_RANGE("2010-01-01..2020-01-01"),
    touching = TO_DATE_RANGE("2000-01-01..2010-01-01")
| EVAL hits_overlapping = RANGE_INTERSECTS(a, overlapping),
       hits_disjoint = RANGE_INTERSECTS(a, disjoint),
       hits_touching = RANGE_INTERSECTS(a, touching)
| KEEP hits_overlapping, hits_disjoint, hits_touching
;

hits_overlapping:boolean | hits_disjoint:boolean | hits_touching:boolean
true                     | false                 | false
;

// Argument order doesn't matter for INTERSECTS — both directions return the same boolean.
rangeIntersectsSymmetric
required_capability: fn_range_intersects

FROM decades
| EVAL ab = RANGE_INTERSECTS(date_range, TO_DATE_RANGE("1955-01-01..1975-01-01")),
       ba = RANGE_INTERSECTS(TO_DATE_RANGE("1955-01-01..1975-01-01"), date_range)
| WHERE ab != ba
| KEEP decade
;

decade:integer
;

// (date, date_range) — point in range; same answer as RANGE_WITHIN(date, range).
rangeIntersectsPointInRange
required_capability: fn_range_intersects

FROM decades
| WHERE RANGE_INTERSECTS(TO_DATETIME("1965-07-20"), date_range)
| KEEP decade, description
;

decade:integer | description:keyword
1960           | Swinging Sixties
;

// (date, date) — degenerate; equivalent to a == b. Lowered to Equals via SurrogateExpression.
rangeIntersectsDateDate
required_capability: fn_range_intersects

ROW a = TO_DATETIME("2024-06-15"),
    b = TO_DATETIME("2024-06-15"),
    c = TO_DATETIME("2024-06-16")
| EVAL same = RANGE_INTERSECTS(a, b),
       different = RANGE_INTERSECTS(a, c)
| KEEP same, different
;

same:boolean | different:boolean
true         | false
;

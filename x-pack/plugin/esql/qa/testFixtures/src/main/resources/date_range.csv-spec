| EVAL r = MV_SORT(TO_STRING(TO_DATE_RANGE(s)))
;

s:keyword                                                                                                | r:keyword
[2020-01-01T00:00:00.000Z..2021-01-01T00:00:00.000Z, 2022-01-01T00:00:00.000Z..2023-01-01T00:00:00.000Z] | [2020-01-01T00:00:00.000Z..2021-01-01T00:00:00.000Z, 2022-01-01T00:00:00.000Z..2023-01-01T00:00:00.000Z]
;



// WHERE pushdown on date field: MV event_dates rows produce null → excluded.
rangeWithinPushdownMvDatePoint
required_capability: date_range_field_type_v6

FROM mv_decades
| WHERE RANGE_WITHIN(event_dates, TO_DATE_RANGE("1900-01-01..2010-01-01"))
| KEEP decade, event_dates
| SORT decade
;
warningRegex:evaluation of \[RANGE_WITHIN.*\] failed, treating result as null. Only first 20 failures recorded.
warningRegex:java.lang.IllegalArgumentException: single-value function encountered multi-value

decade:integer | event_dates:date
1900           | 1905-06-01T00:00:00.000Z
;

// WHERE pushdown on date field: MV event_dates rows produce null → excluded.
rangeIntersectsPushdownMvDatePoint
required_capability: date_range_field_type_v6

FROM mv_decades
| WHERE RANGE_INTERSECTS(event_dates, TO_DATE_RANGE("1900-01-01..2010-01-01"))
| KEEP decade, event_dates
| SORT decade
;
warningRegex:evaluation of \[RANGE_INTERSECTS.*\] failed, treating result as null. Only first 20 failures recorded.
warningRegex:java.lang.IllegalArgumentException: single-value function encountered multi-value

decade:integer | event_dates:date
1900           | 1905-06-01T00:00:00.000Z
;

rangeIntersectsPushdownMultiValue
required_capability: date_range_field_type_v6

FROM mv_decades
| WHERE RANGE_INTERSECTS(date_range, TO_DATE_RANGE("1800-01-01..2100-01-01"))
| KEEP decade, date_range
| SORT decade
;
warningRegex:evaluation of \[RANGE_INTERSECTS.*\] failed, treating result as null. Only first 20 failures recorded.
warningRegex:java.lang.IllegalArgumentException: single-value function encountered multi-value

decade:integer | date_range:date_range
1900           | 1900-01-01T00:00:00.000Z..1910-01-01T00:00:00.000Z
;


###############################################
# MV_EXPAND tests
###############################################

// MV_EXPAND on a date_range field: each MV position is split into individual rows.
mvExpandDateRange
required_capability: date_range_field_type_v6

FROM mv_decades
| MV_EXPAND date_range
| KEEP decade, date_range
;

ignoreOrder:true
decade:integer | date_range:date_range
1900           | 1900-01-01T00:00:00.000Z..1910-01-01T00:00:00.000Z
1950           | 1950-01-01T00:00:00.000Z..1960-01-01T00:00:00.000Z
1950           | 1955-01-01T00:00:00.000Z..1965-01-01T00:00:00.000Z
2000           | 1995-01-01T00:00:00.000Z..2005-01-01T00:00:00.000Z
2000           | 2000-01-01T00:00:00.000Z..2010-01-01T00:00:00.000Z
;

// MV_EXPAND followed by a scalar filter: after expansion each row has a single date_range value.
mvExpandDateRangeThenFilter
required_capability: date_range_field_type_v6

FROM mv_decades
| MV_EXPAND date_range
| WHERE RANGE_WITHIN(TO_DATETIME("1951-01-01"), date_range)
| KEEP decade, description, date_range
;

decade:integer | description:keyword | date_range:date_range
1950           | Two                 | 1950-01-01T00:00:00.000Z..1960-01-01T00:00:00.000Z
;



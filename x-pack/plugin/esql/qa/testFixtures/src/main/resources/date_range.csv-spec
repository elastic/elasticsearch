required_capability: fn_to_range

FROM decades
| EVAL r = TO_RANGE(TO_DATETIME("2000-01-01T00:00:00.000Z"), RANGE_MAX(date_range))
| WHERE date_range == r
| KEEP decade
| SORT decade

// Date from LOOKUP, date_range from FROM (decades_main + lookup_with_date)
rangeWithinDateFromLookupRangeFromFromDecadesMain
required_capability: range_within
required_capability: join_lookup_v12

FROM decades_main
| LOOKUP JOIN lookup_with_date ON join_key
| WHERE RANGE_WITHIN(some_date, date_range)
| KEEP date_range, some_date
;

date_range:date_range                              | some_date:date
1950-01-01T00:00:00.000Z..1960-01-01T00:00:00.000Z | 1955-06-15T00:00:00.000Z
;

// date_range from FROM, date_range from LOOKUP (decades_main + lookup_with_date_range)
rangeWithinRangeFromFromRangeFromLookup
required_capability: range_within
required_capability: join_lookup_v12

FROM decades_main
| LOOKUP JOIN lookup_with_date_range ON join_key
| WHERE RANGE_WITHIN(date_range, lookup_range)
| KEEP date_range, lookup_range
;

date_range:date_range                              | lookup_range:date_range
1950-01-01T00:00:00.000Z..1960-01-01T00:00:00.000Z | 1952-01-01T00:00:00.000Z..1954-01-01T00:00:00.000Z
;

// Multiple ranges in WHERE (OR)
rangeWithinMultipleRangesInWhere
required_capability: range_within
required_capability: join_lookup_v12

FROM employees
| EVAL join_key = 1
| LOOKUP JOIN date_ranges ON join_key
| WHERE RANGE_WITHIN(TO_DATETIME("1985-06-15"), date_range) OR RANGE_WITHIN(TO_DATETIME("1988-06-15"), date_range)
| KEEP emp_no, description
| SORT emp_no, description
| LIMIT 6
;

ignoreOrder:true
emp_no:integer | description:keyword
10001          | 1985
10001          | 1988
10002          | 1985
10002          | 1988
10003          | 1985
10003          | 1988
;

// Boundary: 1985-01-01 at start of 1985 range
rangeWithinBoundaryCondition
required_capability: range_within
required_capability: join_lookup_v12

FROM employees
| EVAL join_key = 1
| LOOKUP JOIN date_ranges ON join_key
| WHERE RANGE_WITHIN(TO_DATETIME("1985-01-01"), date_range)
| KEEP emp_no, description
| SORT emp_no
| LIMIT 3
;

ignoreOrder:true
emp_no:integer | description:keyword
10001          | 1985
10002          | 1985
10003          | 1985
;

// Date from FROM with literal range (join still multiplies rows; filter by literal range)
rangeWithinLeftSideDateLiteralRange
required_capability: range_within
required_capability: join_lookup_v12

FROM employees
| EVAL join_key = 1
| LOOKUP JOIN date_ranges ON join_key
| WHERE RANGE_WITHIN(hire_date, TO_DATE_RANGE("1986-01-01T00:00:00Z..1987-01-01T00:00:00Z"))
| KEEP emp_no, hire_date, description
| SORT emp_no, description
| LIMIT 8
;

ignoreOrder:true
emp_no:integer | hire_date:date                | description:keyword
10001          | 1986-06-26T00:00:00.000Z      | 1985
10001          | 1986-06-26T00:00:00.000Z      | 1986
10001          | 1986-06-26T00:00:00.000Z      | 1987
10001          | 1986-06-26T00:00:00.000Z      | 1988
10003          | 1986-08-28T00:00:00.000Z      | 1985
10003          | 1986-08-28T00:00:00.000Z      | 1986

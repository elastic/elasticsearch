rangeContainsRangeContainingRange
required_capability: fn_range_contains

ROW outer = TO_DATE_RANGE("1900-01-01..2000-01-01"),
    inner = TO_DATE_RANGE("1950-01-01..1960-01-01"),
    overlap = TO_DATE_RANGE("1990-01-01..2010-01-01")
| EVAL contains_inner = RANGE_CONTAINS(outer, inner),
       contains_overlap = RANGE_CONTAINS(outer, overlap)
| KEEP contains_inner, contains_overlap
;

contains_inner:boolean | contains_overlap:boolean
true                   | false
;



r:date_range
2000-01-01..2010-01-01
// end::to_range-result[]
;

toRangeRoundTrip
required_capability: fn_to_range

FROM decades
| EVAL r = TO_RANGE(RANGE_MIN(date_range), RANGE_MAX(date_range))
| WHERE date_range == r
| KEEP decade
| SORT decade
;


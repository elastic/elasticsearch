// Requires range_within (TO_DATE_RANGE(keyword) support).
toDateRangeFromString
required_capability: range_within

// tag::to_date_range-str[]
ROW str = "2020-01-01T00:00:00.000Z..2021-01-01T00:00:00.000Z"
| EVAL range = TO_DATE_RANGE(str)
// end::to_date_range-str[]
;

// tag::to_date_range-str-result[]
str:keyword                                          | range:date_range
2020-01-01T00:00:00.000Z..2021-01-01T00:00:00.000Z   | 2020-01-01T00:00:00.000Z..2021-01-01T00:00:00.000Z
// end::to_date_range-str-result[]
;

toDateRangeIdentity
required_capability: range_within

FROM decades
| WHERE decade == 1900
| EVAL range = TO_DATE_RANGE(date_range)
;

date_range:date_range  | decade:integer | description:keyword | range:date_range
1900-01-01..1910-01-01 | 1900           | Edwardian Era       | 1900-01-01..1910-01-01
;

// Requires range_within (TO_DATE_RANGE(keyword) support).
toDateRangeFromShortFormat
required_capability: range_within

ROW str = "2024-06-01..2024-06-30"
| EVAL range = TO_DATE_RANGE(str)
;

str:keyword            | range:date_range
2024-06-01..2024-06-30 | 2024-06-01..2024-06-30
;

// Requires range_within (TO_DATE_RANGE(keyword) support).
toDateRangeWithEval
required_capability: range_within

ROW start_date = "2023-01-01T00:00:00.000Z", end_date = "2024-01-01T00:00:00.000Z"
| EVAL range_str = CONCAT(start_date, "..", end_date)
| EVAL range = TO_DATE_RANGE(range_str)
| KEEP start_date, end_date, range
;

start_date:keyword              | end_date:keyword                | range:date_range
2023-01-01T00:00:00.000Z        | 2024-01-01T00:00:00.000Z        | 2023-01-01T00:00:00.000Z..2024-01-01T00:00:00.000Z
;

// Requires range_within (TO_DATE_RANGE(keyword) support).
toDateRangeSingleDay
required_capability: range_within

ROW str = "2024-07-04T00:00:00.000Z..2024-07-05T00:00:00.000Z"
| EVAL range = TO_DATE_RANGE(str)
;

str:keyword                                          | range:date_range
2024-07-04T00:00:00.000Z..2024-07-05T00:00:00.000Z   | 2024-07-04T00:00:00.000Z..2024-07-05T00:00:00.000Z
;

###############################################
# RANGE_WITHIN tests
###############################################

rangeWithinWithEmployees
required_capability: range_within

// tag::rangeWithin[]
FROM employees
| WHERE RANGE_WITHIN(hire_date, TO_DATE_RANGE("1985-02-01..1985-03-01"))
| KEEP emp_no, hire_date
| SORT emp_no
// end::rangeWithin[]
;

// tag::rangeWithin-result[]
emp_no:integer | hire_date:date
10009          | 1985-02-18T00:00:00.000Z
10048          | 1985-02-24T00:00:00.000Z
// end::rangeWithin-result[]
;

rangeWithinWithDateRangesTable
required_capability: range_within

FROM decades
| WHERE RANGE_WITHIN(TO_DATETIME("1955-06-15"), date_range)
| KEEP decade, description
;

decade:integer | description:keyword
1950           | Nifty Fifties
;

rangeWithinAtBoundaryStart
required_capability: range_within

FROM decades
| WHERE RANGE_WITHIN(TO_DATETIME("1950-01-01"), date_range)
| KEEP decade, description
;

decade:integer | description:keyword
1950           | Nifty Fifties
;

rangeWithinAtBoundaryEnd
required_capability: range_within

FROM decades

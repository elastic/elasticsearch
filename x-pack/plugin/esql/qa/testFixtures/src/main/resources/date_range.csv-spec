// Null propagation: null from → null result
toRangeNullFrom
required_capability: fn_to_range

ROW from_dt = TO_DATETIME("2000-01-01T00:00:00.000Z")
| EVAL r = TO_RANGE(null, from_dt)
| KEEP r
;

r:date_range
null
;

// Null propagation: null to → null result
toRangeNullTo
required_capability: fn_to_range

ROW from_dt = TO_DATETIME("2000-01-01T00:00:00.000Z")
| EVAL r = TO_RANGE(from_dt, null)
| KEEP r
;

r:date_range
null
;

// Inverted bounds: to < from → warns and yields null, consistent with TO_DATE_RANGE
toRangeInvertedBounds
required_capability: fn_to_range

ROW from_dt = TO_DATETIME("2010-01-01T00:00:00.000Z"), to_dt = TO_DATETIME("2000-01-01T00:00:00.000Z")
| EVAL r = TO_RANGE(from_dt, to_dt)
| KEEP r
;
warningRegex:evaluation of \[TO_RANGE\(from_dt, to_dt\)\] failed, treating result as null. Only first 20 failures recorded.
warningRegex:java.lang.IllegalArgumentException: 'from' \[.*\] must be less than 'to' \[.*\]

r:date_range
null
;

// Multi-value input: MV from → warns and yields null.
// Uses emp_no 10039 whose birth_date and hire_date are both non-null, so MV_APPEND produces a 2-element MV datetime.
toRangeMvFromWarns
required_capability: fn_to_range

FROM employees
| WHERE emp_no == 10039
| EVAL from_mv = MV_APPEND(birth_date, hire_date)
| EVAL r = TO_RANGE(from_mv, hire_date)
| KEEP r
;
warningRegex:evaluation of \[TO_RANGE\(from_mv, hire_date\)\] failed, treating result as null. Only first 20 failures recorded.
warningRegex:java.lang.IllegalArgumentException: single-value function encountered multi-value

r:date_range
null
;

// Multi-value input: MV to → warns and yields null.
toRangeMvToWarns
required_capability: fn_to_range

FROM employees
| WHERE emp_no == 10039
| EVAL to_mv = MV_APPEND(birth_date, hire_date)
| EVAL r = TO_RANGE(birth_date, to_mv)
| KEEP r
;
warningRegex:evaluation of \[TO_RANGE\(birth_date, to_mv\)\] failed, treating result as null. Only first 20 failures recorded.
warningRegex:java.lang.IllegalArgumentException: single-value function encountered multi-value

r:date_range
null
;

// Diagnostic: bare KEEP of MV date_range to verify base data is correct (no SORT to isolate).
mvDecadesBaseData
required_capability: date_range_field_type_v6

FROM mv_decades
| KEEP decade, date_range
;

ignoreOrder:true
decade:integer | date_range:date_range
1900           | 1900-01-01T00:00:00.000Z..1910-01-01T00:00:00.000Z
1950           | [1950-01-01T00:00:00.000Z..1960-01-01T00:00:00.000Z, 1955-01-01T00:00:00.000Z..1965-01-01T00:00:00.000Z]
2000           | [1995-01-01T00:00:00.000Z..2005-01-01T00:00:00.000Z, 2000-01-01T00:00:00.000Z..2010-01-01T00:00:00.000Z]
;

// (date, date_range): MV date_range → null. 1955 is in 1950's SV equivalent but 1950/2000 are MV.
rangeWithinPointMultiValue
required_capability: date_range_field_type_v6


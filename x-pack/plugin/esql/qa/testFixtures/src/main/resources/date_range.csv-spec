| LOOKUP JOIN date_ranges ON join_key
| WHERE RANGE_WITHIN(TO_DATETIME("1985-06-15"), date_range)
| KEEP emp_no, description
| SORT emp_no
| LIMIT 5
;

ignoreOrder:true
emp_no:integer | description:keyword
10001          | 1985
10002          | 1985
10003          | 1985
10004          | 1985
10005          | 1985
;


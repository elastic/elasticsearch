TS exp_histo_sample 
 | WHERE NOT STARTS_WITH(instance, "dummy") 
 | STATS min = MIN(responseTime), max = MAX(responseTime), median = MEDIAN(responseTime), p75 = PERCENTILE(responseTime,75), sum = SUM(responseTime), avg = AVG(responseTime) BY instance

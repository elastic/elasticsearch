sum for exponential histogram docs
required_capability: exponential_histogram_tech_preview
required_capability: ts_command_v0

// tag::sumExpHistoForDocs[]
TS exp_histo_sample
| WHERE instance == "instance-0"
| STATS total = ROUND(SUM(responseTime), 2)
// end::sumExpHistoForDocs[]
;


operatorLikeRLike
required_capability: external_command

EXTERNAL "{{employees}}"
| KEEP emp_no, first_name
| WHERE first_name LIKE "Hi*"
| WHERE first_name RLIKE "Hi.*"
| SORT emp_no
;


// DROP and RENAME commands with EXTERNAL

dropColumn
required_capability: external_command

EXTERNAL "{{employees}}"
| DROP birth_date, gender, hire_date, languages*, height*, still_hired, avg_worked_seconds, job_positions, is_rehired, salary_change*
| SORT emp_no
| LIMIT 3;


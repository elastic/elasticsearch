10002          | "Bezalel"          | "Simmel"          | 56371
10003          | "Parto"            | "Bamford"         | 61805
;

renameColumn
required_capability: external_command

EXTERNAL "{{employees}}"
| RENAME emp_no AS employee_id, first_name AS given_name
| KEEP employee_id, given_name, last_name, salary
| SORT employee_id
| LIMIT 3;


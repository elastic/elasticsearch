// Shared tests for standalone external files (Parquet, CSV, etc.)
// Uses {{employees_no_mv}} template that gets replaced with the actual path based on storage backend and format
//
// Authored as FROM <dataset>: each test declares its source via a `dataset:` directive. On dataset-capable
// backends (S3) the flipped format ITs (ORC/NDJSON/Java-Parquet/multi-node) register the dataset and run the
// FROM query verbatim; every other backend and the generic EsqlSpecTestCase families rebuild the equivalent
// EXTERNAL query. employees_no_mv has no index equivalent (bare name kept); web_logs collides with the ES|QL
// web_logs index twin, so that dataset is named web_logs_ds.

readAllEmployees
required_capability: external_command
dataset: employees_no_mv: "{{employees_no_mv}}"

FROM employees_no_mv
| KEEP emp_no, first_name, last_name, birth_date, gender, hire_date, languages, height, salary, still_hired
| SORT emp_no
| LIMIT 5;

emp_no:integer | first_name:keyword | last_name:keyword | birth_date:date          | gender:keyword | hire_date:date           | languages:integer | height:double | salary:integer | still_hired:boolean
10001          | "Georgi"           | "Facello"         | 1953-09-02T00:00:00.000Z | "M"            | 1986-06-26T00:00:00.000Z | 2                 | 2.03          | 57305          | true
10002          | "Bezalel"          | "Simmel"          | 1964-06-02T00:00:00.000Z | "F"            | 1985-11-21T00:00:00.000Z | 5                 | 2.08          | 56371          | true
10003          | "Parto"            | "Bamford"         | 1959-12-03T00:00:00.000Z | "M"            | 1986-08-28T00:00:00.000Z | 4                 | 1.83          | 61805          | false
10004          | "Chirstian"        | "Koblick"         | 1954-05-01T00:00:00.000Z | "M"            | 1986-12-01T00:00:00.000Z | 5                 | 1.78          | 36174          | true
10005          | "Kyoichi"          | "Maliniak"        | 1955-01-21T00:00:00.000Z | "M"            | 1989-09-12T00:00:00.000Z | 1                 | 2.05          | 63528          | true
;


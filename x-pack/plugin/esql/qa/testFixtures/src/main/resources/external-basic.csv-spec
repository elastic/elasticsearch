uriPartsFromEval
required_capability: external_command
required_capability: external_csv_ip_support
required_capability: uri_parts_command

EXTERNAL "{{web_logs}}"
| WHERE domain == "www.elastic.co"
| URI_PARTS parts = uri
| KEEP parts.scheme, parts.domain, parts.path
| SORT parts.path
;

parts.scheme:keyword | parts.domain:keyword       | parts.path:keyword
https                | www.elastic.co             | /downloads/elasticsearch
https                | www.elastic.co             | /guide/en/elasticsearch/reference/current/esql.html
;

registeredDomainFromEval
required_capability: external_command
required_capability: external_csv_ip_support
required_capability: registered_domain_command

EXTERNAL "{{web_logs}}"
| WHERE timestamp == "2024-01-10T10:00:00.000Z"
| REGISTERED_DOMAIN rd = domain
| KEEP rd.domain, rd.registered_domain, rd.top_level_domain, rd.subdomain
;

rd.domain:keyword    | rd.registered_domain:keyword | rd.top_level_domain:keyword | rd.subdomain:keyword
www.elastic.co       | elastic.co                   | co                          | www
;


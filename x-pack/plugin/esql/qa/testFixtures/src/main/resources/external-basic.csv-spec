// TRANGE and TBUCKET require @timestamp; RENAME hire_date to @timestamp for these tests.

trangeOnHireDate
required_capability: external_command
required_capability: fn_trange

EXTERNAL "{{employees}}"
| RENAME hire_date AS @timestamp
| WHERE TRANGE("1985-01-01T00:00:00.000Z", "1986-01-01T00:00:00.000Z")
| KEEP emp_no, `@timestamp`
| SORT emp_no
| LIMIT 5
;

emp_no:integer | @timestamp:date
10002          | 1985-11-21T00:00:00.000Z
10009          | 1985-02-18T00:00:00.000Z
10013          | 1985-10-20T00:00:00.000Z
10029          | 1985-11-20T00:00:00.000Z
10048          | 1985-02-24T00:00:00.000Z
;

tbucketByHireDate
required_capability: external_command
required_capability: tbucket

EXTERNAL "{{employees}}"
| RENAME hire_date AS @timestamp
| STATS min = MIN(`@timestamp`), max = MAX(`@timestamp`) BY bucket = TBUCKET(1 year)
| SORT min
| LIMIT 5
;

min:datetime | max:datetime | bucket:datetime

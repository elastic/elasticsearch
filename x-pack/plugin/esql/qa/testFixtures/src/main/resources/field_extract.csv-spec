2020-01-01T11:38:54.751Z | 2          | infra-filebeat-6vjxr
2020-01-01T00:00:00.000Z | 1          | equal-host
2020-01-01T00:04:00.000Z | 1          | null
2020-01-01T00:07:43.000Z | 1          | devops-ci-master-blue.c.elastic-ci-prod.internal
;

// MV_EXPAND on a single-valued field_extract result is a row-preserving no-op,
// but the test pins down that the keyword output of field_extract composes
// cleanly with MV_EXPAND. Multi-valued flattened sub-fields (e.g. an
// array-valued `host.ip`) are not yet supported by FIELD_EXTRACT and are
// tracked as a follow-up.
mvExpandOnSingleValuedExtract
required_capability: field_extract_function
required_capability: flattened_datatype
required_capability: fn_field_extract

FROM flattened_otel_logs
| EVAL hn = field_extract(resource.attributes, "host.name")
| MV_EXPAND hn
| KEEP @timestamp, hn
| SORT @timestamp ASC
| LIMIT 3
;

@timestamp:date          | hn:keyword
2020-01-01T00:00:00.000Z | equal-host
2020-01-01T00:02:48.461Z | infra-filebeat-6vjxr
2020-01-01T00:04:00.000Z | null
;


// INLINE STATS appends an aggregate over the extracted sub-field to every row.
// The duplicated host (`infra-filebeat-6vjxr`, count 2) sorts first, the rest
// are unique (count 1).
inlineStatsOverFlattenedSubfield
required_capability: field_extract_function
required_capability: flattened_datatype
required_capability: fn_field_extract
required_capability: inline_stats

FROM flattened_otel_logs
| EVAL host.name = field_extract(resource.attributes, "host.name")
| INLINE STATS count = COUNT(*) BY host.name
| DROP attributes, resource.attributes
| SORT count DESC, @timestamp ASC
| LIMIT 5
;

@timestamp:date          | count:long | host.name:keyword

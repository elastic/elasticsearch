// FIELD_EXTRACT result is `keyword`, so it must compose with all the regular
// keyword-consuming functions. Spot-checks: TO_LOWER -> STARTS_WITH.
resultInToLowerStartsWith
required_capability: field_extract_function
required_capability: flattened_datatype
required_capability: fn_field_extract

FROM flattened_otel_logs
| EVAL hn = field_extract(resource.attributes, "host.name")
| WHERE STARTS_WITH(TO_LOWER(hn), "infra-filebeat-")
| STATS c = count(*)
;

c:long
5
;

// COALESCE chooses the first non-null. The first FIELD_EXTRACT call still
// emits a warning per row (path doesn't exist), and the second produces the
// host name. This test pins down null-propagation through COALESCE.
resultInCoalesceFallback
required_capability: field_extract_function
required_capability: flattened_datatype
required_capability: fn_field_extract

FROM flattened_otel_logs
| WHERE @timestamp == "2020-01-01T00:02:48.461Z"
| EVAL hn = COALESCE(field_extract(resource.attributes, "no.such"),
                     field_extract(resource.attributes, "host.name"))
| KEEP hn
;

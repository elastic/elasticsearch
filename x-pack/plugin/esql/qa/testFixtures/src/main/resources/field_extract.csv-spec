fieldExtractInSubquery
required_capability: field_extract_function
required_capability: flattened_datatype
required_capability: fn_field_extract
required_capability: subquery_in_from_command

FROM (FROM flattened_otel_logs | WHERE @timestamp >= "2020-01-01T12:00:00Z" | EVAL h_late = field_extract(resource.attributes, "host.name") | KEEP h_late),
     (FROM flattened_otel_logs | WHERE @timestamp <  "2020-01-01T12:00:00Z" | EVAL h_early = field_extract(resource.attributes, "host.name") | KEEP h_early)
| STATS d_late = COUNT_DISTINCT(h_late), d_early = COUNT_DISTINCT(h_early)
;

d_late:long | d_early:long
3           | 7
;

fieldExtractAfterSubqueriesWithRename
required_capability: field_extract_function
required_capability: flattened_datatype
required_capability: fn_field_extract
required_capability: subquery_in_from_command

FROM (FROM flattened_otel_logs | WHERE @timestamp >= "2020-01-01T12:00:00Z" | RENAME resource.attributes AS attrs_late  | KEEP attrs_late),
     (FROM flattened_otel_logs | WHERE @timestamp <  "2020-01-01T12:00:00Z" | RENAME resource.attributes AS attrs_early | KEEP attrs_early)
| EVAL h_late  = field_extract(attrs_late,  "host.name")
| EVAL h_early = field_extract(attrs_early, "host.name")
| STATS d_late = COUNT_DISTINCT(h_late), d_early = COUNT_DISTINCT(h_early)
;

d_late:long | d_early:long
3           | 7
;

fieldExtractWithLookupJoin
required_capability: field_extract_function
required_capability: flattened_datatype
required_capability: fn_field_extract
required_capability: join_lookup_v12

FROM flattened_otel_logs
| EVAL host.name = field_extract(resource.attributes, "host.name")
| LOOKUP JOIN host_threat_list ON host.name
| WHERE threat_level IS NOT NULL
| KEEP @timestamp, host.name, threat_level
| SORT @timestamp
;

@timestamp:date          | host.name:keyword     | threat_level:keyword
2020-01-01T00:02:48.461Z | infra-filebeat-6vjxr  | high
2020-01-01T11:38:54.751Z | infra-filebeat-6vjxr  | high
2020-01-01T11:43:13.255Z | filebeat-6t7v6        | low
;

// Numeric leaves in a flattened root come out as their stringified value
// in doc values, so FIELD_EXTRACT returns them as a keyword.

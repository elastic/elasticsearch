57      | M
10      | Unknown
;

fillNullCompositionInEval
required_capability: fillnull

FROM employees
| WHERE emp_no IN (10020, 10021, 10022)
| FILLNULL WITH 0 languages
| EVAL bonus = languages + 10
| KEEP emp_no, languages, bonus
| SORT emp_no
;

emp_no:integer | languages:integer | bonus:integer
10020           | 0                 | 10
10021           | 0                 | 10
10022           | 0                 | 10
;


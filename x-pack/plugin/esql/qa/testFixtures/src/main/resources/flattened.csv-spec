lookupJoinBringsInFlattenedField
required_capability: flattened_datatype
required_capability: flattened_datatype_sorted_keys
required_capability: join_lookup_v12
required_capability: fn_field_extract

FROM flattened_otel_logs
| EVAL host_name = FIELD_EXTRACT(resource.attributes, "host.name")
| LOOKUP JOIN host_info_lookup ON host_name
| WHERE info IS NOT NULL
| SORT @timestamp
| LIMIT 3
| KEEP @timestamp, host_name, info
;


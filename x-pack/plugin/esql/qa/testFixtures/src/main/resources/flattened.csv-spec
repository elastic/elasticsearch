FROM flattened_otel_logs
| WHERE @timestamp == "2020-01-01T11:38:54.751Z" OR @timestamp == "2020-01-01T21:38:06.655Z"
| STATS v = VALUES(resource.attributes)
| MV_EXPAND v
| EVAL key = FIELD_EXTRACT(v, "agent.id")
| SORT key
| KEEP v
;


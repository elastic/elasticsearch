required_capability: flattened_datatype
required_capability: fn_mv_append_flattened
required_capability: fn_field_extract
request_stored: skip

FROM flattened_many
| WHERE id == 1
| EVAL mv = MV_APPEND(flat_a, flat_b)
| MV_EXPAND mv
| EVAL key = FIELD_EXTRACT(mv, "k")
| SORT key
| KEEP id, mv
;


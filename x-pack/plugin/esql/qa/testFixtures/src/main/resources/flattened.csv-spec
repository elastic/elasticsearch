mvContains
required_capability: flattened_datatype
required_capability: fn_mv_contains_flattened

FROM flattened_many
| EVAL c = MV_CONTAINS(flat_a, flat_c)
| KEEP id, c
| SORT id
;

id:integer | c:boolean
1          | true
2          | false
3          | false
4          | false
5          | true
;


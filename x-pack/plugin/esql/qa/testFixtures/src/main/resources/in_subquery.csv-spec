grokInsideInSubquery
required_capability: where_in_subquery_without_view

FROM employees
| WHERE first_name IN (
    FROM employees
    | GROK CONCAT(first_name, " ", last_name) "%{WORD:a} %{WORD:b}"
    | WHERE b LIKE "S*"
    | KEEP a
  )
| SORT emp_no
| KEEP emp_no, first_name
| LIMIT 5
;


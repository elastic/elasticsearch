inSubqueryMetadataIndexTautology
required_capability: where_in_subquery_without_view

FROM employees METADATA _index
| WHERE _index IN (FROM employees METADATA _index | KEEP _index)
| KEEP emp_no, _index
| SORT emp_no
| LIMIT 3
;


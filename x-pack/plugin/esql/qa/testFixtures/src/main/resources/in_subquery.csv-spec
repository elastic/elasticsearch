inSubqueryWithStatsInsideInSubquery
required_capability: where_in_subquery_without_view

FROM employees
| WHERE salary IN (FROM employees | STATS m = max(salary) by languages | KEEP m)
| KEEP emp_no, salary, languages
| SORT emp_no
;


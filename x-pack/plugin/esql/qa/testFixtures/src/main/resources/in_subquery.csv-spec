grokBeforeInSubquery
required_capability: where_in_subquery_without_view

FROM employees
| GROK CONCAT(first_name, " ", last_name) "%{WORD:a} %{WORD:b}"
| WHERE a IN (FROM employees | WHERE salary > 70000 | KEEP first_name)
| SORT emp_no
| KEEP emp_no, a, b
| LIMIT 5
;


10019          | 73717          | 1
10029          | 74999          | null
10045          | 74970          | 3
10094          | 66817          | 5
10099          | 73578          | 2
;

inSubqueryWithStatsBeforeAndAfterInSubquery
required_capability: where_in_subquery_without_view

FROM employees
| STATS cnt = COUNT(*) BY gender
| WHERE gender IN (FROM employees | KEEP gender)
| STATS cnt = COUNT(*)
;

cnt:long
2
;

inSubqueryWithStatsInsideAndAfterInSubquery
required_capability: where_in_subquery_without_view


rerankBeforeInSubquery
required_capability: where_in_subquery_without_view
required_capability: rerank
required_capability: match_operator_colon
required_capability: routing_function_update

FROM books METADATA _score
| WHERE title:"war and peace" AND author:"Tolstoy"
| SORT _score DESC, book_no ASC
| LIMIT 5
| RERANK "war and peace" ON title WITH { "inference_id" : "test_reranker" }
| WHERE book_no IN (FROM books | EVAL bn = "5327" | KEEP bn)
| EVAL _score = ROUND(_score, 2)
| KEEP book_no, title, _score
;

book_no:keyword | title:text    | _score:double
5327            | War and Peace | 0.08
;

rerankInsideInSubquery
required_capability: where_in_subquery_without_view
required_capability: rerank
required_capability: match_operator_colon
required_capability: routing_function_update

FROM books
| WHERE book_no IN (
    FROM books METADATA _score
    | WHERE title:"war and peace" AND author:"Tolstoy"
    | SORT _score DESC, book_no ASC
    | LIMIT 5
    | RERANK "war and peace" ON title WITH { "inference_id" : "test_reranker" }
    | EVAL _score = ROUND(_score, 2)
    | WHERE _score > 0.05
    | KEEP book_no
  )
| KEEP book_no, title
;

book_no:keyword | title:text
5327            | War and Peace
;


mainFromInSubqueryTsWithAvgOverTimeTBucketInInSubquery
required_capability: where_in_subquery_without_view
required_capability: subquery_with_ts
required_capability: ts_command_v0
required_capability: tbucket

FROM employees
| EVAL cluster = "qa"
| WHERE cluster IN (TS k8s
                    | STATS avg_cost = avg(avg_over_time(network.cost)) BY cluster, tb = tbucket(5minute)
                    | STATS top = max(avg_cost) BY cluster
                    | WHERE top > 0
                    | KEEP cluster)
| SORT emp_no
| KEEP emp_no, first_name
| LIMIT 3
;

emp_no:integer | first_name:keyword
10001          | Georgi
10002          | Bezalel
10003          | Parto
;

mainFromInSubqueryTsWithSumOverTimeWithoutGroupingInInSubquery
skip_flattened_rewrite: without_unsupported
required_capability: where_in_subquery_without_view
required_capability: subquery_with_ts
required_capability: ts_command_v0
required_capability: esql_without_grouping

FROM employees
| EVAL m = 0.0
| WHERE m IN (TS k8s
              | STATS m = sum(sum_over_time(network.cost)) BY WITHOUT(pod, region)
              | KEEP m)
| STATS cnt = COUNT(*)
;

cnt:long
0
;


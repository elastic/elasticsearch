| WHERE cluster IN (TS k8s
                    | STATS r = max(irate(network.total_bytes_in)) BY cluster
                    | WHERE r > 5
                    | KEEP cluster)
| SORT emp_no
| KEEP emp_no, first_name
| LIMIT 3
;


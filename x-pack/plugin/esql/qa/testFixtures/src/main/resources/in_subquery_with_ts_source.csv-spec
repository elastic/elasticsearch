mainFromNotInSubqueryTsWithIncreaseInInSubquery
required_capability: where_in_subquery_without_view
required_capability: subquery_with_ts
required_capability: ts_command_v0

FROM employees
| EVAL cluster = "fake_cluster"
| WHERE cluster NOT IN (TS k8s
                        | STATS inc = max(increase(network.total_bytes_in)) BY cluster
                        | WHERE inc > 1000
                        | KEEP cluster)
| STATS cnt = COUNT(*)
;

cnt:long
100
;

mainFromInSubqueryTsWithCountOverTimeInInSubquery
required_capability: where_in_subquery_without_view
required_capability: subquery_with_ts
required_capability: ts_command_v0
required_capability: tbucket

FROM employees
| EVAL cluster = "staging"
| WHERE cluster IN (TS k8s
                    | STATS samples = sum(count_over_time(network.bytes_in)) BY cluster, tb = tbucket(5minute)
                    | STATS total_samples = sum(samples) BY cluster
                    | WHERE total_samples > 5
                    | KEEP cluster)
| STATS cnt = COUNT(*)
;

cnt:long
100
;

mainFromInSubqueryTsWithMultipleAggsInInSubquery
required_capability: where_in_subquery_without_view
required_capability: subquery_with_ts
required_capability: ts_command_v0
required_capability: rate_with_interpolation_v2

FROM employees
| EVAL cluster = "qa"
| WHERE cluster IN (TS k8s
                    | STATS r = max(rate(network.total_bytes_in)),
                            top = max(max_over_time(network.cost)),
                            samples = max(count_over_time(network.bytes_in)) BY cluster
                    | WHERE r > 5 AND top > 5 AND samples > 5
                    | KEEP cluster)
| SORT emp_no
| KEEP emp_no, first_name
| LIMIT 3
;

emp_no:integer | first_name:keyword
10001          | Georgi
10002          | Bezalel
10003          | Parto
;

mainFromInSubqueryTsWithMultipleTsSubqueryInInSubquery
required_capability: where_in_subquery_without_view
required_capability: subquery_with_ts
required_capability: ts_command_v0

FROM employees
| EVAL cluster = "qa"
| WHERE cluster IN (FROM
                       (TS k8s | STATS m = max(to_long(network.total_bytes_in)) BY cluster | WHERE m > 10500 | KEEP cluster),
                       (TS k8s | STATS m = max(to_long(network.total_bytes_in)) BY cluster | WHERE m < 8000 | KEEP cluster)
                   )
| STATS cnt = COUNT(*)
;

cnt:long
100
;


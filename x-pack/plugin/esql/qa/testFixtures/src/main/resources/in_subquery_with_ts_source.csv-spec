mainFromInSubqueryTsWithMinOverTimeInInSubquery
required_capability: where_in_subquery_without_view
required_capability: subquery_with_ts
required_capability: ts_command_v0

FROM employees
| EVAL cluster = "prod"
| WHERE cluster IN (TS k8s
                    | STATS min_cost = min(min_over_time(network.cost)) BY cluster
                    | WHERE min_cost < 100
                    | KEEP cluster)
| STATS cnt = COUNT(*)
;

cnt:long
100

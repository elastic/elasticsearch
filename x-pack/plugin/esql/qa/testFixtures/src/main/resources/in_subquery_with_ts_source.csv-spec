mainFromNotInSubqueryFromWithConstantInNotInSubquery
required_capability: where_in_subquery_without_view

FROM employees
| EVAL cluster = "missing_cluster"
| WHERE cluster NOT IN (FROM k8s
                        | STATS c = COUNT(*) BY cluster
                        | KEEP cluster)
| STATS cnt = COUNT(*)
;

cnt:long
100
;

// main query from command, subquery mixed of from/ts/row command

mainFromInSubqueryWithMixedRowFromTs
skip_flattened_rewrite: row_branch_in_from_union_inflates_recovery_scope
required_capability: where_in_subquery_without_view
required_capability: subquery_in_from_command
required_capability: subquery_with_ts
required_capability: subquery_with_row
required_capability: ts_command_v0

FROM employees
| EVAL cluster = "qa"
| WHERE cluster IN (FROM
                       (ROW cluster = "synthetic"),
                       (FROM employees | WHERE emp_no == 10001 | EVAL cluster = "from_branch" | KEEP cluster),
                       (TS k8s | STATS m = max(to_long(network.total_bytes_in)) BY cluster | WHERE m > 10000 | KEEP cluster)
                   )
| STATS cnt = COUNT(*)
;

cnt:long
100
;

// main query ts command, subquery ts command

mainTsInSubqueryTs
required_capability: where_in_subquery_without_view
required_capability: subquery_with_ts
required_capability: ts_command_v0

TS k8s
| WHERE cluster IN (TS k8s
                    | STATS max_bytes = max(to_long(network.total_bytes_in)) BY cluster
                    | WHERE max_bytes > 10000
                    | KEEP cluster)
| STATS max_bytes = max(to_long(network.total_bytes_in)) BY cluster
| SORT cluster
;

max_bytes:long | cluster:keyword
10277          | prod
10797          | qa
;

mainTsNotInSubqueryTs
required_capability: where_in_subquery_without_view
required_capability: subquery_with_ts
required_capability: ts_command_v0

TS k8s
| WHERE cluster NOT IN (TS k8s
                        | STATS max_bytes = max(to_long(network.total_bytes_in)) BY cluster
                        | WHERE max_bytes > 10000
                        | KEEP cluster)
| STATS max_bytes = max(to_long(network.total_bytes_in)) BY cluster
| SORT cluster
;

max_bytes:long | cluster:keyword
7403           | staging
;

mainTsInSubqueryTsWithFilter
required_capability: where_in_subquery_without_view
required_capability: subquery_with_ts
required_capability: ts_command_v0

TS k8s
| WHERE pod IN (TS k8s
                | WHERE pod != "one"
                | STATS max_bytes = max(to_long(network.total_bytes_in)) BY pod
                | WHERE max_bytes > 10500
                | KEEP pod)
| STATS max_bytes = max(to_long(network.total_bytes_in)) BY pod
| SORT pod
;

max_bytes:long | pod:keyword
10797          | three
;

mainTsNotInSubqueryTsWithFilter
required_capability: where_in_subquery_without_view
required_capability: subquery_with_ts
required_capability: ts_command_v0

TS k8s
| WHERE cluster NOT IN (TS k8s
                        | WHERE cluster != "staging"
                        | STATS max_bytes = max(to_long(network.total_bytes_in)) BY cluster
                        | WHERE max_bytes > 10500
                        | KEEP cluster)
| STATS max_bytes = max(to_long(network.total_bytes_in)) BY cluster
| SORT cluster
;

max_bytes:long | cluster:keyword
10277          | prod
7403           | staging
;

mainTsInSubqueryTsWithEvalFilter
required_capability: where_in_subquery_without_view
required_capability: subquery_with_ts
required_capability: ts_command_v0

TS k8s
| WHERE cluster IN (TS k8s
                    | STATS max_bytes = max(to_long(network.total_bytes_in)) BY cluster
                    | EVAL high = max_bytes > 10500
                    | WHERE high
                    | KEEP cluster)
| STATS max_bytes = max(to_long(network.total_bytes_in)) BY cluster
| SORT cluster
;

max_bytes:long | cluster:keyword
10797          | qa
;

mainTsInSubqueryTsWithRateBucket
required_capability: where_in_subquery_without_view
required_capability: subquery_with_ts
required_capability: ts_command_v0
required_capability: rate_with_interpolation_v2

TS k8s
| WHERE cluster IN (TS k8s
                    | WHERE cluster == "prod"
                    | STATS r = max(rate(network.total_bytes_in)) BY tb = bucket(@timestamp, 5minute), cluster
                    | KEEP cluster)
| STATS max_bytes = max(to_long(network.total_bytes_in)) BY cluster
| SORT cluster
;

max_bytes:long | cluster:keyword
10277          | prod
;

mainTsInSubqueryTsConjunctive
required_capability: where_in_subquery_without_view
required_capability: subquery_with_ts
required_capability: ts_command_v0

TS k8s
| WHERE cluster IN (TS k8s
                    | STATS max_bytes = max(to_long(network.total_bytes_in)) BY cluster
                    | WHERE max_bytes > 10000
                    | KEEP cluster)
    AND pod == "two"
| STATS max_bytes = max(to_long(network.total_bytes_in)) BY cluster
| SORT cluster
;

max_bytes:long | cluster:keyword
10277          | prod
8568           | qa
;

mainTsInSubqueryTsDisjunctive
required_capability: where_in_subquery_without_view
required_capability: subquery_with_ts
required_capability: ts_command_v0

TS k8s
| WHERE cluster NOT IN (TS k8s
                        | STATS max_bytes = max(to_long(network.total_bytes_in)) BY cluster
                        | WHERE max_bytes > 10000
                        | KEEP cluster)
     OR cluster == "qa"
| STATS max_bytes = max(to_long(network.total_bytes_in)) BY cluster
| SORT cluster
;

max_bytes:long | cluster:keyword

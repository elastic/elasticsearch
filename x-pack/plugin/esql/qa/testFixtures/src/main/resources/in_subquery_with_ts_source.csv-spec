//
// CSV spec for IN and NOT IN subqueries with TS source command
//

// main query from command, subquery ts command
mainFromInSubqueryTsBasic
required_capability: where_in_subquery_without_view
required_capability: subquery_with_ts
required_capability: ts_command_v0

FROM sample_data
| WHERE client_ip IN (TS k8s
                      | STATS m = max(to_long(network.total_bytes_in)) BY client.ip
                      | KEEP client.ip)
| SORT @timestamp
| KEEP @timestamp, client_ip
;

@timestamp:datetime | client_ip:ip
;

mainFromNotInSubqueryTsBasic
required_capability: where_in_subquery_without_view
required_capability: subquery_with_ts
required_capability: ts_command_v0

FROM sample_data
| WHERE client_ip NOT IN (TS k8s
                          | STATS m = max(to_long(network.total_bytes_in)) BY client.ip
                          | KEEP client.ip)
| STATS cnt = COUNT(*)
;

cnt:long
7
;

mainFromWithEvalInSubqueryTs
required_capability: where_in_subquery_without_view
required_capability: subquery_with_ts
required_capability: ts_command_v0

FROM employees
| EVAL env = "qa"
| WHERE env IN (TS k8s
                | STATS max_bytes = max(to_long(network.total_bytes_in)) BY cluster
                | WHERE max_bytes > 10500
                | KEEP cluster)
| STATS cnt = COUNT(*)
;

cnt:long
100
;

mainFromWithEvalNotInSubqueryTs
required_capability: where_in_subquery_without_view
required_capability: subquery_with_ts
required_capability: ts_command_v0

FROM employees
| EVAL b = to_long(99999)
| WHERE b NOT IN (TS k8s
                  | STATS max_bytes = max(to_long(network.total_bytes_in)) BY cluster
                  | KEEP max_bytes)
| STATS cnt = COUNT(*)
;

cnt:long
100
;

mainFromWithConstantStringInSubqueryTs
required_capability: where_in_subquery_without_view
required_capability: subquery_with_ts
required_capability: ts_command_v0

FROM employees
| WHERE "staging" IN (TS k8s
                      | STATS max_bytes = max(to_long(network.total_bytes_in)) BY cluster
                      | WHERE max_bytes < 8000
                      | KEEP cluster)

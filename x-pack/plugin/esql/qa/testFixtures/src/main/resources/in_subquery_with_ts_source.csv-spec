mainFromInSubqueryTsConjunctive
required_capability: where_in_subquery_without_view
required_capability: subquery_with_ts
required_capability: ts_command_v0

FROM employees
| EVAL env = "qa"
| WHERE env IN (TS k8s
                | STATS max_bytes = max(to_long(network.total_bytes_in)) BY cluster
                | WHERE max_bytes > 10500
                | KEEP cluster)
    AND salary > 70000
| STATS cnt = COUNT(*)
;

cnt:long
8
;

mainFromInSubqueryTsDisjunctive
required_capability: where_in_subquery_without_view
required_capability: subquery_with_ts
required_capability: ts_command_v0

FROM employees
| EVAL env = "prod"
| WHERE env IN (TS k8s
                | STATS max_bytes = max(to_long(network.total_bytes_in)) BY cluster
                | WHERE max_bytes > 10500
                | KEEP cluster)
     OR salary > 74000
| STATS cnt = COUNT(*)
;

cnt:long
3
;

mainFromInSubqueryTsWithRate
required_capability: where_in_subquery_without_view
required_capability: subquery_with_ts
required_capability: ts_command_v0

FROM employees
| EVAL cluster = "qa"
| WHERE cluster IN (TS k8s
                    | STATS r = max(rate(network.total_bytes_in)) BY cluster
                    | WHERE r > 10
                    | KEEP cluster)
| SORT emp_no
| KEEP emp_no, first_name
| LIMIT 3
;

emp_no:integer | first_name:keyword
10001          | Georgi
10002          | Bezalel
10003          | Parto
;

mainFromNotInSubqueryTsWithRate
required_capability: where_in_subquery_without_view
required_capability: subquery_with_ts
required_capability: ts_command_v0

FROM employees
| EVAL cluster = "prod"
| WHERE cluster NOT IN (TS k8s
                        | STATS r = max(rate(network.total_bytes_in)) BY cluster
                        | WHERE r > 10
                        | KEEP cluster)
| SORT emp_no
| KEEP emp_no, first_name
| LIMIT 3
;

emp_no:integer | first_name:keyword
10001          | Georgi
10002          | Bezalel
10003          | Parto
;

mainFromInSubqueryTsWithWithoutAndRateInNestedInSubquery
skip_flattened_rewrite: without_unsupported
required_capability: where_in_subquery_without_view
required_capability: subquery_with_ts
required_capability: ts_command_v0
required_capability: esql_without_grouping
required_capability: where_in_subquery_with_ts

FROM employees
| EVAL total_cost = 26.5
| WHERE total_cost IN (TS k8s
                       | WHERE cluster IN (TS k8s
                                           | STATS r = max(rate(network.total_bytes_in)) BY cluster
                                           | WHERE r > 10
                                           | KEEP cluster)
                       | STATS total_cost = sum(network.cost) BY WITHOUT(pod, region)
                       | KEEP total_cost)
| SORT emp_no
| KEEP emp_no, first_name
| LIMIT 3
;

emp_no:integer | first_name:keyword
10001          | Georgi
10002          | Bezalel
10003          | Parto
;

mainFromInSubqueryTsWithMaxOverTimeInSubquery
required_capability: where_in_subquery_without_view
required_capability: subquery_with_ts
required_capability: ts_command_v0

FROM employees
| EVAL cluster = "qa"
| WHERE cluster IN (TS k8s
                    | STATS m = max(max_over_time(network.bytes_in)) BY cluster
                    | WHERE m > 0
                    | KEEP cluster)
| SORT emp_no
| KEEP emp_no, first_name
| LIMIT 3
;

emp_no:integer | first_name:keyword
10001          | Georgi
10002          | Bezalel
10003          | Parto
;


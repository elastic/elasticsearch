;

ip:keyword
2602:306:33d3:8000::3257:9652
;


dottedPrefix
required_capability: ip_location_command

ROW ip = "2602:306:33d3:8000::3257:9652"
| IP_LOCATION a.b.c = ip WITH { "properties": ["country_iso_code", "city_name"] }
| KEEP a.b.c.country_iso_code, a.b.c.city_name
;

a.b.c.country_iso_code:keyword | a.b.c.city_name:keyword
US                              | Homestead
;



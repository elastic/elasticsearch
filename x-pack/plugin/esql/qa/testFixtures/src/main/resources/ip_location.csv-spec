basic
required_capability: ip_location_command

// tag::basic[]
ROW ip = "2602:306:33d3:8000::3257:9652"
| IP_LOCATION g = ip
| KEEP g.country_iso_code, g.country_name, g.continent_name, g.region_iso_code, g.region_name, g.city_name
// end::basic[]
;

// tag::basic-result[]
g.country_iso_code:keyword | g.country_name:keyword | g.continent_name:keyword | g.region_iso_code:keyword | g.region_name:keyword | g.city_name:keyword
US                         | United States          | North America            | US-FL                     | Florida               | Homestead
// end::basic-result[]
;


withCountryDatabase
required_capability: ip_location_command

ROW ip = "82.170.213.79"
| IP_LOCATION g = ip WITH { "database_file": "GeoLite2-Country.mmdb" }
| KEEP g.*
;

g.country_iso_code:keyword | g.country_name:keyword | g.continent_name:keyword
NL                         | Netherlands            | Europe
;


propertiesFilter
required_capability: ip_location_command

ROW ip = "2602:306:33d3:8000::3257:9652"
| IP_LOCATION g = ip WITH { "properties": ["country_iso_code", "city_name"] }
| KEEP g.*
;

g.country_iso_code:keyword | g.city_name:keyword
US                         | Homestead
;



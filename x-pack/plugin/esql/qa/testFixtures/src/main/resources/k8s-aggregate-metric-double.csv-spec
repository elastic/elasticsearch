17         | qa              | three
52         | qa              | two
14         | staging         | one
19         | staging         | three
30         | staging         | two
;

ImplicitCastingWithBinaryOperatorAndThenStats
required_capability: ts_command_v0
required_capability: aggregate_metric_double_binary_operators
TS k8s, k8s_unmapped, k8s-downsampled
| WHERE network.eth0.tx > 512.0
| STATS min = min(min_over_time(network.eth0.tx)), avg = round(avg(avg_over_time(network.eth0.tx)), 3) by cluster, pod
| sort cluster, pod
;

min:double | avg:double | cluster:keyword | pod:keyword

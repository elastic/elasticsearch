ImplicitCastingWithBinaryOperatorCountFrom
required_capability: ts_command_v0
required_capability: aggregate_metric_double_binary_operators
FROM k8s, k8s_unmapped, k8s-downsampled | STATS count = count(network.eth0.tx) WHERE network.eth0.tx > 512.0 BY cluster, pod | sort cluster, pod
;

count:long | cluster:keyword | pod:keyword

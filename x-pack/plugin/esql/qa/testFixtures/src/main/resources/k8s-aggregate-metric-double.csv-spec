AggregateMetricDoubleEquals
required_capability: ts_command_v0
required_capability: aggregate_metric_double_binary_operators
TS k8s-downsampled
| WHERE network.eth0.tx == 605.0 OR network.eth0.tx == 512.0 OR network.eth0.rx == 924.5
| SORT @timestamp, cluster, pod
| KEEP @timestamp, cluster, pod, network.eth0.tx, network.eth0.rx
;

@timestamp:datetime      | cluster:keyword | pod:keyword | network.eth0.tx:aggregate_metric_double               | network.eth0.rx:aggregate_metric_double

# Tests for features specific to aggregate_metric_double

AggregateMetricDoubleLessThan
required_capability: ts_command_v0
required_capability: aggregate_metric_double_binary_operators
TS k8s-downsampled
| WHERE network.eth0.tx < 512.0
| SORT @timestamp, cluster, pod
| KEEP @timestamp, cluster, pod, network.eth0.tx
;


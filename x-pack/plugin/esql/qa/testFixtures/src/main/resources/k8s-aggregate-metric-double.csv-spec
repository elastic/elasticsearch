AggregateMetricDoubleStatsAfterBinaryOperator
required_capability: ts_command_v0
required_capability: aggregate_metric_double_binary_operators
TS k8s-downsampled
| WHERE network.eth0.tx > 500.0
| STATS min_tx = MIN(network.eth0.tx), max_tx = MAX(network.eth0.tx) BY pod
| SORT pod
;

min_tx:double | max_tx:double | pod:keyword
512.0         | 998.0         | one
644.0         | 734.0         | three
540.0         | 1251.0        | two
;

AggregateMetricDoubleEvalAfterBinaryOperator
required_capability: ts_command_v0
required_capability: aggregate_metric_double_binary_operators
TS k8s-downsampled
| WHERE cluster == "qa" AND pod == "three"
| EVAL is_high = network.eth0.tx > 300.0
| SORT @timestamp
| KEEP @timestamp, cluster, pod, network.eth0.tx, is_high
;

@timestamp:datetime      | cluster:keyword | pod:keyword | network.eth0.tx:aggregate_metric_double                 | is_high:boolean
2024-05-09T23:30:00.000Z | qa              | three       | {"min":605.0,"max":605.0,"sum":605.0,"value_count":1}   | true
2024-05-09T23:40:00.000Z | qa              | three       | {"min":321.0,"max":685.0,"sum":1932.0,"value_count":3}  | true
2024-05-09T23:50:00.000Z | qa              | three       | {"min":243.0,"max":398.0,"sum":2585.0,"value_count":10} | false
;

AggregateMetricDoubleInlineFilterInStats
required_capability: ts_command_v0
required_capability: aggregate_metric_double_binary_operators
TS k8s-downsampled

avg_over_time_older_than_10d
required_capability: ts_command_v0
required_capability: aggregate_metric_double_v0
TS k8s-downsampled 
| WHERE cluster == "qa" AND @timestamp < now() - 10 day 
| STATS cost = avg(avg_over_time(network.eth0.rx)) BY pod, time_bucket = bucket(@timestamp, 10minute) 
| EVAL cost = round(cost, 4)
| KEEP cost, pod, time_bucket
| SORT time_bucket, pod 
| LIMIT 5;


eval_on_avg_over_time
required_capability: ts_command_v0
TS k8s 
| STATS max_bytes = avg(avg_over_time(network.bytes_in)) BY cluster, time_bucket = bucket(@timestamp, 10minute) 
| EVAL kb_minus_offset = (max_bytes - 100) / 1000.0 
| EVAL max_bytes = round(max_bytes, 4), kb_minus_offset = round(kb_minus_offset, 4)
| KEEP max_bytes, cluster, time_bucket, kb_minus_offset
| SORT time_bucket, cluster 
| LIMIT 10;


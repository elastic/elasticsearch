// Instant-query coverage for PromQL specific behavior.
// Keep this separate from the range-query spec so the test intent is obvious.

instant_time_scalar_at_0003
required_capability: promql_command_v0
required_capability: promql_instant_query
required_capability: promql_time

PROMQL index=k8s time="2024-05-10T00:03:00.000Z" result=(time());

result:double | step:datetime   
1.71529938E9  | 2024-05-10T00:03:00.000Z
;

instant_time_scalar_at_0010
required_capability: promql_command_v0
required_capability: promql_instant_query
required_capability: promql_time

PROMQL index=k8s time="2024-05-10T00:10:00.000Z" result=(time());

result:double | step:datetime
1.7152998E9   | 2024-05-10T00:10:00.000Z
;

instant_first_over_time_clients
required_capability: promql_command_v0
required_capability: promql_instant_query

PROMQL index=k8s time="2024-05-10T00:03:00.000Z" clients=(avg by (cluster) (first_over_time(network.eth0.currently_connected_clients[1m])))
| SORT cluster;

clients:double | step:datetime            | cluster:keyword
659.5          | 2024-05-10T00:03:00.000Z | prod
565.0          | 2024-05-10T00:03:00.000Z | qa
426.5          | 2024-05-10T00:03:00.000Z | staging
;

instant_last_over_time_clients
required_capability: promql_command_v0
required_capability: promql_instant_query

PROMQL index=k8s time="2024-05-10T00:03:00.000Z" clients=(avg by (cluster) (last_over_time(network.eth0.currently_connected_clients[1m])))
| SORT cluster;

clients:double | step:datetime            | cluster:keyword
632.5          | 2024-05-10T00:03:00.000Z | prod
565.0          | 2024-05-10T00:03:00.000Z | qa
205.0          | 2024-05-10T00:03:00.000Z | staging
;

// `offset 3m` at time=00:06 evaluates at 00:03, reproducing instant_last_over_time_clients with a step label of 00:06.
instant_offset_modifier
required_capability: promql_command_v0
required_capability: promql_instant_query
required_capability: promql_offset_modifier

PROMQL index=k8s time="2024-05-10T00:06:00.000Z" clients=(avg by (cluster) (last_over_time(network.eth0.currently_connected_clients[1m] offset 3m)))
| SORT cluster;

clients:double | step:datetime            | cluster:keyword
632.5          | 2024-05-10T00:06:00.000Z | prod
565.0          | 2024-05-10T00:06:00.000Z | qa
205.0          | 2024-05-10T00:06:00.000Z | staging
;


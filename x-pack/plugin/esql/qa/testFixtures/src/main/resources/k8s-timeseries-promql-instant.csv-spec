instant_scalar_constant_time
required_capability: promql_command_v0
required_capability: promql_instant_query
required_capability: promql_time
required_capability: fix_promql_scalar_constant_results
// time() on a non-empty index is const-folded without touching the index.
PROMQL index=k8s time="2025-01-01T00:01:00.000Z" result=(time())
| EVAL result_as_date = TO_DATETIME(result * 1000);

result:double    | step:datetime            | result_as_date:datetime
1.73568966E9     | 2025-01-01T00:01:00.000Z | 2025-01-01T00:01:00.000Z
;


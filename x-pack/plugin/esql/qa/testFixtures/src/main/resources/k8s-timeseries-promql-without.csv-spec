// Tests for PromQL `without` grouping modifier.
// `without (dim1, dim2)` groups by all dimensions except the listed ones.

// without (pod, region) = by (cluster)

without_sum_equals_by_cluster
required_capability: promql_command_v0
required_capability: promql_nested_aggregates
required_capability: tsdim_without
PROMQL index=k8s step=1h result=(sum without (pod, region) (avg_over_time(network.cost[1h])))
| SORT result;

result:double          | step:datetime            | _timeseries:keyword
17.521233974358974     | 2024-05-10T00:00:00.000Z | "{""cluster"":""staging""}"
18.032269021739133     | 2024-05-10T00:00:00.000Z | "{""cluster"":""prod""}"
20.76903735632184      | 2024-05-10T00:00:00.000Z | "{""cluster"":""qa""}"
;

without_avg_equals_by_cluster
required_capability: promql_command_v0
required_capability: promql_nested_aggregates
required_capability: tsdim_without
PROMQL index=k8s step=1h result=(avg without (pod, region) (avg_over_time(network.cost[1h])))
| SORT result;

result:double          | step:datetime            | _timeseries:keyword
5.8404113247863245     | 2024-05-10T00:00:00.000Z | "{""cluster"":""staging""}"
6.010756340579711      | 2024-05-10T00:00:00.000Z | "{""cluster"":""prod""}"
6.92301245210728       | 2024-05-10T00:00:00.000Z | "{""cluster"":""qa""}"
;


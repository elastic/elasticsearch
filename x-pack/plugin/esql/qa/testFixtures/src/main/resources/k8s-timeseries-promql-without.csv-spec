// without in binary expression

without_binary_mul_scalar
required_capability: promql_command_v0
required_capability: promql_nested_aggregates
required_capability: tsdim_without
PROMQL index=k8s step=1h result=(sum without (pod, region) (network.cost) * 2)
| SORT result;

result:double | step:datetime            | _timeseries:keyword
31.75         | 2024-05-10T00:00:00.000Z | "{""cluster"":""staging""}"
37.25         | 2024-05-10T00:00:00.000Z | "{""cluster"":""prod""}"
53.0          | 2024-05-10T00:00:00.000Z | "{""cluster"":""qa""}"
;

without_binary_vector_division
required_capability: promql_command_v0
required_capability: promql_nested_aggregates
required_capability: tsdim_without
PROMQL index=k8s step=1h result=(sum without (pod, region) (avg_over_time(network.cost[1h])) / count without (pod, region) (avg_over_time(network.cost[1h])))
| SORT result;

result:double          | step:datetime            | _timeseries:keyword
5.8404113247863245     | 2024-05-10T00:00:00.000Z | "{""cluster"":""staging""}"
6.010756340579711      | 2024-05-10T00:00:00.000Z | "{""cluster"":""prod""}"
6.92301245210728       | 2024-05-10T00:00:00.000Z | "{""cluster"":""qa""}"
;



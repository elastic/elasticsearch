// Contains tests for functionality that's PromQL specific.
// Otherwise, PromQL tests go alongside TS tests grouped by functionality k8s-timeseries-<function>.csv-spec.
// This makes it easy to verify that PromQL and TS produce the same results for the same functionality where applicable
// and helps to ensure we have the same test coverage for PromQL vs TS|STATS.
promql_start_end_step
required_capability: promql_command_v0
required_capability: fix_promql_time_bucket_v2
required_capability: fix_tstep_bucket_rounding
PROMQL index=k8s step=5m start="2024-05-10T00:20:00.000Z" end="2024-05-10T00:25:00.000Z" (
  sum(avg_over_time(network.cost[5m]))
)
| SORT step;

// With TStep grid: step=00:20 covers (00:15, 00:20], step=00:25 covers (00:20, 00:25].
sum(avg_over_time(network.cost[5m])):double | step:date
51.958333333333336                          | 2024-05-10T00:20:00.000Z
51.59375                                    | 2024-05-10T00:25:00.000Z
;

no_parentheses
required_capability: promql_command_v0
required_capability: fix_promql_time_bucket_v2
required_capability: fix_tstep_bucket_rounding
PROMQL index=k8s step=5m start="2024-05-10T00:20:00.000Z" end="2024-05-10T00:25:00.000Z" sum(avg_over_time(network.cost[5m]))
| SORT step;

sum(avg_over_time(network.cost[5m])):double | step:date
51.958333333333336                          | 2024-05-10T00:20:00.000Z
51.59375                                    | 2024-05-10T00:25:00.000Z
;

auto_step_buckets
required_capability: promql_command_v0
required_capability: promql_buckets_parameter
required_capability: fix_promql_time_bucket_v2
required_capability: fix_tstep_bucket_rounding
required_capability: fix_promql_scalar_constant_results
PROMQL index=k8s start="2024-05-10T00:00:00.000Z" end="2024-05-10T00:20:00.000Z" buckets=4 1
| KEEP step
| SORT step;

// Const-folded literal bypasses the index; step grid includes the inclusive start timestamp.
step:datetime
2024-05-10T00:00:00.000Z
2024-05-10T00:05:00.000Z
2024-05-10T00:10:00.000Z
2024-05-10T00:15:00.000Z
2024-05-10T00:20:00.000Z
;

not_equals_filter
required_capability: promql_command_v0
required_capability: fix_promql_time_bucket_v2
PROMQL index=k8s step=1h cost=(max by (cluster) (network.total_bytes_in{cluster!="prod"}))
| SORT cluster;

cost:double | step:datetime            | cluster:keyword
10797.0     | 2024-05-10T01:00:00.000Z | qa
7403.0      | 2024-05-10T01:00:00.000Z | staging
;

not_equals_filter_collapsed
required_capability: promql_command_v0
required_capability: fix_promql_time_bucket_v2
required_capability: ts_collapse
PROMQL index=k8s step=1h start="2024-05-10T00:00:00.000Z" end="2024-05-10T01:00:00.000Z" cost=(max by (cluster) (network.total_bytes_in{cluster!="prod"}))
| TS_COLLAPSE
| SORT cluster;

cost:double | step:datetime              | cluster:keyword
[10797.0]   | [2024-05-10T01:00:00.000Z] | qa
[7403.0]    | [2024-05-10T01:00:00.000Z] | staging
;


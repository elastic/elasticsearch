range_selector_different_from_step
required_capability: promql_command_v0
required_capability: time_series_window_v1
required_capability: fix_time_series_window_backward
required_capability: fix_promql_time_bucket_v2
required_capability: fix_tstep_bucket_rounding
PROMQL index=k8s step=5m start="2024-05-10T00:10:00.000Z" end="2024-05-10T00:15:00.000Z" sum by (pod) (avg_over_time(events_received[10m]))
| SORT pod, step
;

// With TStep and window=10m > step=5m: the step range filter removes any labels outside [start, end].
// Label 00:10 uses data in (00:05,00:10], label 00:15 uses data in (00:10,00:15].
sum by (pod) (avg_over_time(events_received[10m])):double | step:datetime            | pod:keyword
15.746543778801843                                        | 2024-05-10T00:10:00.000Z | one
17.711405529953918                                        | 2024-05-10T00:15:00.000Z | one
15.396284829721363                                        | 2024-05-10T00:10:00.000Z | three
14.625735294117646                                        | 2024-05-10T00:15:00.000Z | three
14.19994204578383                                         | 2024-05-10T00:10:00.000Z | two
15.605820105820106                                        | 2024-05-10T00:15:00.000Z | two
;

// value transformation functions
ceil
required_capability: promql_command_v0
required_capability: fix_promql_time_bucket_v2
PROMQL index=k8s step=1h ceil=(ceil(sum(avg_over_time(network.cost[1h])) by (cluster)))
| SORT cluster;

ceil:double | step:datetime            | cluster:keyword
19.0        | 2024-05-10T01:00:00.000Z | prod
21.0        | 2024-05-10T01:00:00.000Z | qa
18.0        | 2024-05-10T01:00:00.000Z | staging
;


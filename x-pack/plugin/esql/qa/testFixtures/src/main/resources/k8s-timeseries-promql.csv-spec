// Set operator: top-level `or` (UNION).
// Combines the series from both operands. The left operand wins where label sets overlap.
set_operator_union_combines_series
required_capability: promql_command_v0
required_capability: promql_set_operator_union
required_capability: fix_promql_time_bucket_v2
PROMQL index=k8s step=1h set_union=(max by (cluster) (network.total_bytes_in{cluster="prod"}) or max by (cluster) (network.total_bytes_in))
| SORT cluster;

set_union:double | step:datetime            | cluster:keyword
10277.0          | 2024-05-10T01:00:00.000Z | prod

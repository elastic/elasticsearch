implicitTimestampSortWithEval
required_capability: ts_command_v0
required_capability: ts_implicit_timestamp_sort

TS k8s 
| WHERE cluster == "staging" 
| EVAL bytes_kb = network.bytes_in / 1024.0 
| KEEP @timestamp, cluster, bytes_kb 
| LIMIT 5;


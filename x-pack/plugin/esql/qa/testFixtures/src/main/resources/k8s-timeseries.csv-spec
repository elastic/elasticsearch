GroupingOnScalarFunction
required_capability: ts_command_v0
required_capability: ts_command_group_on_aliases
TS k8s
| STATS m = max(max_over_time(network.cost)) by pod = to_upper(pod), bucket = bucket(@timestamp,5minute)
| sort bucket, pod
;


0              | 9              
44             | 8              
10             | 7              
28             | 6              
10             | 5              
12             | 4              
10             | 3              
15             | 2              
;


testMatchWithReplace
required_capability: match_function
required_capability: no_plain_strings_in_literals
from books 
| keep book_no, author 
| where match(author, REPLACE("FaulkneX", "X", "r"))
| sort book_no 
| limit 5;

book_no:keyword | author:text
2378            | [Carol Faulkner, Holly Byers Ochoa, Lucretia Mott]
2713            | William Faulkner
2847            | Colleen Faulkner
2883            | William Faulkner
3293            | Danny Faulkner
;

matchBeforeMvExpand
required_capability: match_function

from books
| where match(author, "Faulkner") and book_no == "2378"
| mv_expand author
| keep book_no, author
;
ignoreOrder: true

book_no:keyword | author:text
2378            | Carol Faulkner
2378            | Holly Byers Ochoa
2378            | Lucretia Mott
;

matchBeforeMvExpandWithStats
required_capability: match_function

from books
| where match(author, "Tolkien")
| mv_expand author
| stats count = count(*) by book_no
| sort book_no
| limit 5
;

   count:long  |    book_no:keyword

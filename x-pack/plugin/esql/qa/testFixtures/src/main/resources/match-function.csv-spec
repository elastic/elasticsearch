matchOnRuntimeIp

required_capability: match_function
required_capability: match_runtime_search

pragma: runtime_lexical_search=true

FROM hosts
| EVAL my_ip = CASE(mv_contains(ip0, ip1), ip0, ip1)
| WHERE match(my_ip, "127.0.0.1")
| SORT host, my_ip, card
| LIMIT 3
| KEEP host, my_ip, ip0, ip1
;

host:keyword | my_ip:ip                          | ip0:ip    | ip1:ip
alpha        | 127.0.0.1                         | 127.0.0.1 | 127.0.0.1
epsilon      | [127.0.0.1, 127.0.0.2, 127.0.0.3] | null      | [127.0.0.1, 127.0.0.2, 127.0.0.3]
;

matchOnRuntimeIpWithRow

required_capability: match_function
required_capability: match_runtime_search

pragma: runtime_lexical_search=true

ROW content = ["127.0.0.1", "fe80::cae2:65ff:fece:feb9", "::1"]::ip
| MV_EXPAND content
| WHERE match(content, "127.0.0.1")
;

content:ip
127.0.0.1
;

matchOnIpWithRowAndNullValues

required_capability: match_function
required_capability: match_runtime_search

pragma: runtime_lexical_search=true

ROW content =  ["127.0.0.1", "fe80::cae2:65ff:fece:feb9", "::1"]::ip
| MV_EXPAND content
| EVAL content = CASE(content == "::1", NULL, "127.0.0.1"::ip)
| WHERE match(content, "127.0.0.1")
;

content:ip
127.0.0.1
127.0.0.1
;

matchOnIpWithRowAndMultiValues

required_capability: match_function
required_capability: match_runtime_search

pragma: runtime_lexical_search=true


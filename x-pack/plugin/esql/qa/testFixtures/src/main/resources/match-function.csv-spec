| KEEP emp_no, x
| LIMIT 2
;

emp_no:integer | x:double
10001          | 0.0203
10002          | 0.0208
;

matchOnRuntimeDoubleWithRow

required_capability: match_function
required_capability: match_runtime_search

pragma: runtime_lexical_search=true

ROW a = [1.2, 1.3, 1.4, 1.5]
| MV_EXPAND a
| WHERE match(a, 1.2) OR match(a, 1.3)
| SORT a
;

a:double
1.2
1.3
;

matchOnDoubleWithRowAndNullValues

required_capability: match_function
required_capability: match_runtime_search

pragma: runtime_lexical_search=true


ROW a = [1.2, 1.3, 1.4, 1.5, 1.6]
| MV_EXPAND a
| EVAL a = CASE(a > 1.5, NULL, a)
| WHERE match(a, 1.2) OR match(a, 1.3)
| SORT a
;

a:double
1.2
1.3
;

matchOnDoubleWithRowAndMultiValues

required_capability: match_function
required_capability: match_runtime_search

pragma: runtime_lexical_search=true

ROW a = [1.2, 1.3, 1.4, 1.5, 1.6]
| MV_EXPAND a
| EVAL a = mv_append(a, round(a - 0.1, 1))
| WHERE match(a, 1.2) OR match(a, 1.3)
| SORT a
;

a:double
[1.2, 1.1]
[1.3, 1.2]
[1.4, 1.3]
;


histogramAggsWithoutTBucket
required_capability: ts_command_v0
required_capability: tsdb_temporality_support_v5

TS metric_temporality
 | STATS cnt = COUNT(bytes_per_request), med = MEDIAN(bytes_per_request), avg = AVG(bytes_per_request), mn = MIN(bytes_per_request), mx = MAX(bytes_per_request) BY cluster
 | EVAL med = round(med), avg = round(avg, 2)
 | KEEP cluster, cnt, med, avg, mn, mx
 | SORT cluster
;

cluster:keyword | cnt:long | med:double | avg:double | mn:double | mx:double

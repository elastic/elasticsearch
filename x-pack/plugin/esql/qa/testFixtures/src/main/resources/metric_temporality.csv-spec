 | STATS avg_ot = SUM(avg_over_time(bytes_per_request::tdigest)),
         min_ot = SUM(min_over_time(bytes_per_request::tdigest)),
         max_ot = SUM(max_over_time(bytes_per_request::tdigest)),
         cnt_ot = SUM(count_over_time(bytes_per_request::tdigest)),
         sum_ot = SUM(sum_over_time(bytes_per_request::tdigest)),
         p50_ot = SUM(percentile_over_time(bytes_per_request::tdigest, 50))
         BY my_temporality
 | EVAL avg_ot = round(avg_ot, 2), min_ot = round(min_ot, 2), max_ot = round(max_ot, 2), sum_ot = round(sum_ot, 2), p50_ot = round(p50_ot)
 | KEEP my_temporality, avg_ot, min_ot, max_ot, cnt_ot, sum_ot, p50_ot
 | SORT my_temporality
;


///////////////////////////////////////////////////////////////////////////////
// histogram_quantile on exponential histograms
///////////////////////////////////////////////////////////////////////////////

// --- min (quantile 0.0) ---

histogram_quantile_min_exp_histo_no_bucket
required_capability: promql_histogram_quantile_exponential
PROMQL index=exp_histo_sample step=2h start="2025-09-25T02:00:00.000Z" end="2025-09-25T02:00:00.000Z" result=(histogram_quantile(0.0, increase(responseTime{instance=~"instance-.*"}[2h])))
| SORT _timeseries;

result:double | step:datetime            | _timeseries:keyword
2.4E-4        | 2025-09-25T02:00:00.000Z | "{""instance"":""instance-0""}"
2.17E-4       | 2025-09-25T02:00:00.000Z | "{""instance"":""instance-1""}"
2.2E-4        | 2025-09-25T02:00:00.000Z | "{""instance"":""instance-2""}"
;


// --- sum (merge) of increase across series, then quantile ---

histogram_quantile_median_exp_histo_sum_across_series
required_capability: promql_histogram_quantile_exponential
required_capability: promql_sum_on_histogram
PROMQL index=exp_histo_sample step=2h start="2025-09-25T02:00:00.000Z" end="2025-09-25T02:00:00.000Z" result=(histogram_quantile(0.5, sum(increase(responseTime{instance=~"instance-.*"}[2h]))));

result:double          | step:datetime
0.00169649..0.001714   | 2025-09-25T02:00:00.000Z
;

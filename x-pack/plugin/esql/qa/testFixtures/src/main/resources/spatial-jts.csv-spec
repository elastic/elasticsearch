stSimplifyPreserveTopologyPreservesTopology
required_capability: fn_st_simplifypreservetopology

ROW geo_shape = TO_GEOSHAPE("POLYGON((0 0, 1 0.1, 2 0, 2 2, 1 1.9, 0 2, 0 0))")
| EVAL result = ST_SIMPLIFYPRESERVETOPOLOGY(geo_shape, 2.0)
| KEEP result
;

result:geo_shape
POLYGON ((0.0 2.0, 2.0 0.0, 2.0 2.0, 0.0 2.0))
;

stSimplifyPreserveTopologyNull
required_capability: fn_st_simplifypreservetopology

ROW geo_shape = NULL
| EVAL result = ST_SIMPLIFYPRESERVETOPOLOGY(geo_shape, 2.0)
| KEEP result
;

result:null
NULL
;

stSimplifyPreserveTopologyEmptyPolygon
required_capability: fn_st_simplifypreservetopology

ROW geo_shape = TO_GEOSHAPE("POLYGON EMPTY")
| EVAL result = ST_SIMPLIFYPRESERVETOPOLOGY(geo_shape, 0.5)
| KEEP result
;

result:geo_shape
POLYGON EMPTY
;

stSimplifyPreserveTopologyCartesianShape
required_capability: fn_st_simplifypreservetopology

ROW wkt = "POLYGON ((2 3, 4 8, 7 6, 6 2, 2 3))"
| EVAL result = ST_SIMPLIFYPRESERVETOPOLOGY(TO_CARTESIANSHAPE(wkt), 0.5)
| KEEP result
;

result:cartesian_shape
POLYGON ((2.0 3.0, 4.0 8.0, 7.0 6.0, 6.0 2.0, 2.0 3.0))
;

stSimplifyPreserveTopologyWithIntegerTolerance
required_capability: fn_st_simplifypreservetopology

ROW geo_shape = TO_GEOSHAPE("POLYGON((0 0, 1 0.1, 2 0, 2 2, 1 1.9, 0 2, 0 0))")
| EVAL result = ST_SIMPLIFYPRESERVETOPOLOGY(geo_shape, 2)
| KEEP result
;

result:geo_shape
POLYGON ((0.0 2.0, 2.0 0.0, 2.0 2.0, 0.0 2.0))
;

###############################################
# Tests for ST_BUFFER
###############################################

stBufferNegativeDistance
required_capability: fn_st_buffer

// tag::st_buffer[]
ROW wkt = "POLYGON ((0 0, 4 0, 4 4, 0 4, 0 0))"
| EVAL buffered = ST_BUFFER(TO_GEOSHAPE(wkt), -1)
// end::st_buffer[]
;

// tag::st_buffer-result[]
wkt:keyword                                | buffered:geo_shape
POLYGON ((0 0, 4 0, 4 4, 0 4, 0 0))       | POLYGON ((1.0 1.0, 1.0 3.0, 3.0 3.0, 3.0 1.0, 1.0 1.0))
// end::st_buffer-result[]
;

// When expanding angular geometries like rectangles, we get rounded corners with many points
// We assert on the number of points, rather than the exact geometry to cope with occasional floating points errors
stBufferPositiveAndNegativeDistance
required_capability: fn_st_buffer

ROW wkt = "POLYGON ((0 0, 4 0, 4 4, 0 4, 0 0))"
| EVAL bigger = ST_NPOINTS(ST_BUFFER(TO_GEOSHAPE(wkt), 1))
| EVAL smaller = ST_NPOINTS(ST_BUFFER(TO_GEOSHAPE(wkt), -1))
;

wkt:keyword                         | bigger:integer | smaller:integer
POLYGON ((0 0, 4 0, 4 4, 0 4, 0 0)) | 37             | 5
;

stBufferLargeNegativeDistance
required_capability: fn_st_buffer

ROW wkt = "POLYGON ((0 0, 4 0, 4 4, 0 4, 0 0))"
| EVAL buffered = ST_BUFFER(TO_GEOSHAPE(wkt), -4)
;

wkt:keyword                               | buffered:geo_shape
POLYGON ((0 0, 4 0, 4 4, 0 4, 0 0))       | POLYGON EMPTY
;


;

###############################################
# Tests for ST_SIMPLIFYPRESERVETOPOLOGY
###############################################

stSimplifyPreserveTopologyLiteralPolygon
required_capability: fn_st_simplifypreservetopology

// tag::st_simplifypreservetopology[]
ROW wkt = "POLYGON ((7.998 53.827, 9.470 53.068, 15.754 53.801, 16.523 57.160, 11.162 57.868, 8.064 57.445, 6.219 55.317, 7.998 53.827))"
| EVAL simplified = ST_SIMPLIFYPRESERVETOPOLOGY(TO_GEOSHAPE(wkt), 0.7)
// end::st_simplifypreservetopology[]
;

// tag::st_simplifypreservetopology-result[]
wkt:keyword                                                                                                                   | simplified:geo_shape
POLYGON ((7.998 53.827, 9.470 53.068, 15.754 53.801, 16.523 57.160, 11.162 57.868, 8.064 57.445, 6.219 55.317, 7.998 53.827)) | POLYGON ((6.219 55.317, 9.47 53.068, 15.754 53.801, 16.523 57.16, 8.064 57.445, 6.219 55.317))
// end::st_simplifypreservetopology-result[]
;

stSimplifyPreserveTopologyNoSimplification
required_capability: fn_st_simplifypreservetopology

ROW geo_shape = TO_GEOSHAPE("POLYGON((0 0, 1 0.1, 2 0, 2 2, 1 1.9, 0 2, 0 0))")
| EVAL result = ST_SIMPLIFYPRESERVETOPOLOGY(geo_shape, 0.01)
| KEEP result
;

result:geo_shape
POLYGON ((0.0 0.0, 1.0 0.1, 2.0 0.0, 2.0 2.0, 1.0 1.9, 0.0 2.0, 0.0 0.0))
;


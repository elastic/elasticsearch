stBufferCartesianPoint
required_capability: fn_st_buffer
required_capability: fn_st_geometrytype
required_capability: fn_st_npoints

ROW geom = TO_CARTESIANSHAPE("POINT(5 5)")
| EVAL buffered = ST_BUFFER(geom, 2)
| EVAL geom_type = ST_GEOMETRYTYPE(buffered), npoints = ST_NPOINTS(buffered)
| KEEP geom_type, npoints
;

geom_type:keyword | npoints:integer
ST_Polygon        | 33
;


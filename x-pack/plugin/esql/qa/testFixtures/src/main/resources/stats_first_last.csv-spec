Test passing int foldables in the sort field
required_capability: first_last_agg_on_ints

FROM voyager
| SORT row_no ASC
| LIMIT 1000
| EVAL p = 17
| STATS
    # queries that run the regular "type1"-by-int aggregator and does nothing unusual (type1 is the search field's type)
    
    x01 = FIRST(@timestamp, p),
    x02 = LAST(@timestamp, p),
    
    x03 = FIRST(active_instruments, p),
    x04 = LAST(active_instruments, p),
    
    x05 = FIRST(low_power_mode, p),
    x06 = LAST(low_power_mode, p),
    
    # queries that run the new any-value-by-int aggregator which returns the first value it encounters
    
    x07 = FIRST(distance_to_earth, 31), 
    x08 = LAST(distance_to_earth, 44),
    
    x09 = FIRST(status, -273.15::int),
    x10 = LAST(status, 3.14::int)
;

x01:datetime | x02:datetime | x03:integer | x04:integer | x05:boolean | x06:boolean | x07:long    | x08:long    | x09:keyword | x10:keyword
null         | null         | [3, 4]      | [3, 4]      | false       | false       | 21190910703 | 21190910703 | yellow      | yellow
;


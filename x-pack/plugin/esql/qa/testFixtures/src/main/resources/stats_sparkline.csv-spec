[9.0, 0.0, 7.0, 0.0, 9.0, 4.0, 0.0, 8.0, 9.0, 0.0, 8.0, 0.0, 0.0, 0.0, 7.0]                                                                         | [-0.18, 0.0, 0.89, 0.0, 0.31, 0.97, 0.0, 0.73, 0.86, 0.0, 0.04, 0.0, 0.0, 0.0, 0.11]  | null

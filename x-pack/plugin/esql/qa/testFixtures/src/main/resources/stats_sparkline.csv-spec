// Make sure that the non-time series aggs don't choke on null.
withCountDistinctNull
required_capability: fn_sparkline_null_alongside

FROM employees
| EVAL y = null
| STATS s = SPARKLINE(SUM(salary), hire_date, 20, "1985-01-01T00:00:00Z", "1985-12-31T00:00:00Z"),
       cd = COUNT_DISTINCT(y)
;

s:long                                                           | cd:long
[0, 92610, 0, 0, 44817, 0, 62405, 0, 49095, 103064, 218159, 0]  | 0
;

withCountDistinctNullFromRow
required_capability: fn_sparkline_null_alongside

ROW hire_date = to_datetime("1985-06-01T00:00:00Z"), y = null
| STATS s = SPARKLINE(COUNT(*), hire_date, 5, "1985-01-01T00:00:00Z", "1985-12-31T00:00:00Z"), cd = COUNT_DISTINCT(y)
;

s:long | cd:long
1      | 0
;

withValuesNull
required_capability: fn_sparkline_null_alongside

ROW hire_date = to_datetime("1985-06-01T00:00:00Z"), y = null
| STATS s = SPARKLINE(COUNT(*), hire_date, 5, "1985-01-01T00:00:00Z", "1985-12-31T00:00:00Z"),
        v = VALUES(y)
;

s:long | v:null
1      | null
;

withSumNull
required_capability: fn_sparkline_null_alongside

ROW hire_date = to_datetime("1985-06-01T00:00:00Z"), y = null
| STATS s = SPARKLINE(COUNT(*), hire_date, 5, "1985-01-01T00:00:00Z", "1985-12-31T00:00:00Z"),
       sm = SUM(y)
;

s:long | sm:null
1      | null
;

withTopNull
required_capability: fn_sparkline_null_alongside

ROW hire_date = to_datetime("1985-06-01T00:00:00Z"), y = null
| STATS s = SPARKLINE(COUNT(*), hire_date, 5, "1985-01-01T00:00:00Z", "1985-12-31T00:00:00Z"),
        t = TOP(y, 3, "asc")
;

s:long | t:null
1      | null
;

sparklineComplexWithGroupingMapped
required_capability: fn_sparkline_nested
FROM employees
| STATS name_length = TO_STRING(SPARKLINE(AVG(LENGTH(first_name)::DOUBLE), hire_date, 8, "1985-01-01T00:00:00Z", "1999-12-31T00:00:00Z")),
          silly_sin = TO_STRING(SPARKLINE(MAX(ROUND(SIN(emp_no + 12), 2)), hire_date, 8, "1985-01-01T00:00:00Z", "1999-12-31T00:00:00Z"))
     BY gender
| SORT gender
;


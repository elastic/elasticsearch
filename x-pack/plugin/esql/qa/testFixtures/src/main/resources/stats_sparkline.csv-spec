sparklineWithMvExpand
required_capability: fn_sparkline_nested
FROM employees
| STATS sparkline = MV_APPEND(999::LONG, SPARKLINE(COUNT(*), hire_date, 20, "1985-01-01T00:00:00Z", "1985-12-31T00:00:00Z")),
        value     = 7 + MV_COUNT(MV_APPEND(999::LONG, SPARKLINE(COUNT(*), hire_date, 20, "1985-01-01T00:00:00Z", "1985-12-31T00:00:00Z")))
;

sparkline:long                            | value:long
[999, 0, 2, 0, 0, 1, 0, 1, 0, 1, 2, 4, 0] | 20
;

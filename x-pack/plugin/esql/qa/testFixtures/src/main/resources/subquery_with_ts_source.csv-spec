FROM sample_data,
     (TS k8s
      | STATS max_rate=max(rate(network.total_bytes_in)), max_cost=max(rate(network.total_cost)) BY cluster
      | EVAL max_rate=ROUND(max_rate, 4), max_cost=ROUND(max_cost, 4)
      | DROP max_cost)
| WHERE max_rate IS NOT NULL OR client_ip == "172.21.0.5"
| SORT max_rate, cluster, @timestamp
| KEEP @timestamp, client_ip, cluster, max_rate
;


2024-05-10T00:00:29.000Z | 10.10.20.34  | staging         | 953                         | null
2024-05-10T00:00:33.000Z | 10.10.20.34  | staging         | 1111                        | null
2024-05-10T00:00:51.000Z | 10.10.20.30  | prod            | 278                         | null
2024-05-10T00:00:57.000Z | 10.10.20.30  | prod            | 955                         | null
;

// Both UnionAll branches use TS as their source. The conflicting `network.eth0.tx`
// (integer in k8s vs aggregate_metric_double in k8s-downsampled) is referenced only via KEEP,
// so it surfaces as `unsupported` with null values across the union.
subqueryInFromWithBothBranchesTsConflictingFieldOnlyInKeep
required_capability: subquery_in_from_command
required_capability: subquery_with_ts
required_capability: subquery_in_from_command_union_types_conflict_resolution
required_capability: ts_command_v0

FROM (TS "k8s" | WHERE @timestamp <= "2024-05-10T00:01:00.000Z"),
     (TS "k8s-downsampled" | WHERE @timestamp <= "2024-05-09T23:30:00.000Z")
| KEEP @timestamp, client.ip, cluster, network.total_bytes_in, network.eth0.tx
| SORT @timestamp, client.ip, cluster, network.total_bytes_in
;

@timestamp:datetime      | client.ip:ip | cluster:keyword | network.total_bytes_in:long | network.eth0.tx:unsupported

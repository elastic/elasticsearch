//
// CSV spec for subqueries whose source command is TS (time-series).
// Patterns mirror those in subquery.csv-spec, but each subquery is sourced
// from one of the k8s* time-series indices used by the k8s-timeseries-* csv-specs.
//

subqueryInFromWithTsSubqueryStatsByCluster
required_capability: subquery_in_from_command
required_capability: subquery_with_ts
required_capability: ts_command_v0
required_capability: double_quotes_source_enclosing

FROM sample_data,
     (TS "k8s"
      | STATS max_bytes=max(to_long(network.total_bytes_in)) BY cluster)
| EVAL has_ts = max_bytes IS NOT NULL
| SORT has_ts, cluster, @timestamp
| KEEP @timestamp, client_ip, cluster, max_bytes
;

@timestamp:datetime      | client_ip:ip | cluster:keyword | max_bytes:long
2023-10-23T12:15:03.360Z | 172.21.2.162 | null            | null
2023-10-23T12:27:28.948Z | 172.21.2.113 | null            | null
2023-10-23T13:33:34.937Z | 172.21.0.5   | null            | null
2023-10-23T13:51:54.732Z | 172.21.3.15  | null            | null
2023-10-23T13:52:55.015Z | 172.21.3.15  | null            | null
2023-10-23T13:53:55.832Z | 172.21.3.15  | null            | null
2023-10-23T13:55:01.543Z | 172.21.3.15  | null            | null
null                     | null         | prod            | 10277
null                     | null         | qa              | 10797
null                     | null         | staging         | 7403
;

subqueryInFromWithTsSubqueryMaxCost
required_capability: subquery_in_from_command
required_capability: subquery_with_ts
required_capability: ts_command_v0

FROM sample_data,
     (TS k8s
      | STATS max_cost=max(rate(network.total_cost))
      | EVAL max_cost=ROUND(max_cost, 6)
      | KEEP max_cost)
| WHERE max_cost IS NOT NULL OR client_ip == "172.21.0.5"
| SORT max_cost, @timestamp
| KEEP @timestamp, client_ip, max_cost
;

@timestamp:datetime      | client_ip:ip | max_cost:double
null                     | null         | 0.161517
2023-10-23T13:33:34.937Z | 172.21.0.5   | null
;

subqueryInFromWithTsSubqueryRateWithBucket
skip_flattened_rewrite: subquery_bleed
required_capability: subquery_in_from_command
required_capability: subquery_with_ts
required_capability: ts_command_v0
required_capability: rate_with_interpolation_v2

FROM sample_data,
     (TS k8s
      | STATS max_rate=max(rate(network.total_bytes_in)) BY time_bucket = bucket(@timestamp, 5minute), cluster
      | EVAL max_rate=ROUND(max_rate, 6)
      | KEEP max_rate, time_bucket, cluster
      | SORT time_bucket DESC, cluster
      | LIMIT 6)
| WHERE max_rate IS NOT NULL OR client_ip == "172.21.0.5"
| SORT time_bucket, cluster, @timestamp
| KEEP @timestamp, client_ip, max_rate, time_bucket, cluster
;

@timestamp:datetime      | client_ip:ip | max_rate:double | time_bucket:datetime     | cluster:keyword
null                     | null         | 13.765185       | 2024-05-10T00:15:00.000Z | prod
null                     | null         | 22.359074       | 2024-05-10T00:15:00.000Z | qa
null                     | null         | 9.934874        | 2024-05-10T00:15:00.000Z | staging
null                     | null         | 64.5            | 2024-05-10T00:20:00.000Z | prod
null                     | null         | 17.226415       | 2024-05-10T00:20:00.000Z | qa
null                     | null         | 3.19            | 2024-05-10T00:20:00.000Z | staging
2023-10-23T13:33:34.937Z | 172.21.0.5   | null            | null                     | null
;

subqueryInFromWithTsSubqueryMaxOverTime
skip_flattened_rewrite: subquery_bleed
required_capability: subquery_in_from_command
required_capability: subquery_with_ts
required_capability: ts_command_v0
required_capability: tbucket

FROM sample_data,
     (TS k8s
      | STATS cost=SUM(MAX_OVER_TIME(network.cost)) BY cluster, time_bucket = TBUCKET(1minute)
      | SORT cost DESC, time_bucket DESC, cluster
      | LIMIT 4)
| WHERE cost IS NOT NULL OR client_ip == "172.21.3.15"
| SORT cost, time_bucket, cluster, @timestamp
| KEEP @timestamp, client_ip, cluster, cost, time_bucket
;


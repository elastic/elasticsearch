// ----------------------------------------------------------------------------
// Tests exercising METADATA _index inside the TS subquery and/or the main
// query. They all surface the index name in the output and follow the
// MV_LAST(SPLIT(_index, ":")) pattern from subquery.csv-spec to strip any
// remote-cluster prefix.
// ----------------------------------------------------------------------------

// METADATA _index lives only inside the TS subquery; the outer FROM does not
// re-declare it. _index is promoted to a regular column via STATS BY _index,
// so sample_data rows surface a null _index.
subqueryInFromWithTsSubqueryAndMetadataIndexInSubquery
required_capability: subquery_in_from_command
required_capability: subquery_with_ts
required_capability: ts_command_v0
required_capability: double_quotes_source_enclosing

FROM sample_data,
     (TS "k8s" METADATA _index
      | STATS max_bytes=max(to_long(network.total_bytes_in)) BY cluster, _index)
| EVAL _index = MV_LAST(SPLIT(_index, ":"))
| WHERE max_bytes IS NOT NULL OR client_ip == "172.21.0.5"
| SORT _index, cluster, @timestamp
| KEEP _index, @timestamp, client_ip, cluster, max_bytes
;


// Three-way UnionAll: a non-TS FROM branch and two TS branches whose `network.eth0.tx` types
// disagree. Only KEEP/Project references the field, so it surfaces as `unsupported` with nulls.
subqueryInFromWithMixedFromAndTsConflictingFieldOnlyInKeep
required_capability: subquery_in_from_command
required_capability: subquery_with_ts
required_capability: subquery_in_from_command_union_types_conflict_resolution
required_capability: ts_command_v0


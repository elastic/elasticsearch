// ----------------------------------------------------------------------------
// Tests based on the per-function k8s-timeseries-*.csv-spec files. PROMQL
// queries are skipped. Patterns that already appear earlier in this file are
// not duplicated.
// ----------------------------------------------------------------------------

// Mirrors storedSourceTimeseriesGroupByAllImplicitly - exercises the
// stored-source TSDB variant as the TS subquery source.
subqueryInFromWithTsSubqueryStoredSource
skip_flattened_rewrite: subquery_bleed
required_capability: subquery_in_from_command
required_capability: subquery_with_ts
required_capability: ts_command_v0

FROM sample_data,
     (TS k8s_stored_source
      | STATS avg = ROUND(MAX(avg_over_time(network.cost)), 6) BY cluster, pod
      | SORT avg DESC
      | LIMIT 3)
| WHERE avg IS NOT NULL OR client_ip == "172.21.0.5"
| SORT avg, cluster, pod, @timestamp
| KEEP @timestamp, client_ip, cluster, pod, avg
;

@timestamp:datetime      | client_ip:ip | cluster:keyword | pod:keyword | avg:double
null                     | null         | qa              | two         | 6.87069
null                     | null         | qa              | one         | 7.262931
null                     | null         | prod            | three       | 8.375
2023-10-23T13:33:34.937Z | 172.21.0.5   | null            | null        | null
;

// Mirrors without_avg - exercises BY WITHOUT(...) grouping inside a TS
// subquery. The implicit _timeseries column emitted by WITHOUT is a virtual
// output column and is not addressable in subsequent EVAL/KEEP/outer query
// stages, so the union surfaces only avg_cost from the subquery.
subqueryInFromWithTsSubqueryWithoutGrouping
skip_flattened_rewrite: subquery_bleed
required_capability: subquery_in_from_command
required_capability: subquery_with_ts
required_capability: ts_command_v0
required_capability: esql_without_grouping

FROM sample_data,
     (TS k8s
      | STATS avg_cost = ROUND(avg(network.cost), 6) BY WITHOUT(pod, region)
      | SORT avg_cost)
| WHERE avg_cost IS NOT NULL OR client_ip == "172.21.0.5"
| SORT avg_cost, @timestamp
| DROP event_duration, message
;

@timestamp:datetime      | client_ip:ip | avg_cost:double | WITHOUT(pod, region):keyword

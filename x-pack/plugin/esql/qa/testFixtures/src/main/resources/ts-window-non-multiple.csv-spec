###############################################
# Tests for non-multiple window/bucket combos
# Uses the ts_window dataset with controlled
# data at 1-minute intervals:
#   dim a: val[m] = m + 1  (1..30)
#   dim b: val[m] = (m+1)*10  (10..300)
#   counter_val: cumulative sum of val
# Timestamps: 2024-01-01T00:00..00:29
###############################################

sum_over_time_non_multiple_7m_window_5m_bucket
required_capability: time_series_window_non_multiple

TS ts_window
| STATS s = sum(sum_over_time(val, 7m)) BY dim, time_bucket = TBUCKET(5minute)
| SORT time_bucket, dim
| LIMIT 20;

s:long | dim:keyword | time_bucket:datetime
7      | a           | 2024-01-01T00:00:00.000Z
70     | b           | 2024-01-01T00:00:00.000Z
17     | a           | 2024-01-01T00:05:00.000Z
170    | b           | 2024-01-01T00:05:00.000Z
27     | a           | 2024-01-01T00:10:00.000Z
270    | b           | 2024-01-01T00:10:00.000Z
37     | a           | 2024-01-01T00:15:00.000Z
370    | b           | 2024-01-01T00:15:00.000Z
47     | a           | 2024-01-01T00:20:00.000Z
470    | b           | 2024-01-01T00:20:00.000Z
26     | a           | 2024-01-01T00:25:00.000Z
260    | b           | 2024-01-01T00:25:00.000Z
;



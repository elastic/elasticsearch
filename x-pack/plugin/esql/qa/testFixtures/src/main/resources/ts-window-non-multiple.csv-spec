###############################################
# Rate tests with non-multiple windows
# rate() computes the per-second increase of a
# counter metric, with interpolation at bucket
# boundaries.
###############################################

rate_non_multiple_avg_rate_7m_window_5m_bucket
required_capability: time_series_window_non_multiple
required_capability: rate_with_interpolation

TS ts_window
| STATS r = avg(rate(counter_val, 7m)) BY dim, time_bucket = TBUCKET(5minute)
| EVAL r = ROUND(r, 6)
| SORT time_bucket, dim
| LIMIT 20;

dim:keyword | time_bucket:datetime     | r:double
a           | 2024-01-01T00:00:00.000Z | 0.066667
b           | 2024-01-01T00:00:00.000Z | 0.666667
a           | 2024-01-01T00:05:00.000Z | 0.15
b           | 2024-01-01T00:05:00.000Z | 1.5
a           | 2024-01-01T00:10:00.000Z | 0.233333
b           | 2024-01-01T00:10:00.000Z | 2.333333
a           | 2024-01-01T00:15:00.000Z | 0.316667
b           | 2024-01-01T00:15:00.000Z | 3.166667
a           | 2024-01-01T00:20:00.000Z | 0.4
b           | 2024-01-01T00:20:00.000Z | 4.0
a           | 2024-01-01T00:25:00.000Z | null
b           | 2024-01-01T00:25:00.000Z | null     
;

rate_non_multiple_9m_window_6m_bucket_with_trange
required_capability: time_series_window_non_multiple
required_capability: rate_with_interpolation

TS ts_window
| WHERE TRANGE("2024-01-01T00:06:00.000Z", "2024-01-01T00:18:00.000Z")
| STATS r = sum(rate(counter_val, 9m)) BY dim, time_bucket = TBUCKET(6minute)
| EVAL r = ROUND(r, 6)
| SORT time_bucket, dim
| LIMIT 20;

dim:keyword | time_bucket:datetime     | r:double
a           | 2024-01-01T00:06:00.000Z | 0.2
b           | 2024-01-01T00:06:00.000Z | 2.0
a           | 2024-01-01T00:12:00.000Z | 0.20625
b           | 2024-01-01T00:12:00.000Z | 2.0625
a           | 2024-01-01T00:18:00.000Z | null
b           | 2024-01-01T00:18:00.000Z | null     
;

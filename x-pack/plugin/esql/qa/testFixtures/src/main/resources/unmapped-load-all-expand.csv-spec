// RENAME message AS language_code conflicts with the unmapped source field language_code:
// patternForRename adds "language_code" to the exclude list. Only 3 unmapped fields are expanded.
renameMappedFieldConflictsWithUnmappedExpand
required_capability: optional_fields_load_all_expand

SET unmapped_fields="LOAD_ALL_EXPAND"\;
FROM partial_mapping_sample_data
| RENAME message AS language_code
| SORT @timestamp
;


############################
# LOAD_ALL_EXPAND mode — loads all unmapped source fields and expands each into its own keyword column.
# The _unmapped_fields column itself is suppressed; one dedicated column per unique field name is
# appended at the end of the schema in alphabetical order.
#
# These tests mirror the non-gap tests in unmapped-load-all.csv-spec, with the only difference being
# the SET value and the expected output schema/data.
############################

############################
# Baseline: all unmapped fields expanded
############################

// Bare FROM with no projection: all mapped columns appear, followed by one keyword column per
// unique unmapped source field, in alphabetical order. No _unmapped_fields JSON column is emitted.
fromNoProjectionExpand
required_capability: optional_fields_load_all_expand

SET unmapped_fields="LOAD_ALL_EXPAND"\;
FROM partial_mapping_sample_data
| SORT @timestamp
;

@timestamp:datetime      | client_ip:ip | event_duration:long | message:keyword        | language_code:keyword | unmapped.nested:keyword | unmapped_event_duration:keyword | unmapped_message:keyword
2024-10-23T12:15:03.360Z | 173.21.2.162 | 3450232             | Connected to 10.1.0.3! | 4                     | g                       | 3450234                         | Disconnected from 10.1.0.3
2024-10-23T12:27:28.948Z | 173.21.2.113 | 2764888             | Connected to 10.1.0.2! | 3                     | f                       | 2764890                         | Disconnected from 10.1.0.2
2024-10-23T13:33:34.937Z | 173.21.0.5   | 1232381             | 42                     | 2                     | e                       | 1232383                         | 43
2024-10-23T13:51:54.732Z | 173.21.3.15  | 725447              | Connection error?      | 1                     | d                       | 725449                          | Disconnection error
2024-10-23T13:52:55.015Z | 173.21.3.15  | 8268152             | Connection error?      | 3                     | c                       | 8268154                         | Disconnection error
2024-10-23T13:53:55.832Z | 173.21.3.15  | 5033754             | Connection error?      | 2                     | b                       | 5033756                         | Disconnection error
2024-10-23T13:55:01.543Z | 173.21.3.15  | 1756466             | Connected to 10.1.0.1! | 1                     | a                       | 1756468                         | Disconnected from 10.1.0.1
;

// KEEP * — identical result to fromNoProjectionExpand: KEEP * retains all mapped columns and
// all expanded unmapped field columns.
keepStarExpand
required_capability: optional_fields_load_all_expand

SET unmapped_fields="LOAD_ALL_EXPAND"\;
FROM partial_mapping_sample_data
| KEEP *
| SORT @timestamp
;

@timestamp:datetime      | client_ip:ip | event_duration:long | message:keyword        | language_code:keyword | unmapped.nested:keyword | unmapped_event_duration:keyword | unmapped_message:keyword
2024-10-23T12:15:03.360Z | 173.21.2.162 | 3450232             | Connected to 10.1.0.3! | 4                     | g                       | 3450234                         | Disconnected from 10.1.0.3
2024-10-23T12:27:28.948Z | 173.21.2.113 | 2764888             | Connected to 10.1.0.2! | 3                     | f                       | 2764890                         | Disconnected from 10.1.0.2
2024-10-23T13:33:34.937Z | 173.21.0.5   | 1232381             | 42                     | 2                     | e                       | 1232383                         | 43
2024-10-23T13:51:54.732Z | 173.21.3.15  | 725447              | Connection error?      | 1                     | d                       | 725449                          | Disconnection error
2024-10-23T13:52:55.015Z | 173.21.3.15  | 8268152             | Connection error?      | 3                     | c                       | 8268154                         | Disconnection error
2024-10-23T13:53:55.832Z | 173.21.3.15  | 5033754             | Connection error?      | 2                     | b                       | 5033756                         | Disconnection error
2024-10-23T13:55:01.543Z | 173.21.3.15  | 1756466             | Connected to 10.1.0.1! | 1                     | a                       | 1756468                         | Disconnected from 10.1.0.1
;

// EVAL shadows an unmapped field: unmapped_message is demand-loaded by EVAL and uppercased.
// DetermineUnmappedFieldsToKeep excludes unmapped_message from the block loader pattern.
// After expansion the remaining 3 unmapped fields are emitted as columns; the EVAL-produced
// unmapped_message column (keyword, uppercased) appears before the expanded columns.
evalShadowsUnmappedFieldExpand
required_capability: optional_fields_load_all_expand

SET unmapped_fields="LOAD_ALL_EXPAND"\;
FROM partial_mapping_sample_data
| EVAL unmapped_message = to_upper(unmapped_message)
| SORT @timestamp
;

@timestamp:datetime      | client_ip:ip | event_duration:long | message:keyword        | unmapped_message:keyword        | language_code:keyword | unmapped.nested:keyword | unmapped_event_duration:keyword
2024-10-23T12:15:03.360Z | 173.21.2.162 | 3450232             | Connected to 10.1.0.3! | DISCONNECTED FROM 10.1.0.3      | 4                     | g                       | 3450234
2024-10-23T12:27:28.948Z | 173.21.2.113 | 2764888             | Connected to 10.1.0.2! | DISCONNECTED FROM 10.1.0.2      | 3                     | f                       | 2764890
2024-10-23T13:33:34.937Z | 173.21.0.5   | 1232381             | 42                     | 43                              | 2                     | e                       | 1232383
2024-10-23T13:51:54.732Z | 173.21.3.15  | 725447              | Connection error?      | DISCONNECTION ERROR             | 1                     | d                       | 725449
2024-10-23T13:52:55.015Z | 173.21.3.15  | 8268152             | Connection error?      | DISCONNECTION ERROR             | 3                     | c                       | 8268154
2024-10-23T13:53:55.832Z | 173.21.3.15  | 5033754             | Connection error?      | DISCONNECTION ERROR             | 2                     | b                       | 5033756
2024-10-23T13:55:01.543Z | 173.21.3.15  | 1756466             | Connected to 10.1.0.1! | DISCONNECTED FROM 10.1.0.1      | 1                     | a                       | 1756468
;

// KEEP @timestamp, unmapped_message: demand-loads unmapped_message; the block loader pattern
// excludes it. The expansion of the remaining unmapped fields yields nothing because all other
// unmapped fields are also excluded by the narrow KEEP. Since every row's _unmapped_fields is
// "{}", expansion produces no extra columns.
keepUnmappedFieldByNameExpand
required_capability: optional_fields_load_all_expand

SET unmapped_fields="LOAD_ALL_EXPAND"\;
FROM partial_mapping_sample_data
| KEEP @timestamp, unmapped_message
| SORT @timestamp
;

@timestamp:datetime      | unmapped_message:keyword
2024-10-23T12:15:03.360Z | Disconnected from 10.1.0.3
2024-10-23T12:27:28.948Z | Disconnected from 10.1.0.2
2024-10-23T13:33:34.937Z | 43
2024-10-23T13:51:54.732Z | Disconnection error
2024-10-23T13:52:55.015Z | Disconnection error
2024-10-23T13:53:55.832Z | Disconnection error
2024-10-23T13:55:01.543Z | Disconnected from 10.1.0.1
;


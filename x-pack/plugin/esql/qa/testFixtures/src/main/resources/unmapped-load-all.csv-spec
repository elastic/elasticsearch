// FROM with two inline subqueries (gap): the union of two subqueries is a BinaryPlan, whose
// unmappedFieldsToKeep() throws UnsupportedOperationException and falls back to ALL. The
// annotate() traversal must recurse into both Subquery branches and annotate each inner
// EsRelation correctly. For rows from partial_mapping_sample_data _unmapped_fields carries the
// four unmapped source fields; for rows from sample_data (fully mapped) _unmapped_fields = "{}".
// This test documents the correct intended output for the top-4 most-recent rows (all from
// partial_mapping_sample_data since its 2024 timestamps sort above sample_data's 2023).
fromMultipleSubqueries
required_capability: optional_fields_load_all
required_capability: subquery_in_from_command

SET unmapped_fields="LOAD_ALL"\;
FROM (FROM partial_mapping_sample_data), (FROM sample_data)
| SORT @timestamp DESC
| LIMIT 4
;


############################
# Mapping diversity tests
############################

// All fields unmapped: the index mapping is empty (dynamic:false), so every source field
// lands in _unmapped_fields. The output has only the synthetic column.
allFieldsUnmapped
required_capability: optional_fields_load_all

SET unmapped_fields="LOAD_ALL"\;
FROM no_mapping_sample_data
;
ignoreOrder:true

_unmapped_fields:keyword
"{""@timestamp"":""2024-10-23T12:15:03.360Z"",""client_ip"":""173.21.2.162"",""event_duration"":3450232,""language_code"":""4"",""message"":""Connected to 10.1.0.3!"",""unmapped.nested"":""g"",""unmapped_event_duration"":""3450234"",""unmapped_message"":""Disconnected from 10.1.0.3""}"
"{""@timestamp"":""2024-10-23T12:27:28.948Z"",""client_ip"":""173.21.2.113"",""event_duration"":2764888,""language_code"":""3"",""message"":""Connected to 10.1.0.2!"",""unmapped.nested"":""f"",""unmapped_event_duration"":""2764890"",""unmapped_message"":""Disconnected from 10.1.0.2""}"
"{""@timestamp"":""2024-10-23T13:33:34.937Z"",""client_ip"":""173.21.0.5"",""event_duration"":1232381,""language_code"":""2"",""message"":""42"",""unmapped.nested"":""e"",""unmapped_event_duration"":""1232383"",""unmapped_message"":""43""}"
"{""@timestamp"":""2024-10-23T13:51:54.732Z"",""client_ip"":""173.21.3.15"",""event_duration"":725447,""language_code"":""1"",""message"":""Connection error?"",""unmapped.nested"":""d"",""unmapped_event_duration"":""725449"",""unmapped_message"":""Disconnection error""}"
"{""@timestamp"":""2024-10-23T13:52:55.015Z"",""client_ip"":""173.21.3.15"",""event_duration"":8268152,""language_code"":""3"",""message"":""Connection error?"",""unmapped.nested"":""c"",""unmapped_event_duration"":""8268154"",""unmapped_message"":""Disconnection error""}"
"{""@timestamp"":""2024-10-23T13:53:55.832Z"",""client_ip"":""173.21.3.15"",""event_duration"":5033754,""language_code"":""2"",""message"":""Connection error?"",""unmapped.nested"":""b"",""unmapped_event_duration"":""5033756"",""unmapped_message"":""Disconnection error""}"
"{""@timestamp"":""2024-10-23T13:55:01.543Z"",""client_ip"":""173.21.3.15"",""event_duration"":1756466,""language_code"":""1"",""message"":""Connected to 10.1.0.1!"",""unmapped.nested"":""a"",""unmapped_event_duration"":""1756468"",""unmapped_message"":""Disconnected from 10.1.0.1""}"
;

// Multi-index: rows from a fully-mapped index produce _unmapped_fields = "{}" because all
// their source keys are excluded (they are mapped columns). Rows from the partially-mapped
// index carry their unmapped source fields.
multiIndexFullyMappedHasEmptyUnmappedFields
required_capability: optional_fields_load_all

SET unmapped_fields="LOAD_ALL"\;
FROM partial_mapping_sample_data, sample_data
| SORT @timestamp DESC
;


// WHERE reduces the document set: the block loader runs on fewer documents, but _unmapped_fields
// content is identical to a bare-FROM result for the rows that pass the filter.
whereReducesDocumentSet
required_capability: optional_fields_load_all

SET unmapped_fields="LOAD_ALL"\;
FROM partial_mapping_sample_data
| WHERE message == "Connection error?"
| SORT @timestamp
;

@timestamp:datetime      | client_ip:ip | event_duration:long | message:keyword   | _unmapped_fields:keyword
2024-10-23T13:51:54.732Z | 173.21.3.15  | 725447              | Connection error? | "{""language_code"":""1"",""unmapped.nested"":""d"",""unmapped_event_duration"":""725449"",""unmapped_message"":""Disconnection error""}"
2024-10-23T13:52:55.015Z | 173.21.3.15  | 8268152             | Connection error? | "{""language_code"":""3"",""unmapped.nested"":""c"",""unmapped_event_duration"":""8268154"",""unmapped_message"":""Disconnection error""}"
2024-10-23T13:53:55.832Z | 173.21.3.15  | 5033754             | Connection error? | "{""language_code"":""2"",""unmapped.nested"":""b"",""unmapped_event_duration"":""5033756"",""unmapped_message"":""Disconnection error""}"
;

// WHERE on an unmapped column: the predicate causes ResolveUnmapped to demand-load unmapped_message
// into EsRelation output. DetermineUnmappedFieldsToKeep.annotate() then sees unmapped_message in
// esr.output() and adds it to the exclude list, so _unmapped_fields no longer contains it. The
// demand-loaded column appears explicitly between message and _unmapped_fields.
whereOnUnmappedField
required_capability: optional_fields_load_all

SET unmapped_fields="LOAD_ALL"\;
FROM partial_mapping_sample_data
| WHERE unmapped_message == "Disconnection error"
| SORT @timestamp
;

@timestamp:datetime      | client_ip:ip | event_duration:long | message:keyword   | unmapped_message:keyword | _unmapped_fields:keyword
2024-10-23T13:51:54.732Z | 173.21.3.15  | 725447              | Connection error? | Disconnection error      | "{""language_code"":""1"",""unmapped.nested"":""d"",""unmapped_event_duration"":""725449""}"
2024-10-23T13:52:55.015Z | 173.21.3.15  | 8268152             | Connection error? | Disconnection error      | "{""language_code"":""3"",""unmapped.nested"":""c"",""unmapped_event_duration"":""8268154""}"
2024-10-23T13:53:55.832Z | 173.21.3.15  | 5033754             | Connection error? | Disconnection error      | "{""language_code"":""2"",""unmapped.nested"":""b"",""unmapped_event_duration"":""5033756""}"
;

// RENAME a mapped column: the renamed attribute (msg) replaces message in the output; since
// message is a mapping-level field, it was always excluded from _unmapped_fields regardless of
// the rename. The _unmapped_fields content is unchanged.
renameMappedField
required_capability: optional_fields_load_all

SET unmapped_fields="LOAD_ALL"\;
FROM partial_mapping_sample_data
| RENAME message AS msg
| SORT @timestamp
;


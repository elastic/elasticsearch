############################
# Source mode coverage
############################

// Synthetic source, regular (non-TS) index (gap): with index.mapping.source.mode=synthetic and
// dynamic:false, DocumentParser.parseDynamicValue calls addIgnoredField(), which stores each
// unmapped field in the _ignored_source stored field. SyntheticSourceLoader then merges
// _ignored_source into the reconstructed _source it returns. Whether UnmappedFieldsBlockLoader
// receives the full reconstruction — including those entries — depends on which storedFields
// are requested by the SourceLoader and merged into the StoredFieldsSpec. This test documents the
// correct intended behaviour; update this comment if it turns out to pass without a code change.
fromSyntheticSource
required_capability: optional_fields_load_all

SET unmapped_fields="LOAD_ALL"\;
FROM synthetic_source_partial_mapping
| SORT @timestamp
;


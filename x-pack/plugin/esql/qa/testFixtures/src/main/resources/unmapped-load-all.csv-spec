// FROM-based STATS drops _unmapped_fields: the aggregation collapses all rows and the per-document
// synthetic column is gone from the output. No error is raised.
fromStatsDropsUnmappedFields
required_capability: optional_fields_load_all

SET unmapped_fields="LOAD_ALL"\;
FROM partial_mapping_sample_data
| STATS cnt = COUNT(*), max_dur = MAX(event_duration)
;

cnt:long | max_dur:long
7        | 8268152
;

// INLINE STATS creates a column whose name conflicts with an unmapped source field.
// The INLINE STATS output column "language_code" shadows the unmapped source field, so
// language_code does not appear in _unmapped_fields.
inlineStatsConflictsWithUnmapped
required_capability: optional_fields_load_all
required_capability: inline_stats

SET unmapped_fields="LOAD_ALL"\;
FROM partial_mapping_sample_data
| INLINE STATS language_code = COUNT(*) BY message
| SORT @timestamp
| LIMIT 4
;

@timestamp:datetime      | client_ip:ip | event_duration:long | _unmapped_fields:keyword                                                                                                                                       | language_code:long | message:keyword
2024-10-23T12:15:03.360Z | 173.21.2.162 | 3450232             | "{""unmapped.nested"":""g"",""unmapped_event_duration"":""3450234"",""unmapped_message"":""Disconnected from 10.1.0.3""}"                                   | 1                  | Connected to 10.1.0.3!
2024-10-23T12:27:28.948Z | 173.21.2.113 | 2764888             | "{""unmapped.nested"":""f"",""unmapped_event_duration"":""2764890"",""unmapped_message"":""Disconnected from 10.1.0.2""}"                                   | 1                  | Connected to 10.1.0.2!
2024-10-23T13:33:34.937Z | 173.21.0.5   | 1232381             | "{""unmapped.nested"":""e"",""unmapped_event_duration"":""1232383"",""unmapped_message"":""43""}"                                                           | 1                  | 42
2024-10-23T13:51:54.732Z | 173.21.3.15  | 725447              | "{""unmapped.nested"":""d"",""unmapped_event_duration"":""725449"",""unmapped_message"":""Disconnection error""}"                                           | 3                  | Connection error?
;

// Complex pipeline combining EVAL, DROP, and RENAME on mapped columns: none of these operations
// touch the unmapped source fields, so _unmapped_fields carries the same content it would in a
// bare-FROM query for the same rows.
complexDropRenameEval
required_capability: optional_fields_load_all

SET unmapped_fields="LOAD_ALL"\;
FROM partial_mapping_sample_data
| EVAL duration_ms = event_duration / 1000
| DROP event_duration, client_ip
| RENAME message AS msg
| SORT @timestamp
| LIMIT 3
;

@timestamp:datetime      | msg:keyword            | duration_ms:long | _unmapped_fields:keyword
2024-10-23T12:15:03.360Z | Connected to 10.1.0.3! | 3450             | "{""language_code"":""4"",""unmapped.nested"":""g"",""unmapped_event_duration"":""3450234"",""unmapped_message"":""Disconnected from 10.1.0.3""}"
2024-10-23T12:27:28.948Z | Connected to 10.1.0.2! | 2764             | "{""language_code"":""3"",""unmapped.nested"":""f"",""unmapped_event_duration"":""2764890"",""unmapped_message"":""Disconnected from 10.1.0.2""}"
2024-10-23T13:33:34.937Z | 42                     | 1232             | "{""language_code"":""2"",""unmapped.nested"":""e"",""unmapped_event_duration"":""1232383"",""unmapped_message"":""43""}"
;

// Complex pipeline with EVAL that conflicts with an unmapped source field and a wildcard DROP
// (gap): EVAL adds "language_code" to the excludes via Eval.unmappedFieldsToKeep(), so the source
// field language_code does not appear in _unmapped_fields. DROP *duration* should also propagate
// the glob pattern into the _unmapped_fields exclude list, removing unmapped_event_duration. This
// test documents the intended correct behaviour; it will fail until the glob propagation is fixed.
complexEvalDropWildcard
required_capability: optional_fields_load_all

SET unmapped_fields="LOAD_ALL"\;
FROM partial_mapping_sample_data
| EVAL language_code = event_duration / 1000
| DROP *duration*, client_ip
| SORT @timestamp
| LIMIT 3
;

@timestamp:datetime      | message:keyword        | language_code:long | _unmapped_fields:keyword
2024-10-23T12:15:03.360Z | Connected to 10.1.0.3! | 3450               | "{""unmapped.nested"":""g"",""unmapped_message"":""Disconnected from 10.1.0.3""}"
2024-10-23T12:27:28.948Z | Connected to 10.1.0.2! | 2764               | "{""unmapped.nested"":""f"",""unmapped_message"":""Disconnected from 10.1.0.2""}"
2024-10-23T13:33:34.937Z | 42                     | 1232               | "{""unmapped.nested"":""e"",""unmapped_message"":""43""}"

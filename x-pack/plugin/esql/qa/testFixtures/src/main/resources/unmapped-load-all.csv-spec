// RENAME a mapped column to a name that conflicts with an unmapped source field: patternForRename
// adds the target name "language_code" to the exclude list, so the unmapped source field
// language_code does not appear in _unmapped_fields. The renamed column carries the mapped
// message values.
renameMappedFieldConflictsWithUnmapped
required_capability: optional_fields_load_all

SET unmapped_fields="LOAD_ALL"\;
FROM partial_mapping_sample_data
| RENAME message AS language_code
| SORT @timestamp
;


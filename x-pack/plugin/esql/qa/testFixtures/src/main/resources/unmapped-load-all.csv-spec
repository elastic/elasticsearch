############################
# Distributed / join coverage
############################

// LOOKUP JOIN: the annotate() traversal unconditionally skips every IndexMode.LOOKUP EsRelation,
// so the LOOKUP index never gains an _unmapped_fields attribute. _unmapped_fields reflects only
// the main index's unmapped source fields. Column order: main-index columns + _unmapped_fields
// (from the left/main output), then the lookup's non-key column (message_type).
lookupJoinDoesNotContributeToUnmappedFields
required_capability: optional_fields_load_all
required_capability: join_lookup_v12

SET unmapped_fields="LOAD_ALL"\;
FROM partial_mapping_sample_data
| LOOKUP JOIN partial_message_types_lookup ON message
| SORT @timestamp DESC
;

@timestamp:datetime      | client_ip:ip | event_duration:long | message:keyword        | _unmapped_fields:keyword                                                                                                                                      | message_type:keyword

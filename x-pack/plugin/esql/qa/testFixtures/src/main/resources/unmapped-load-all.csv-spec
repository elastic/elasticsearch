############################
# More command coverage
############################

// DROP a mapped column: the _unmapped_fields content is unchanged because mapped fields were
// never candidates for the synthetic column. The dropped column simply disappears from output.
dropMappedColumn
required_capability: optional_fields_load_all

SET unmapped_fields="LOAD_ALL"\;
FROM partial_mapping_sample_data
| DROP client_ip
| SORT @timestamp
;

@timestamp:datetime      | event_duration:long | message:keyword        | _unmapped_fields:keyword

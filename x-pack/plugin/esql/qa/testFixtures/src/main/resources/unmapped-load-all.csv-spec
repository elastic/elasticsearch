############################
# LOAD_ALL mode — loads all unmapped source fields into the synthetic _unmapped_fields column
############################

############################
# Command coverage tests
############################

// KEEP * — all mapped columns are kept; _unmapped_fields is always appended at the end.
// Content is identical to the bare-FROM test.
keepStar
required_capability: optional_fields_load_all

SET unmapped_fields="LOAD_ALL"\;
FROM partial_mapping_sample_data
| KEEP *
| SORT @timestamp
;

@timestamp:datetime      | client_ip:ip | event_duration:long | message:keyword        | _unmapped_fields:keyword
2024-10-23T12:15:03.360Z | 173.21.2.162 | 3450232             | Connected to 10.1.0.3! | "{""language_code"":""4"",""unmapped.nested"":""g"",""unmapped_event_duration"":""3450234"",""unmapped_message"":""Disconnected from 10.1.0.3""}"
2024-10-23T12:27:28.948Z | 173.21.2.113 | 2764888             | Connected to 10.1.0.2! | "{""language_code"":""3"",""unmapped.nested"":""f"",""unmapped_event_duration"":""2764890"",""unmapped_message"":""Disconnected from 10.1.0.2""}"
2024-10-23T13:33:34.937Z | 173.21.0.5   | 1232381             | 42                     | "{""language_code"":""2"",""unmapped.nested"":""e"",""unmapped_event_duration"":""1232383"",""unmapped_message"":""43""}"
2024-10-23T13:51:54.732Z | 173.21.3.15  | 725447              | Connection error?      | "{""language_code"":""1"",""unmapped.nested"":""d"",""unmapped_event_duration"":""725449"",""unmapped_message"":""Disconnection error""}"
2024-10-23T13:52:55.015Z | 173.21.3.15  | 8268152             | Connection error?      | "{""language_code"":""3"",""unmapped.nested"":""c"",""unmapped_event_duration"":""8268154"",""unmapped_message"":""Disconnection error""}"
2024-10-23T13:53:55.832Z | 173.21.3.15  | 5033754             | Connection error?      | "{""language_code"":""2"",""unmapped.nested"":""b"",""unmapped_event_duration"":""5033756"",""unmapped_message"":""Disconnection error""}"
2024-10-23T13:55:01.543Z | 173.21.3.15  | 1756466             | Connected to 10.1.0.1! | "{""language_code"":""1"",""unmapped.nested"":""a"",""unmapped_event_duration"":""1756468"",""unmapped_message"":""Disconnected from 10.1.0.1""}"
;

// KEEP unmapped* — include pattern narrows to unmapped*; language_code is excluded.
// The output column is only _unmapped_fields (no mapped columns match unmapped*).
keepUnmappedStar
required_capability: optional_fields_load_all
ignoreOrder:true

SET unmapped_fields="LOAD_ALL"\;
FROM partial_mapping_sample_data
| KEEP unmapped*
;

_unmapped_fields:keyword
"{""unmapped.nested"":""a"",""unmapped_event_duration"":""1756468"",""unmapped_message"":""Disconnected from 10.1.0.1""}"
"{""unmapped.nested"":""b"",""unmapped_event_duration"":""5033756"",""unmapped_message"":""Disconnection error""}"
"{""unmapped.nested"":""c"",""unmapped_event_duration"":""8268154"",""unmapped_message"":""Disconnection error""}"
"{""unmapped.nested"":""d"",""unmapped_event_duration"":""725449"",""unmapped_message"":""Disconnection error""}"
"{""unmapped.nested"":""e"",""unmapped_event_duration"":""1232383"",""unmapped_message"":""43""}"
"{""unmapped.nested"":""f"",""unmapped_event_duration"":""2764890"",""unmapped_message"":""Disconnected from 10.1.0.2""}"
"{""unmapped.nested"":""g"",""unmapped_event_duration"":""3450234"",""unmapped_message"":""Disconnected from 10.1.0.3""}"
;

// EVAL shadows the unmapped language_code source field — it must not appear in _unmapped_fields JSON.
// language_code is resolved as an unmapped keyword from _source, then cast to integer by EVAL.
// Because language_code is now in the named output, DetermineUnmappedFieldsToKeep excludes it.
// The _unmapped_fields column is placed before the EVAL-introduced language_code (mergeOutputAttributes
// appends new names after child output).
evalShadowsUnmappedLanguageCode
required_capability: optional_fields_load_all

SET unmapped_fields="LOAD_ALL"\;
FROM partial_mapping_sample_data
| EVAL language_code = language_code::integer
| SORT @timestamp
;

@timestamp:datetime      | client_ip:ip | event_duration:long | message:keyword        | _unmapped_fields:keyword                                                                                                                                 | language_code:integer

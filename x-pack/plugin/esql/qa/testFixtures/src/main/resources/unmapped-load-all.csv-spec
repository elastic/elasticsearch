// Multi-index: rows from a fully-mapped index produce _unmapped_fields = "{}" because all
// their source keys are excluded (they are mapped columns). Rows from the partially-mapped
// index carry their unmapped source fields.
multiIndexFullyMappedHasEmptyUnmappedFields
required_capability: optional_fields_load_all

SET unmapped_fields="LOAD_ALL"\;
FROM partial_mapping_sample_data, sample_data METADATA _index
| SORT @timestamp DESC
;


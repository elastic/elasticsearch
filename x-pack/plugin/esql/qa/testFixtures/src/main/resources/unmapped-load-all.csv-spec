// TS (time-series) query with LOAD_ALL: the TIME_SERIES EsRelation is annotated with
// _unmapped_fields (not skipped like LOOKUP), but STATS drops the per-document column
// before it reaches the output. Since all fields in ts_window are mapped, _unmapped_fields
// would be "{}" per row anyway; after aggregation only the STATS output columns appear.
tsStatsDropsUnmappedFields
required_capability: optional_fields_load_all
required_capability: ts_command_v0

SET unmapped_fields="LOAD_ALL"\;
TS ts_window
| STATS total_val = SUM(val) BY dim
| SORT dim
;

total_val:long | dim:keyword
30             | a
300            | b
;

// TS query without STATS on a fully-mapped index: _unmapped_fields = "{}" for every row.
tsWithoutStatsAllMappedFields
required_capability: optional_fields_load_all
required_capability: ts_command_v0

SET unmapped_fields="LOAD_ALL"\;
TS ts_window
| SORT @timestamp, dim
| KEEP @timestamp, dim, val
| LIMIT 4
;

@timestamp:datetime      | dim:keyword | val:long | _unmapped_fields:keyword
2024-01-01T00:00:00.000Z | a           | 1        | {}
2024-01-01T00:00:00.000Z | b           | 10       | {}
2024-01-01T00:01:00.000Z | a           | 2        | {}
2024-01-01T00:01:00.000Z | b           | 20       | {}
;

// TS query without STATS on an index with an unmapped source field (gap): TSDB with
// dynamic:false does not surface unmapped fields via _source to UnmappedFieldsBlockLoader,
// regardless of source mode (synthetic or stored). The dynamic:false field extra_label is not
// stored in a way that UnmappedFieldsBlockLoader.read() can retrieve it: with synthetic source,
// ignored_source entries are not surfaced through the LeafStoredFieldLoader used by ES|QL; with
// stored source mode, DocumentParser.parseDynamicValue() returns early before adding the field
// and the raw stored bytes are not read. This test documents the correct intended behaviour;
// it will fail until the production gap is fixed.
tsWithoutStatsHasUnmappedFields
required_capability: optional_fields_load_all
required_capability: ts_command_v0

SET unmapped_fields="LOAD_ALL"\;
TS ts_window_partial_mapping
| SORT @timestamp, dim
| KEEP @timestamp, dim, val
| LIMIT 4
;

@timestamp:datetime      | dim:keyword | val:long | _unmapped_fields:keyword
2024-01-01T00:00:00.000Z | a           | 1        | {"extra_label":"label_a"}
2024-01-01T00:00:00.000Z | b           | 10       | {"extra_label":"label_b"}
2024-01-01T00:01:00.000Z | a           | 2        | {"extra_label":"label_a"}
2024-01-01T00:01:00.000Z | b           | 20       | {"extra_label":"label_b"}
;

############################
# Subquery coverage
############################

// FROM with an inline subquery (gap): DetermineUnmappedFieldsToKeep annotates EsRelation nodes
// reached during traversal of the main plan, but the inner EsRelation wrapped by a Subquery plan
// node may not receive the annotation, or the _unmapped_fields attribute may not propagate
// through the Subquery boundary into the outer query's output. This test documents the correct
// intended behaviour; it will fail until the production gap is fixed.
fromSubquery
required_capability: optional_fields_load_all
required_capability: subquery_in_from_command

SET unmapped_fields="LOAD_ALL"\;
FROM (FROM partial_mapping_sample_data)
| SORT @timestamp
| KEEP @timestamp, _unmapped_fields
;


############################
# Distributed / join coverage
############################

// LOOKUP JOIN: the annotate() traversal unconditionally skips every IndexMode.LOOKUP EsRelation,
// so the LOOKUP index never gains an _unmapped_fields attribute. _unmapped_fields reflects only
// the main index's unmapped source fields. Column order: main-index columns + _unmapped_fields
// (from the left/main output), then the lookup's non-key column (message_type).
lookupJoinDoesNotContributeToUnmappedFields
required_capability: optional_fields_load_all
required_capability: join_lookup_v12

SET unmapped_fields="LOAD_ALL"\;
FROM partial_mapping_sample_data
| LOOKUP JOIN partial_message_types_lookup ON message
| SORT @timestamp DESC
;

@timestamp:datetime      | client_ip:ip | event_duration:long | message:keyword        | _unmapped_fields:keyword                                                                                                                                      | message_type:keyword
2024-10-23T13:55:01.543Z | 173.21.3.15  | 1756466             | Connected to 10.1.0.1! | "{""language_code"":""1"",""unmapped.nested"":""a"",""unmapped_event_duration"":""1756468"",""unmapped_message"":""Disconnected from 10.1.0.1""}"           | connection
2024-10-23T13:53:55.832Z | 173.21.3.15  | 5033754             | Connection error?      | "{""language_code"":""2"",""unmapped.nested"":""b"",""unmapped_event_duration"":""5033756"",""unmapped_message"":""Disconnection error""}"                 | error
2024-10-23T13:52:55.015Z | 173.21.3.15  | 8268152             | Connection error?      | "{""language_code"":""3"",""unmapped.nested"":""c"",""unmapped_event_duration"":""8268154"",""unmapped_message"":""Disconnection error""}"                 | error
2024-10-23T13:51:54.732Z | 173.21.3.15  | 725447              | Connection error?      | "{""language_code"":""1"",""unmapped.nested"":""d"",""unmapped_event_duration"":""725449"",""unmapped_message"":""Disconnection error""}"                  | error
2024-10-23T13:33:34.937Z | 173.21.0.5   | 1232381             | 42                     | "{""language_code"":""2"",""unmapped.nested"":""e"",""unmapped_event_duration"":""1232383"",""unmapped_message"":""43""}"                                  | numeric
2024-10-23T12:27:28.948Z | 173.21.2.113 | 2764888             | Connected to 10.1.0.2! | "{""language_code"":""3"",""unmapped.nested"":""f"",""unmapped_event_duration"":""2764890"",""unmapped_message"":""Disconnected from 10.1.0.2""}"           | connection
2024-10-23T12:15:03.360Z | 173.21.2.162 | 3450232             | Connected to 10.1.0.3! | "{""language_code"":""4"",""unmapped.nested"":""g"",""unmapped_event_duration"":""3450234"",""unmapped_message"":""Disconnected from 10.1.0.3""}"           | connection
;

// LOOKUP JOIN shadowing (gap): when the lookup provides a column (language_code) whose name
// matches an unmapped source field in the main index, language_code should appear only as the
// proper output column (with the lookup value) and NOT inside _unmapped_fields. Currently the
// production code does not add LOOKUP non-key column names to the exclusion pattern for the
// main EsRelation, so language_code still leaks into _unmapped_fields. This test documents the
// correct intended behaviour; it will fail until the production gap is fixed.
lookupJoinColumnShadowsUnmappedField
required_capability: optional_fields_load_all
required_capability: join_lookup_v12

SET unmapped_fields="LOAD_ALL"\;
FROM partial_mapping_sample_data
| LOOKUP JOIN message_language_code_lookup ON message
| SORT @timestamp DESC
;

@timestamp:datetime      | client_ip:ip | event_duration:long | message:keyword        | _unmapped_fields:keyword                                                                                                            | language_code:keyword

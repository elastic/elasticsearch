maxOverTimeOfKeyword
required_capability: optional_fields_v3
required_capability: ts_command_v0

SET unmapped_fields="load"\;
TS k8s,k8s_unmapped METADATA _index
| STATS pod = min(max_over_time(region)) BY time_bucket = bucket(@timestamp,1minute), _index
| SORT time_bucket, _index
| LIMIT 10;


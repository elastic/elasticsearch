// Confirm that the employees_no_names index does not have first_name and last_name mapped.
employeesNoNamesFieldsRemoved
required_capability: index_metadata_field

FROM employees, employees_no_names METADATA _index
| KEEP emp_no, first_name, last_name, _index
| SORT emp_no, _index
| LIMIT 6
;

emp_no:integer | first_name:keyword | last_name:keyword | _index:keyword
10001          | Georgi             | Facello           | employees
10001          | null               | null              | employees_no_names
10002          | Bezalel            | Simmel            | employees
10002          | null               | null              | employees_no_names
10003          | Parto              | Bamford           | employees
10003          | null               | null              | employees_no_names
;


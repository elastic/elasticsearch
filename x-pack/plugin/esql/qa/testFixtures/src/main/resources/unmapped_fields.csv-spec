// In load mode, an unmapped join key is read from _source as keyword and used in the LOOKUP JOIN.
// The KEEP before the join is required: it binds the key to the primary, not the lookup output.
loadUnmappedJoinKeyFromSourceTreatedAsKeyword
required_capability: optional_fields_load_with_lookup_join
required_capability: join_lookup_v12

SET unmapped_fields="load"\;
FROM no_message_sample_data
| KEEP message
| LOOKUP JOIN message_types_lookup ON message
| SORT message ASC, type ASC
;

message:keyword        | type:keyword

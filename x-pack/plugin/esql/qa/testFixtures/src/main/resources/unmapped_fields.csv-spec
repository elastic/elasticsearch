2024-10-23T13:53:55.832Z | Connection error?      | error                | Disconnection error
2024-10-23T13:52:55.015Z | Connection error?      | error                | Disconnection error
2024-10-23T13:51:54.732Z | Connection error?      | error                | Disconnection error
2024-10-23T13:33:34.937Z | 42                     | numeric              | 43
2024-10-23T12:27:28.948Z | Connected to 10.1.0.2! | connection           | Disconnected from 10.1.0.2
2024-10-23T12:15:03.360Z | Connected to 10.1.0.3! | connection           | Disconnected from 10.1.0.3
;

// A field absent from all mappings and _source returns null downstream of LOOKUP JOIN.
loadAbsentFieldAfterLookupJoin
required_capability: optional_fields_load_with_lookup_join
required_capability: join_lookup_v12

SET unmapped_fields="load"\;
FROM partial_mapping_sample_data
| LOOKUP JOIN partial_message_types_lookup ON message
| KEEP @timestamp, message_type, completely_absent_field
| SORT @timestamp DESC
;


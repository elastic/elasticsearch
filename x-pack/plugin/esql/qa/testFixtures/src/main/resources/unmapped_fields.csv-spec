// An unmapped field referenced in one FORK branch can be renamed and grouped on after the FORK; it is
// null everywhere (absent from _source), so the cast filter eliminates that branch.
loadUnmappedFieldRenamedAndGroupedAcrossForkBranches
required_capability: optional_fields_load_with_fork_subqueries_and_views

##############################
# LOAD mode with LOOKUP JOIN #
##############################

// Unmapped field present in _source is loaded from the primary index after LOOKUP JOIN.
loadUnmappedFieldAfterLookupJoin
required_capability: optional_fields_load_with_lookup_join
required_capability: join_lookup_v12

SET unmapped_fields="load"\;
FROM partial_mapping_sample_data
| LOOKUP JOIN partial_message_types_lookup ON message
| KEEP @timestamp, message, message_type, unmapped_message
| SORT @timestamp DESC
;

@timestamp:date          | message:keyword        | message_type:keyword | unmapped_message:keyword

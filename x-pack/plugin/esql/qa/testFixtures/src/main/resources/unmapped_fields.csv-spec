###################
# LOAD mode + FORK #
###################

// An unmapped field referenced in only one FORK branch is loaded from _source in every branch, so it is
// available in the merged FORK output even for the branch that never references it. Here unmapped_message
// is referenced in branch 1's WHERE; for branch 2 (matched by the mapped "message" field) its value still
// has to be loaded from _source ("43"). unmapped_event_duration is referenced only after the FORK, proving
// it is loaded in both branches too.
loadUnmappedFieldAcrossForkBranches
required_capability: optional_fields_load_with_fork_subqueries_and_views
required_capability: fork_v9

SET unmapped_fields="load"\;
FROM partial_mapping_sample_data
| FORK (WHERE unmapped_message == "Disconnection error")
       (WHERE message == "42")
| KEEP _fork, message, unmapped_message, unmapped_event_duration
| SORT _fork, unmapped_event_duration
;

_fork:keyword | message:keyword   | unmapped_message:keyword | unmapped_event_duration:keyword
fork1         | Connection error? | Disconnection error      | 5033756
fork1         | Connection error? | Disconnection error      | 725449
fork1         | Connection error? | Disconnection error      | 8268154
fork2         | 42                | 43                       | 1232383
;

// A field absent from all mappings and _source is null in the merged FORK output for every branch.
loadAbsentFieldAcrossForkBranches
required_capability: optional_fields_load_with_fork_subqueries_and_views
required_capability: fork_v9

SET unmapped_fields="load"\;
FROM partial_mapping_sample_data
| FORK (WHERE message == "42")
       (WHERE message == "Connected to 10.1.0.1!")
| KEEP _fork, message, completely_absent_field
| SORT _fork
;

_fork:keyword | message:keyword        | completely_absent_field:keyword
fork1         | 42                     | null
fork2         | Connected to 10.1.0.1! | null
;

// A FORK branch topped by a LOOKUP JOIN must still surface the cross-branch loaded unmapped field: a LEFT join
// preserves its left-hand (primary) columns, so unmapped_message loaded from the primary's _source flows through
// the join. unmapped_message is only referenced in branch 2's WHERE; branch 1 (the LOOKUP JOIN) never references it
// yet still loads it from _source ("43") rather than null-filling it. message_type comes from the lookup index, so it
// is null in branch 2 which has no join. See https://github.com/elastic/elasticsearch/issues/142033.
loadUnmappedFieldAcrossForkBranchWithLookupJoin
required_capability: optional_fields_load_with_fork_subqueries_and_views
required_capability: join_lookup_v12
required_capability: fork_v9

SET unmapped_fields="load"\;
FROM partial_mapping_sample_data
| FORK (WHERE message == "42" | LOOKUP JOIN partial_message_types_lookup ON message)
       (WHERE unmapped_message == "Disconnected from 10.1.0.1")
| KEEP _fork, message, message_type, unmapped_message
| SORT _fork
;

_fork:keyword | message:keyword        | message_type:keyword | unmapped_message:keyword
fork1         | 42                     | numeric              | 43
fork2         | Connected to 10.1.0.1! | null                 | Disconnected from 10.1.0.1
;

// Same as above but the FORK branch uses an expression-based LOOKUP JOIN (no row matches, so message_type is null), proving the
// cross-branch loaded unmapped_message still surfaces through an expression join. unmapped_message is referenced only in branch 2.
loadUnmappedFieldAcrossForkBranchWithExpressionLookupJoin
required_capability: optional_fields_load_with_fork_subqueries_and_views
required_capability: lookup_join_on_boolean_expression
required_capability: join_lookup_v12
required_capability: fork_v9

SET unmapped_fields="load"\;
FROM partial_mapping_sample_data
| FORK (WHERE event_duration == 1232381 | LOOKUP JOIN partial_message_types_lookup ON unmapped_event_duration > message_type)
       (WHERE unmapped_message == "Disconnected from 10.1.0.1")
| KEEP _fork, message_type, unmapped_message
| SORT _fork
;

_fork:keyword | message_type:keyword | unmapped_message:keyword
fork1         | null                 | 43
fork2         | null                 | Disconnected from 10.1.0.1
;

##############################
# LOAD mode + subqueries/views #
##############################

// Subqueries read from independent sources, so an unmapped field is loaded from _source only in the branch that references it.
// Both branches read the same physical index, but unmapped_message is referenced only in the first branch:
// it is loaded there ("43"), while the sibling branch null-fills it even though the value exists in that branch's _source.
loadUnmappedFieldInOneSubqueryBranch
required_capability: optional_fields_load_with_fork_subqueries_and_views
required_capability: subquery_in_from_command

SET unmapped_fields="load"\;
FROM (FROM partial_mapping_sample_data | WHERE message == "42" | KEEP @timestamp, unmapped_message),
     (FROM partial_mapping_sample_data | WHERE message == "Connected to 10.1.0.1!" | KEEP @timestamp)
| KEEP @timestamp, unmapped_message
| SORT @timestamp
;

@timestamp:date          | unmapped_message:keyword
2024-10-23T13:33:34.937Z | 43
2024-10-23T13:55:01.543Z | null
;

// An unmapped field referenced only in the outer query (above the union) and unmapped in every branch source is null-filled
// everywhere for union-type consistency, even though it exists in each branch's _source. The branches do not
// project their output, so the null-filled column flows up to the union for the outer reference to resolve against.
loadUnmappedFieldReferencedOnlyAboveSubqueries
required_capability: optional_fields_load_with_fork_subqueries_and_views
required_capability: subquery_in_from_command

SET unmapped_fields="load"\;
FROM (FROM partial_mapping_sample_data | WHERE message == "42"),
     (FROM partial_mapping_sample_data | WHERE message == "Connected to 10.1.0.1!")
| KEEP @timestamp, message, unmapped_message
| SORT @timestamp
;

@timestamp:date          | message:keyword        | unmapped_message:null
2024-10-23T13:33:34.937Z | 42                     | null
2024-10-23T13:55:01.543Z | Connected to 10.1.0.1! | null
;


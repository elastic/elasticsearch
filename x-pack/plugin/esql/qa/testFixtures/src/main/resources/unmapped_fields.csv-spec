SET unmapped_fields="load"\;
FROM employees
| FORK (WHERE does_not_exist::LONG > 0) (WHERE emp_no > 0)
| DROP *a*
| RENAME does_not_exist AS foo
| STATS c = COUNT(*) BY _fork, foo
;


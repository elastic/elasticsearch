###############################################
# LOAD mode with expression-based LOOKUP JOIN #
###############################################

// Expression-based LOOKUP JOIN: unmapped field loaded from primary even when no lookup row matches.
// unmapped_event_duration values are digit strings; message_type values are alphabetic — in keyword
// order digits sort before letters so the expression is always false, no lookup rows match, and
// message_type is null for every row. The non-null unmapped_event_duration values prove the field
// was loaded from the primary's _source.
loadUnmappedField_expressionJoin_noMatch
required_capability: optional_fields_load_with_lookup_join
required_capability: lookup_join_on_boolean_expression
required_capability: join_lookup_v12

SET unmapped_fields="load"\;
FROM partial_mapping_sample_data
| LOOKUP JOIN partial_message_types_lookup ON unmapped_event_duration > message_type
| KEEP @timestamp, unmapped_event_duration, message_type
| SORT @timestamp DESC
;


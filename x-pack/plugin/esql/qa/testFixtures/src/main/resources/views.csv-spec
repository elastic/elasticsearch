inSubqueryReferencingViewWithInSubqueryAndFilter
required_capability: views_with_no_branching
required_capability: views_crud_as_index_actions
required_capability: where_in_subquery

// Combine a regular filter with an IN subquery that references a view containing an IN subquery.
// employees_in_subquery is a view: FROM employees | WHERE emp_no IN (FROM employees | SORT emp_no ASC | LIMIT 3 | KEEP emp_no)
// The query adds salary > 55000 on top.
FROM employees
| WHERE salary > 55000 AND emp_no IN (FROM employees_in_subquery | KEEP emp_no)
| SORT emp_no
| KEEP emp_no, first_name, salary
;


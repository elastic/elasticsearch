###############################################
# View compaction: simple alias views
# employees_all is defined as just "FROM employees" (a simple alias).
# The ViewResolver compacts this into the original index pattern,
# so "FROM employees_all" should behave identically to "FROM employees".
# But "FROM employees_all, employees" should produce duplicated results.
###############################################

compactedViewSameAsIndex
required_capability: views_with_no_branching
required_capability: views_crud_as_index_actions

// A simple alias view should return the same document count as the underlying index
FROM employees_all
| STATS count=COUNT(emp_no)
;

count:long
100
;

compactedViewWithIndexGivesTwoCopies
required_capability: views_with_branching
required_capability: views_crud_as_index_actions
required_capability: views_deduplication_bugfix

// FROM index, view where view is a simple alias to the same index should give two copies
FROM employees, employees_all
| STATS count=COUNT(emp_no)
;

count:long
200
;

compactedViewWithViewGivesTwoCopies
required_capability: views_with_branching
required_capability: views_crud_as_index_actions

// FROM view, view should only give one copy (normal Elasticsearch behaviour is to de-duplicate repeating index names)
FROM employees_all, employees_all
| STATS count=COUNT(emp_no)
;

count:long
100
;

compactedNestedViewWithIndexGivesTripleCopies
required_capability: views_with_branching
required_capability: views_crud_as_index_actions
required_capability: views_deduplication_bugfix

// employees_extra is "FROM employees, employees_all" (200 docs after compaction).
// FROM employees, employees_extra should give 100 + 200 = 300.
FROM employees, employees_extra
| STATS count=COUNT(emp_no)
;

count:long
300
;

compactedNestedViewWithViewGivesQuadrupleCopies
required_capability: views_with_branching
required_capability: views_crud_as_index_actions
required_capability: views_deduplication_bugfix

// FROM employees_extra, employees_extra: each copy resolves to 200 docs, but de-duplication of same index name gives 200.
FROM employees_extra, employees_extra
| STATS count=COUNT(emp_no)
;

count:long
200
;

wildcardExcludeEmployeeViewsNoFalseCircularReference
required_capability: views_with_branching
required_capability: views_crud_as_index_actions
required_capability: views_false_circular_reference_fix

// Reproduces https://github.com/elastic/elasticsearch/issues/146208
// FROM *,-employees* should not trigger a false circular view reference error.
// Use airports as a concrete non-employee index to keep total > 0, then use the employees* wildcard
// to match all employee views and data. The -employees* exclusion removes them all, which is the
// exact pattern that triggered the false circular-reference bug in issue #146208.
FROM airports, employees*, -employees*
| STATS total = COUNT(*)
| EVAL at_least_one = total > 0
| KEEP at_least_one
;

at_least_one:boolean
true
;

wildcardExcludeNestedEmployeeViewsNoFalseCircularReference
required_capability: views_with_branching
required_capability: views_crud_as_index_actions
required_capability: views_false_circular_reference_fix

// Reproduces https://github.com/elastic/elasticsearch/issues/146208
// FROM *,-employees_extra,-employees_all should not trigger a false circular view reference error.
// Use airports as a concrete non-employee index, then use employees* wildcard to include all employee
// views while excluding only employees_extra, employees_all, and employees_in_subquery*.
// This verifies that partial wildcard exclusion of employees does not trigger a false circular
// reference for the remaining employee views (employees_rehired, employees_not_rehired).
FROM airports, employees*, -employees_extra, -employees_all, -employees_in_subquery*
| STATS total = COUNT(*)
| EVAL at_least_one = total > 0
| KEEP at_least_one
;
warningRegex: \(in view \[employees_not_rehired\]\): evaluation of \[is_rehired == false\] failed, treating result as null. Only first 20 failures recorded.
warningRegex: \(in view \[employees_rehired\]\): evaluation of \[is_rehired == true\] failed, treating result as null. Only first 20 failures recorded.
warningRegex: \(in view \[employees_not_rehired\]\): java.lang.IllegalArgumentException: single-value function encountered multi-value
warningRegex: \(in view \[employees_rehired\]\): java.lang.IllegalArgumentException: single-value function encountered multi-value

at_least_one:boolean
true
;

viewWithInnerSubqueryComposedWithSibling
required_capability: views_with_branching
required_capability: views_crud_as_index_actions
required_capability: subquery_in_from_command

// Regression: view_with_subquery's body is `FROM (FROM employees)` — a UnionAll wrapping a Subquery
// of a UnresolvedRelation. When composed with an unrelated index in the outer query, the
// view-compaction pass lifts the inner subquery's UnresolvedRelation up to the outer level and
// would have merged it with the sibling UnresolvedRelation into a single combined pattern. If that
// merge runs AFTER pre-analysis (i.e. as an analyzer rule before ResolveTable), the merged pattern
// string is one PreAnalyzer never sent to field-caps and ResolveTable would silently produce an
// unresolved relation. This test exercises the exact code path; it would fail with a verification
// error (Unknown index) under that bad placement. See PR #147611 / #543 / #472.
FROM view_with_subquery, addresses
| STATS c = COUNT(*)
;

c:long
103
;


FROM employees
| WHERE emp_no IN (FROM employees_in_subquery_nested | KEEP emp_no)
    AND emp_no IN (FROM employees_in_subquery_disjunction | KEEP emp_no)
    AND emp_no NOT IN (FROM employees_in_subquery_conjunction | KEEP emp_no)
| SORT emp_no
| KEEP emp_no, first_name
;


languages
FROM languages_lookup_non_unique_key
| MV_EXPAND country
| WHERE country IS NOT NULL AND country NOT LIKE ("*-Land*")
| STATS count=COUNT() BY country
;

count:long | country:text
 1         | Canada
 1         | United Kingdom
 1         | United States of America
 1         | Germany
 1         | Austria
 1         | Switzerland
 1         | Atlantis
;


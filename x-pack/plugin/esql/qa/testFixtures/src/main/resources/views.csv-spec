addressCountries
required_capability: views_v1

FROM address_countries
;

count:long | country:keyword
1          | Netherlands
1          | United States of America
1          | Japan
;

airports
FROM airports
| WHERE country IS NOT NULL
| STATS count=COUNT() BY country
| SORT count DESC
| WHERE count > 10
;

count:long | country:keyword
 129        | United States
 50         | India
 45         | Mexico
 41         | China
 37         | Canada
 31         | Brazil
 26         | Russia
 17         | United Kingdom
 17         | Australia
 13         | Argentina
 12         | France
 12         | Indonesia
 11         | Nigeria
 11         | Italy
 11         | Germany
;


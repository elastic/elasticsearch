Limit[1000[INTEGER],false,false]
\_UnionAll[[x{r}#0]]
  |_Project[[x{r}#1]]
  | \_Subquery[]
  |   \_Eval[[TO_INTEGER(x{r}#2) AS x#1]]
  |     \_Row[[1[KEYWORD] AS x#2]]
  |_Project[[x{r}#3]]
  | \_Subquery[]
  |   \_Eval[[TO_INTEGER(x{r}#4) AS x#3]]
  |     \_Row[[1.5[DOUBLE] AS x#4]]
  \_Project[[x{r}#5]]
    \_Subquery[]
      \_Row[[3[INTEGER] AS x#5]]
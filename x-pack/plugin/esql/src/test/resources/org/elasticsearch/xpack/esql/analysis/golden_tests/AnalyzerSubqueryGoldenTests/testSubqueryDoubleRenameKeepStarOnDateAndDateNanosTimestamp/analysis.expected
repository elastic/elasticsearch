Limit[1000[INTEGER],false,false]
\_OrderBy[[Order[y{r}#0,ASC,LAST]]]
  \_Project[[y{r}#0]]
    \_Project[[x{r}#1 AS y#0]]
      \_Project[[@timestamp{r}#2 AS x#1]]
        \_Project[[@timestamp{r}#2]]
          \_UnionAll[[@timestamp{r}#2, client_ip{r}#3, event_duration{r}#4, message{r}#5]]
            |_Project[[@timestamp{r}#6, client_ip{f}#7, event_duration{f}#8, message{f}#9]]
            | \_Eval[[TODATENANOS(@timestamp{f}#10) AS @timestamp#6]]
            |   \_EsRelation[sample_data][@timestamp{f}#10, client_ip{f}#7, event_duration{f}#8, message{f}#9]
            \_Project[[@timestamp{f}#11, client_ip{f}#12, event_duration{f}#13, message{f}#14]]
              \_Subquery[]
                \_EsRelation[sample_data_ts_nanos][@timestamp{f}#11, client_ip{f}#12, event_duration{f}#13, message{f}#14]
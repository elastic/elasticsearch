Project[[y{r}#0]]
\_Limit[1000[INTEGER],false,false]
  \_OrderBy[[Order[y{r}#0,ASC,LAST]]]
    \_Project[[y{r}#0, $$@timestamp$converted_to$long{r$}#1]]
      \_Project[[x{r}#2 AS y#0, $$@timestamp$converted_to$long{r$}#1]]
        \_Project[[@timestamp{r}#3 AS x#2, $$@timestamp$converted_to$long{r$}#1]]
          \_Project[[@timestamp{r}#3, $$@timestamp$converted_to$long{r$}#1]]
            \_Eval[[$$@timestamp$converted_to$long{r$}#1 AS @timestamp#3]]
              \_UnionAll[[!@timestamp, $$@timestamp$converted_to$long{r$}#1, client_ip{r}#4, event_duration{r}#5, message{r}#6]]
                |_Project[[@timestamp{r}#7, $$@timestamp$converted_to$long{r$}#8, client_ip{f}#9, event_duration{f}#10, message{f}#11]]
                | \_Eval[[null[KEYWORD] AS @timestamp#7]]
                |   \_Eval[[TOLONG(@timestamp{f}#12) AS $$@timestamp$converted_to$long#8]]
                |     \_EsRelation[sample_data][@timestamp{f}#12, client_ip{f}#9, event_duration{f}#10, message{f}#11]
                \_Project[[@timestamp{r}#13, $$@timestamp$converted_to$long{r$}#14, client_ip{f}#15, event_duration{f}#16, message{f}#17]]
                  \_Eval[[null[KEYWORD] AS @timestamp#13]]
                    \_Eval[[TOLONG(@timestamp{f}#18) AS $$@timestamp$converted_to$long#14]]
                      \_Subquery[]
                        \_EsRelation[sample_data_ts_long][@timestamp{f}#18, client_ip{f}#15, event_duration{f}#16, message{f}#17]
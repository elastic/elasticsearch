Limit[1000[INTEGER],false,false]
\_OrderBy[[Order[x{r}#0,ASC,LAST]]]
  \_Project[[x{r}#0]]
    \_Project[[@timestamp{r}#1 AS x#0]]
      \_Project[[@timestamp{r}#1]]
        \_UnionAll[[@timestamp{r}#1, client_ip{r}#2, event_duration{r}#3, message{r}#4]]
          |_Project[[@timestamp{r}#5, client_ip{f}#6, event_duration{f}#7, message{f}#8]]
          | \_Eval[[TODATENANOS(@timestamp{f}#9) AS @timestamp#5]]
          |   \_EsRelation[sample_data][@timestamp{f}#9, client_ip{f}#6, event_duration{f}#7, message{f}#8]
          \_Project[[@timestamp{f}#10, client_ip{f}#11, event_duration{f}#12, message{f}#13]]
            \_Subquery[]
              \_EsRelation[sample_data_ts_nanos][@timestamp{f}#10, client_ip{f}#11, event_duration{f}#12, message{f}#13]
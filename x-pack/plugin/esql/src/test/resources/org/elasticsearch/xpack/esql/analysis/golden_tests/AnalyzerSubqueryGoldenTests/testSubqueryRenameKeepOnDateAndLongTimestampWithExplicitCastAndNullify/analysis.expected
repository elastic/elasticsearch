Project[[x{r}#0]]
\_Limit[1000[INTEGER],false,false]
  \_OrderBy[[Order[x{r}#0,ASC,LAST]]]
    \_Project[[x{r}#0, $$@timestamp$converted_to$long{r$}#1]]
      \_Project[[@timestamp{r}#2 AS x#0, $$@timestamp$converted_to$long{r$}#1]]
        \_Project[[@timestamp{r}#2, $$@timestamp$converted_to$long{r$}#1]]
          \_Eval[[$$@timestamp$converted_to$long{r$}#1 AS @timestamp#2]]
            \_UnionAll[[!@timestamp, $$@timestamp$converted_to$long{r$}#1, client_ip{r}#3, event_duration{r}#4, message{r}#5]]
              |_Project[[@timestamp{r}#6, $$@timestamp$converted_to$long{r$}#7, client_ip{f}#8, event_duration{f}#9, message{f}#10]]
              | \_Eval[[null[KEYWORD] AS @timestamp#6]]
              |   \_Eval[[TOLONG(@timestamp{f}#11) AS $$@timestamp$converted_to$long#7]]
              |     \_EsRelation[sample_data][@timestamp{f}#11, client_ip{f}#8, event_duration{f}#9, message{f}#10]
              \_Project[[@timestamp{r}#12, $$@timestamp$converted_to$long{r$}#13, client_ip{f}#14, event_duration{f}#15, message{f}#16]]
                \_Eval[[null[KEYWORD] AS @timestamp#12]]
                  \_Eval[[TOLONG(@timestamp{f}#17) AS $$@timestamp$converted_to$long#13]]
                    \_Subquery[]
                      \_EsRelation[sample_data_ts_long][@timestamp{f}#17, client_ip{f}#14, event_duration{f}#15, message{f}#16]
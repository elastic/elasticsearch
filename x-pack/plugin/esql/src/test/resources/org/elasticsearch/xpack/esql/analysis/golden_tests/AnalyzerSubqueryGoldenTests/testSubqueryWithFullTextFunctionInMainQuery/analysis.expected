Limit[1000[INTEGER],false,false]
\_Filter[MATCH(client_ip{r}#0,127.0.0.1[KEYWORD])]
  \_UnionAll[[@timestamp{r}#1, client_ip{r}#0, event_duration{r}#2, message{r}#3]]
    |_Project[[@timestamp{f}#4, client_ip{f}#5, event_duration{f}#6, message{f}#7]]
    | \_EsRelation[sample_data][@timestamp{f}#4, client_ip{f}#5, event_duration{f}#6, message{f}#7]
    \_Project[[@timestamp{f}#8, client_ip{f}#9, event_duration{f}#10, message{f}#11]]
      \_Subquery[]
        \_Filter[:(message{f}#11,error[KEYWORD])]
          \_EsRelation[sample_data][@timestamp{f}#8, client_ip{f}#9, event_duration{f}#10, message{f}#11]
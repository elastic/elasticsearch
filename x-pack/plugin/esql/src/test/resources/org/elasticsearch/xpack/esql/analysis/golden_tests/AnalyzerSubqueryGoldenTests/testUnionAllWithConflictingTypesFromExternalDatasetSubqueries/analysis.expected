Limit[1000[INTEGER],false,false]
\_Project[[!salary]]
  \_UnionAll[[emp_no{r}#0, name{r}#1, !salary]]
    |_Project[[emp_no{r}#2, name{r}#3, salary{r}#4]]
    | \_Eval[[null[KEYWORD] AS salary#4]]
    |   \_Subquery[]
    |     \_ExternalRelation[s3://bucket/salaries_int.parquet][parquet][emp_no{r}#2, name{r}#3, salary{r}#5]
    \_Project[[emp_no{r}#6, name{r}#7, salary{r}#8]]
      \_Eval[[null[KEYWORD] AS salary#8]]
        \_Subquery[]
          \_ExternalRelation[s3://bucket/salaries_long.parquet][parquet][emp_no{r}#6, name{r}#7, salary{r}#9]
    \_Project[[@timestamp{r}#8, client_ip{r}#9, event_duration{r}#10, message{r}#11]]
      \_Eval[[null[KEYWORD] AS client_ip#9]]
        \_Eval[[null[DATETIME] AS @timestamp#8, null[LONG] AS event_duration#10, null[KEYWORD] AS message#11]]
          \_Subquery[]

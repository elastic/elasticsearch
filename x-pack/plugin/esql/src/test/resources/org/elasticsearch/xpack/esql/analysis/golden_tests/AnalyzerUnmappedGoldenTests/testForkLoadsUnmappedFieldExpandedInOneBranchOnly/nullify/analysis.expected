Limit[1000[INTEGER],false,false]
\_OrderBy[[Order[_fork{r}#0,ASC,LAST], Order[message{r}#1,ASC,LAST], Order[unmapped_message{r}#2,ASC,LAST]]]
  \_Project[[_fork{r}#0, message{r}#1, unmapped_message{r}#2]]
    \_Fork[[@timestamp{r}#3, client_ip{r}#4, event_duration{r}#5, message{r}#1, unmapped_message{r}#2, _fork{r}#0]]
      |_Project[[@timestamp{f}#6, client_ip{f}#7, event_duration{f}#8, message{f}#9, unmapped_message{r}#10, _fork{r}#11]]
      | \_Eval[[fork1[KEYWORD] AS _fork#11]]
      |   \_MvExpand[unmapped_message{f}#12,unmapped_message{r}#10]
      |     \_EsRelation[partial_mapping_sample_data][@timestamp{f}#6, client_ip{f}#7, event_duration{f}#8, message{f}#9, unmapped_message{f}#12]
      \_Project[[@timestamp{f}#13, client_ip{f}#14, event_duration{f}#15, message{f}#16, unmapped_message{r}#17, _fork{r}#18]]
        \_Eval[[null[NULL] AS unmapped_message#17]]
          \_Eval[[fork2[KEYWORD] AS _fork#18]]
            \_Filter[message{f}#16 == 42[KEYWORD]]
              \_EsRelation[partial_mapping_sample_data][@timestamp{f}#13, client_ip{f}#14, event_duration{f}#15, message{f}#16]
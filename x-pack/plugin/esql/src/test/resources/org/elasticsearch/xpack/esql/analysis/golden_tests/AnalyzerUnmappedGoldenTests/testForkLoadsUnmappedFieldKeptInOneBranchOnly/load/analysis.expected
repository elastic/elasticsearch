Limit[1000[INTEGER],false,false]
\_OrderBy[[Order[_fork{r}#0,ASC,LAST], Order[message{r}#1,ASC,LAST]]]
  \_Project[[_fork{r}#0, message{r}#1, unmapped_message{r}#2]]
    \_Fork[[message{r}#1, unmapped_message{r}#2, _fork{r}#0, @timestamp{r}#3, client_ip{r}#4, event_duration{r}#5]]
      |_Project[[message{f}#6, unmapped_message{f(PotentiallyUnmappedKeywordEsField)}#7, _fork{r}#8, @timestamp{r}#9, client_ip{r}#10, event_duration{r}#11]]
      | \_Eval[[null[DATETIME] AS @timestamp#9, null[IP] AS client_ip#10, null[LONG] AS event_duration#11]]
      |   \_Eval[[fork1[KEYWORD] AS _fork#8]]
      |     \_Project[[message{f}#6, unmapped_message{f(PotentiallyUnmappedKeywordEsField)}#7]]
      |       \_EsRelation[partial_mapping_sample_data][@timestamp{f}#12, client_ip{f}#13, event_duration{f}#14, message{f}#6, unmapped_message{f(PotentiallyUnmappedKeywordEsField)}#7]
      \_Project[[message{f}#15, unmapped_message{f(PotentiallyUnmappedKeywordEsField)}#16, _fork{r}#17, @timestamp{f}#18, client_ip{f}#19, event_duration{f}#20]]
        \_Eval[[fork2[KEYWORD] AS _fork#17]]
          \_Filter[message{f}#15 == 42[KEYWORD]]
            \_EsRelation[partial_mapping_sample_data][@timestamp{f}#18, client_ip{f}#19, event_duration{f}#20, message{f}#15, unmapped_message{f(PotentiallyUnmappedKeywordEsField)}#16]
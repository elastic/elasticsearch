Limit[1000[INTEGER],false,false]
\_OrderBy[[Order[_fork{r}#0,ASC,LAST], Order[message{r}#1,ASC,LAST]]]
  \_Project[[_fork{r}#0, message{r}#1, unmapped_message{r}#2, branch_tag{r}#3]]
    \_Fork[[@timestamp{r}#4, client_ip{r}#5, event_duration{r}#6, message{r}#1, unmapped_message{r}#2, _fork{r}#0, branch_tag{r}#3]]
      |_Project[[@timestamp{f}#7, client_ip{f}#8, event_duration{f}#9, message{f}#10, unmapped_message{f}#11, _fork{r}#12, branch_tag{r}#13]]
      | \_Eval[[null[KEYWORD] AS branch_tag#13]]
      |   \_Eval[[fork1[KEYWORD] AS _fork#12]]
      |     \_Filter[unmapped_message{f}#11 == Disconnection error[KEYWORD]]
      |       \_EsRelation[partial_mapping_sample_data][@timestamp{f}#7, client_ip{f}#8, event_duration{f}#9, message{f}#10, unmapped_message{f}#11]
      \_Project[[@timestamp{f}#14, client_ip{f}#15, event_duration{f}#16, message{f}#17, unmapped_message{r}#18, _fork{r}#19, branch_tag{r}#20]]
        \_Eval[[null[NULL] AS unmapped_message#18]]
          \_Eval[[fork2[KEYWORD] AS _fork#19]]
            \_Eval[[two[KEYWORD] AS branch_tag#20]]
              \_EsRelation[partial_mapping_sample_data][@timestamp{f}#14, client_ip{f}#15, event_duration{f}#16, message{f}#17]
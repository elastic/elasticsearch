      |       \_EsRelation[apps_short,partial_mapping_sample_data][@timestamp{f}#4, client_ip{f}#5, event_duration{f}#6, id{f}#2, message{f}#7, name{f}#8, version{f}#9]
      \_Project[[id{f}#10, _fork{r}#11]]
        \_Eval[[fork2[KEYWORD] AS _fork#11]]
          \_Filter[true[BOOLEAN]]
            \_Project[[id{f}#10]]
              \_EsRelation[apps_short,partial_mapping_sample_data][@timestamp{f}#12, client_ip{f}#13, event_duration{f}#14, id{f}#10, message{f}#15, name{f}#16, version{f}#17]
Limit[1000[INTEGER],false,false]
\_Project[[bar{r}#0]]
  \_Filter[a{r}#1 == 1[INTEGER]]
    \_Fork[[a{r}#1, _fork{r}#2, bar{r}#0]]
      \_Project[[a{r}#3, _fork{r}#4, bar{r}#5]]
        \_Eval[[fork1[KEYWORD] AS _fork#4]]
          \_Filter[true[BOOLEAN]]
            \_Eval[[null[NULL] AS bar#5]]
              \_Row[[1[INTEGER] AS a#3]]
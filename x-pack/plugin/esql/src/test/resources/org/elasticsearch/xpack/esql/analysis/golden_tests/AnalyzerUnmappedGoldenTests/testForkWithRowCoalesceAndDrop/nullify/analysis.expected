Limit[1000[INTEGER],false,false]
\_Project[[_fork{r}#0, x{r}#1]]
  \_Eval[[COALESCE(a{r}#2,TOLONG(5[INTEGER])) AS x#1]]
    \_Fork[[a{r}#2, _fork{r}#0]]
      \_Project[[a{r}#3, _fork{r}#4]]
        \_Eval[[fork1[KEYWORD] AS _fork#4]]
          \_Filter[true[BOOLEAN]]
            \_Row[[TOLONG(12[INTEGER]) AS a#3]]
Limit[1000[INTEGER],false,false]
\_Aggregate[[],[PERCENTILE(length{r}#0,true[BOOLEAN],PT0S[TIME_DURATION],50[INTEGER]) AS MEDIAN(length)#1]]
  \_Eval[[LENGTH(language_name{f}#2) AS length#0]]
    \_Join[LEFT,[language_code{r}#3],[language_code{f}#4],null]
      |_Eval[[sv{f}#5 % 4[INTEGER] + 1[INTEGER] AS language_code#3]]
      | \_EsRelation[many_numbers][mv{f}#6, sv{f}#5, sv_and_one_mv{f}#7]
      \_EsRelation[languages_lookup][LOOKUP][language_code{f}#4, language_name{f}#2]
Project[[SUM(mv){r}#0, COUNT(mv){r}#1]]
\_Eval[[TOLONG($$SUM(mv)$not_rounded{r}#2) AS SUM(mv)#0, TOLONG($$COUNT(mv)$not_rounded{r}#3) AS COUNT(mv)#1]]
  \_Limit[1000[INTEGER],false,false]
    \_SampledAggregate[[],[SUM($$SUM(mv)$todouble{r}#4,true[BOOLEAN],PT0S[TIME_DURATION],compensated[KEYWORD],long_overflow_throw[KEYWORD]) AS $$SUM(mv)$not_rounded#2, COUNTAPPROXIMATE(mv{f}#5,true[BOOLEAN],PT0S[TIME_DURATION]) AS $$COUNT(mv)$not_rounded#3],[SUM($$SUM(mv)$todouble{r}#4,true[BOOLEAN],PT0S[TIME_DURATION],compensated[KEYWORD],long_overflow_throw[KEYWORD]) AS $$SUM(mv)$not_rounded#2, COUNTAPPROXIMATE(mv{f}#5,true[BOOLEAN],PT0S[TIME_DURATION]) AS $$COUNT(mv)$not_rounded#3],SampleProbabilityPlaceHolder[]]
      \_Eval[[TODOUBLE(mv{f}#5) AS $$SUM(mv)$todouble#4]]
        \_EsRelation[many_numbers][mv{f}#5, sv{f}#6, sv_and_one_mv{f}#7]
      | \_ExternalRelation[s3://bucket/heavy_a.parquet][parquet][emp_no{r}#4, salary{r}#5, dept{r}#6]
      \_Aggregate[[],[TOPARTIAL(COUNTDISTINCT(emp_no{r}#7,true[BOOLEAN],PT0S[TIME_DURATION]),true[BOOLEAN],PT0S[TIME_DURATION],COUNTDISTINCT(emp_no{r}#7,true[BOOLEAN],PT0S[TIME_DURATION])) AS $$partial$$d1#2]]

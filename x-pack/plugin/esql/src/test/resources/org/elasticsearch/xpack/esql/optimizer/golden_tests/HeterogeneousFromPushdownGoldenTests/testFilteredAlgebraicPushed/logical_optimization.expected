Limit[1000[INTEGER],false,false]
\_Aggregate[[],[SUM(salary{r}#0,true[BOOLEAN],PT0S[TIME_DURATION],compensated[KEYWORD],long_overflow_warn[KEYWORD]) AS s#1]]
  \_UnionAll[[emp_no{r}#2, salary{r}#0, dept{r}#3]]
    |_Project[[emp_no{r}#4, salary{r}#5, dept{r}#6]]
    | \_Filter[salary{r}#5 > 0[INTEGER]]
    |   \_ExternalRelation[s3://bucket/heavy_a.parquet][parquet][emp_no{r}#4, salary{r}#5, dept{r}#6]
    \_Project[[emp_no{r}#7, salary{r}#8, dept{r}#9]]
      \_Filter[salary{r}#8 > 0[INTEGER]]
        \_ExternalRelation[s3://bucket/heavy_b.parquet][parquet][emp_no{r}#7, salary{r}#8, dept{r}#9]
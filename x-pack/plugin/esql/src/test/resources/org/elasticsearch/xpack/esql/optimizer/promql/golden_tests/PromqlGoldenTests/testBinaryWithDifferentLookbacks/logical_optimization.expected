Project[[result{r}#0, step{r}#1]]
\_Limit[10000[INTEGER],false,false]
  \_Filter[ISNOTNULL(result{r}#0)]
    \_Eval[[TODOUBLE(result{r}#2) AS result#0]]
      \_Filter[step{r}#1 >= 0[DATETIME] AND step{r}#1 <= 253402300799999[DATETIME]]
        \_Aggregate[[step{r}#1],[SUM($$avg_over_time(n>$SUM$0{r$}#3,true[BOOLEAN],PT0S[TIME_DURATION],compensated[KEYWORD],long_overflow_warn[KEYWORD]) AS result#2, step{r}#1 AS step#1]]
          \_Eval[[$$SUM$AVGOVERTIME_$1{r$}#4 / $$COUNT$AVGOVERTIME_$2{r$}#5 AS AVGOVERTIME_$1#6, $$SUM$AVGOVERTIME_$3{r$}#7 / $$COUNT$AVGOVERTIME_$4{r$}#8 AS AVGOVERTIME_$2#9, TODOUBLE(AVGOVERTIME_$1{r}#6) + TODOUBLE(AVGOVERTIME_$2{r}#9) AS $$avg_over_time(n>$SUM$0#3]]
            \_TimeSeriesAggregate[[_tsid{m}#10, step{r}#1],[SUM(network.cost{f}#11,true[BOOLEAN],PT1M[TIME_DURATION],lossy[KEYWORD],long_overflow_warn[KEYWORD]) AS $$SUM$AVGOVERTIME_$1#4, COUNT(network.cost{f}#11,true[BOOLEAN],PT1M[TIME_DURATION]) AS $$COUNT$AVGOVERTIME_$2#5, SUM(network.cost{f}#11,true[BOOLEAN],PT10M[TIME_DURATION],lossy[KEYWORD],long_overflow_warn[KEYWORD]) AS $$SUM$AVGOVERTIME_$3#7, COUNT(network.cost{f}#11,true[BOOLEAN],PT10M[TIME_DURATION]) AS $$COUNT$AVGOVERTIME_$4#8, step{r}#1],BUCKET(@timestamp{f}#12,PT1M[TIME_DURATION]),BUCKET(@timestamp{f}#12,PT1M[TIME_DURATION]),@timestamp{f}#12]
              \_Eval[[BUCKET(@timestamp{f}#12,PT1M[TIME_DURATION]) AS step#1]]
                \_EsRelation[k8s][@timestamp{f}#12, client.ip{f}#13, cluster{f}#14, event{f}#15, event_city{f}#16, event_city_boundary{f}#17, event_location{f}#18, event_log{f}#19, event_shape{f}#20, events_received{f}#21, network.bytes_in{f}#22, network.cost{f}#11, network.eth0.currently_connected_clients{f}#23, network.eth0.firmware_version{f}#24, network.eth0.last_up{f}#25, network.eth0.rx{f}#26, network.eth0.tx{f}#27, network.eth0.up{f}#28, network.total_bytes_in{f}#29, network.total_bytes_out{f}#30, network.total_cost{f}#31, pod{f}#32, region{f}#33, _tsid{m}#10]
Project[[bytes{r}#0, step{r}#1, pod{r}#2]]
\_Limit[10000[INTEGER],false,false]
  \_Filter[ISNOTNULL(bytes{r}#0)]
    \_Eval[[UNPACKDIMENSION(group_pod_$1{r}#3) AS pod#2, TODOUBLE(bytes{r}#4) AS bytes#0]]
      \_Aggregate[[step{r}#1, pack_pod_$1{r}#5],[SUM(LASTOVERTIME_$1{r}#6,true[BOOLEAN],PT0S[TIME_DURATION],compensated[KEYWORD],long_overflow_warn[KEYWORD]) AS bytes#4, step{r}#1 AS step#1, pack_pod_$1{r}#5 AS group_pod_$1#3]]
        \_Eval[[PACKDIMENSION(pod{r}#7) AS pack_pod_$1#5]]
          \_TimeSeriesAggregate[[_tsid{m}#8, step{r}#1],[LASTOVERTIME(network.bytes_in{f}#9,true[BOOLEAN],PT0S[TIME_DURATION],@timestamp{f}#10) AS LASTOVERTIME_$1#6, DIMENSIONVALUES(pod{f}#2,true[BOOLEAN],PT0S[TIME_DURATION]) AS pod#7, step{r}#1],BUCKET(@timestamp{f}#10,PT1H[TIME_DURATION]),BUCKET(@timestamp{f}#10,PT1H[TIME_DURATION]),@timestamp{f}#10,false]
            \_Eval[[BUCKET(@timestamp{f}#10,PT1H[TIME_DURATION]) AS step#1]]
              \_EsRelation[k8s][@timestamp{f}#10, client.ip{f}#11, cluster{f}#12, event{f}#13, event_city{f}#14, event_city_boundary{f}#15, event_location{f}#16, event_log{f}#17, event_shape{f}#18, events_received{f}#19, network.bytes_in{f}#9, network.cost{f}#20, network.eth0.currently_connected_clients{f}#21, network.eth0.firmware_version{f}#22, network.eth0.last_up{f}#23, network.eth0.rx{f}#24, network.eth0.tx{f}#25, network.eth0.up{f}#26, network.total_bytes_in{f}#27, network.total_bytes_out{f}#28, network.total_cost{f}#29, pod{f}#2, region{f}#30, _tsid{m}#8]
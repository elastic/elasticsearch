Limit[10000[INTEGER],false,false]
\_Filter[step{r}#0 >= 0[DATETIME] AND step{r}#0 <= 253402300799999[DATETIME]]
  \_Filter[ISNOTNULL(events{r}#1)]
    \_Project[[events{r}#1, step{r}#0, pod{f}#2]]
      \_Eval[[TODOUBLE(events{r}#3) AS events#1]]
        \_Project[[events{r}#3, step{r}#0, pod{r}#2]]
          \_Eval[[UNPACKDIMENSION(group_pod_$1{r}#4) AS pod#2]]
            \_Aggregate[[step{r}#0 AS step#0, pack_pod_$1{r}#5 AS group_pod_$1#4],[SUM(FIRSTOVERTIME_$1{r}#6,true[BOOLEAN],PT0S[TIME_DURATION],compensated[KEYWORD],long_overflow_throw[KEYWORD]) AS events#3, step{r}#0, group_pod_$1{r}#4]]
              \_Eval[[PACKDIMENSION(pod{r}#7) AS pack_pod_$1#5]]
                \_TimeSeriesAggregate[[_tsid{m}#8, BUCKET(@timestamp{f}#9,PT10M[TIME_DURATION]) AS step#0],[FIRSTOVERTIME(events_received{f}#10,true[BOOLEAN],PT10M[TIME_DURATION],@timestamp{f}#9) AS FIRSTOVERTIME_$1#6, DIMENSIONVALUES(pod{f}#2,true[BOOLEAN],PT0S[TIME_DURATION]) AS pod#7, _tsid{m}#8, step{r}#0],BUCKET(@timestamp{f}#9,PT10M[TIME_DURATION]),BUCKET(@timestamp{f}#9,PT10M[TIME_DURATION]),@timestamp{f}#9,PROMQL_COMMAND]
                  \_EsRelation[k8s][@timestamp{f}#9, client.ip{f}#11, cluster{f}#12, event{f}#13, event_city{f}#14, event_city_boundary{f}#15, event_location{f}#16, event_log{f}#17, event_shape{f}#18, events_received{f}#10, network.bytes_in{f}#19, network.cost{f}#20, network.eth0.currently_connected_clients{f}#21, network.eth0.firmware_version{f}#22, network.eth0.last_up{f}#23, network.eth0.rx{f}#24, network.eth0.tx{f}#25, network.eth0.up{f}#26, network.total_bytes_in{f}#27, network.total_bytes_out{f}#28, network.total_cost{f}#29, pod{f}#2, region{f}#30, _tsid{m}#8]
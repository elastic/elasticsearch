Project[[bytes{r}#0, step{r}#1, cluster{r}#2]]
\_Limit[10000[INTEGER],false,false]
  \_Filter[ISNOTNULL(bytes{r}#0)]
    \_Eval[[$$SUM$bytes$0{r$}#3 / $$COUNT$bytes$1{r$}#4 AS bytes#5, UNPACKDIMENSION(group_cluster_$1{r}#6) AS cluster#2, TODOUBLE(bytes{r}#5) AS bytes#0]]
      \_Filter[step{r}#1 >= 0[DATETIME] AND step{r}#1 <= 253402300799999[DATETIME]]
        \_Aggregate[[step{r}#1, pack_cluster_$1{r}#7],[SUM($$avg_by_(cluster>$SUM$2{r$}#8,true[BOOLEAN],PT0S[TIME_DURATION],compensated[KEYWORD],long_overflow_warn[KEYWORD]) AS $$SUM$bytes$0#3, COUNT(LASTOVERTIME_$1{r}#9,true[BOOLEAN],PT0S[TIME_DURATION]) AS $$COUNT$bytes$1#4, step{r}#1 AS step#1, pack_cluster_$1{r}#7 AS group_cluster_$1#6]]
          \_Eval[[PACKDIMENSION(cluster{r}#10) AS pack_cluster_$1#7, TODOUBLE(LASTOVERTIME_$1{r}#9) AS $$avg_by_(cluster>$SUM$2#8]]
            \_TimeSeriesAggregate[[_tsid{m}#11, step{r}#1],[LASTOVERTIME(network.bytes_in{f}#12,true[BOOLEAN],PT0S[TIME_DURATION],@timestamp{f}#13) AS LASTOVERTIME_$1#9, DIMENSIONVALUES(cluster{f}#2,true[BOOLEAN],PT0S[TIME_DURATION]) AS cluster#10, step{r}#1],BUCKET(@timestamp{f}#13,PT1M[TIME_DURATION]),BUCKET(@timestamp{f}#13,PT1M[TIME_DURATION]),@timestamp{f}#13,PROMQL_COMMAND]
              \_Eval[[BUCKET(@timestamp{f}#13,PT1M[TIME_DURATION]) AS step#1]]
                \_EsRelation[k8s][@timestamp{f}#13, client.ip{f}#14, cluster{f}#2, event{f}#15, event_city{f}#16, event_city_boundary{f}#17, event_location{f}#18, event_log{f}#19, event_shape{f}#20, events_received{f}#21, network.bytes_in{f}#12, network.cost{f}#22, network.eth0.currently_connected_clients{f}#23, network.eth0.firmware_version{f}#24, network.eth0.last_up{f}#25, network.eth0.rx{f}#26, network.eth0.tx{f}#27, network.eth0.up{f}#28, network.total_bytes_in{f}#29, network.total_bytes_out{f}#30, network.total_cost{f}#31, pod{f}#32, region{f}#33, _tsid{m}#11]
Project[[network_in_bits{r}#0, step{r}#1, _timeseries{r}#2 AS _timeseries#3]]
\_Limit[10000[INTEGER],false,false]
  \_Filter[ISNOTNULL(network_in_bits{r}#0)]
    \_Eval[[UNPACKDIMENSION(group__timeseries_$1{r}#4) AS _timeseries#2, TODOUBLE(network_in_bits{r}#5) AS network_in_bits#0]]
      \_Aggregate[[step{r}#1, pack__timeseries_$1{r}#6],[VALUES($$network.total_b>$VALUES$0{r$}#7,true[BOOLEAN],PT0S[TIME_DURATION]) AS network_in_bits#5, step{r}#1 AS step#1, pack__timeseries_$1{r}#6 AS group__timeseries_$1#4]]
        \_Eval[[PACKDIMENSION(_timeseries{r}#8) AS pack__timeseries_$1#6, TODOUBLE(LASTOVERTIME_$1{r}#9) * 8.0[DOUBLE] AS $$network.total_b>$VALUES$0#7]]
          \_TimeSeriesAggregate[[_tsid{m}#10, step{r}#1],[LASTOVERTIME(network.total_bytes_in{f}#11,true[BOOLEAN],PT0S[TIME_DURATION],@timestamp{f}#12) AS LASTOVERTIME_$1#9, DIMENSIONVALUES(_timeseries{f}#2,true[BOOLEAN],PT0S[TIME_DURATION]) AS _timeseries#8, step{r}#1],BUCKET(@timestamp{f}#12,PT1H[TIME_DURATION]),BUCKET(@timestamp{f}#12,PT1H[TIME_DURATION]),@timestamp{f}#12,false]
            \_Eval[[BUCKET(@timestamp{f}#12,PT1H[TIME_DURATION]) AS step#1]]
              \_EsRelation[k8s][@timestamp{f}#12, client.ip{f}#13, cluster{f}#14, event{f}#15, event_city{f}#16, event_city_boundary{f}#17, event_location{f}#18, event_log{f}#19, event_shape{f}#20, events_received{f}#21, network.bytes_in{f}#22, network.cost{f}#23, network.eth0.currently_connected_clients{f}#24, network.eth0.firmware_version{f}#25, network.eth0.last_up{f}#26, network.eth0.rx{f}#27, network.eth0.tx{f}#28, network.eth0.up{f}#29, network.total_bytes_in{f}#11, network.total_bytes_out{f}#30, network.total_cost{f}#31, pod{f}#32, region{f}#33, _timeseries{f}#2, _tsid{m}#10]
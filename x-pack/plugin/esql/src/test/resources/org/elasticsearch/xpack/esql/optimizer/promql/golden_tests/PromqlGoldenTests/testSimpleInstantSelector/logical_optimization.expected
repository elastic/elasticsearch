        \_Eval[[PACKDIMENSION(_timeseries{r}#8) AS pack__timeseries_$1#6]]
          \_TimeSeriesAggregate[[_tsid{m}#9, step{r}#1],[LASTOVERTIME(network.bytes_in{f}#10,true[BOOLEAN],PT0S[TIME_DURATION],@timestamp{f}#11) AS LASTOVERTIME_$1#7, DIMENSIONVALUES(_timeseries{f}#2,true[BOOLEAN],PT0S[TIME_DURATION]) AS _timeseries#8, step{r}#1],BUCKET(@timestamp{f}#11,PT1H[TIME_DURATION]),BUCKET(@timestamp{f}#11,PT1H[TIME_DURATION]),@timestamp{f}#11,false]
            \_Eval[[BUCKET(@timestamp{f}#11,PT1H[TIME_DURATION]) AS step#1]]
              \_EsRelation[k8s][@timestamp{f}#11, client.ip{f}#12, cluster{f}#13, event{f}#14, event_city{f}#15, event_city_boundary{f}#16, event_location{f}#17, event_log{f}#18, event_shape{f}#19, events_received{f}#20, network.bytes_in{f}#10, network.cost{f}#21, network.eth0.currently_connected_clients{f}#22, network.eth0.firmware_version{f}#23, network.eth0.last_up{f}#24, network.eth0.rx{f}#25, network.eth0.tx{f}#26, network.eth0.up{f}#27, network.total_bytes_in{f}#28, network.total_bytes_out{f}#29, network.total_cost{f}#30, pod{f}#31, region{f}#32, _timeseries{f}#2, _tsid{m}#9]
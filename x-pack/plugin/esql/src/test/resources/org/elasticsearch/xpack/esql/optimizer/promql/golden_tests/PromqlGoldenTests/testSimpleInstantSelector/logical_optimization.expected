Project[[network.bytes_in{r}#0, step{r}#1, _timeseries{r}#2 AS _timeseries#3]]
\_Limit[10000[INTEGER],false,false]
  \_Filter[ISNOTNULL(network.bytes_in{r}#0)]
    \_Eval[[UNPACKDIMENSION(group__timeseries_$1{r}#4) AS _timeseries#2, TODOUBLE(network.bytes_in{r}#5) AS network.bytes_in#0]]

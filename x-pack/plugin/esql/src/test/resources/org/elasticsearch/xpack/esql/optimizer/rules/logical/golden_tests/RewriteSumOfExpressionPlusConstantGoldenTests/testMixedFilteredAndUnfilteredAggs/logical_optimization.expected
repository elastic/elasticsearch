\_Eval[[$$salary$MVSINGLEVALUEORNULL_SUM$0{r$}#4 + $$salary$MVSINGLEVALUEORNULL_COUNT$1{r$}#5 * 3[INTEGER] AS s3#2, $$salary$MVSINGLEVALUEORNULL_SUM$0{r$}#4 + $$salary$MVSINGLEVALUEORNULL_COUNT$1{r$}#5 * 4[INTEGER] AS s4#3]]

Project[[m{r}#0, c{r}#1, a{r}#2, pod{r}#3, time_bucket{r}#4]]
\_Eval[[$$SUM$a$0{r$}#5 / $$COUNT$a$1{r$}#6 AS a#2, UNPACKDIMENSION(group_pod_$1{r}#7) AS pod#3]]
  \_Limit[10000[INTEGER],false,false]
    \_Aggregate[[pack_pod_$1{r}#8, time_bucket{r}#4],[MAX(MAXOVERTIME_$1{r}#9,true[BOOLEAN],PT0S[TIME_DURATION]) AS m#0, COUNT(COUNTOVERTIME_$1{r}#10,true[BOOLEAN],PT0S[TIME_DURATION]) AS c#1, SUM(AVGOVERTIME_$1{r}#11,true[BOOLEAN],PT0S[TIME_DURATION],compensated[KEYWORD],long_overflow_warn[KEYWORD]) AS $$SUM$a$0#5, COUNT(AVGOVERTIME_$1{r}#11,true[BOOLEAN],PT0S[TIME_DURATION]) AS $$COUNT$a$1#6, pack_pod_$1{r}#8 AS group_pod_$1#7, time_bucket{r}#4 AS time_bucket#4]]
      \_Eval[[COALESCE($$SUM$COUNTOVERTIME_$2{r$}#12,0[LONG]) AS COUNTOVERTIME_$1#10, $$SUM$AVGOVERTIME_$3{r$}#13 / $$SUM$COUNTOVERTIME_$2{r$}#12 AS AVGOVERTIME_$1#11, PACKDIMENSION(pod{r}#14) AS pack_pod_$1#8]]
        \_TimeSeriesAggregate[[_tsid{m}#15, time_bucket{r}#4],[MAX($$max_over_time(n>$MAX$4{r$}#16,true[BOOLEAN],PT0S[TIME_DURATION]) AS MAXOVERTIME_$1#9, SUM($$count_over_time>$SUM$5{r$}#17,true[BOOLEAN],PT0S[TIME_DURATION],compensated[KEYWORD],long_overflow_warn[KEYWORD]) AS $$SUM$COUNTOVERTIME_$2#12, SUM($$avg_over_time(n>$SUM$6{r$}#18,true[BOOLEAN],PT0S[TIME_DURATION],lossy[KEYWORD],long_overflow_warn[KEYWORD]) AS $$SUM$AVGOVERTIME_$3#13, DIMENSIONVALUES(pod{f}#3,true[BOOLEAN],PT0S[TIME_DURATION]) AS pod#14, time_bucket{r}#4],BUCKET(@timestamp{f}#19,PT5M[TIME_DURATION]),BUCKET(@timestamp{f}#19,PT5M[TIME_DURATION]),@timestamp{f}#19,false]
          \_Eval[[BUCKET(@timestamp{f}#19,PT5M[TIME_DURATION]) AS time_bucket#4, FROMAGGREGATEMETRICDOUBLE(network.eth0.tx{f}#20,1[INTEGER]) AS $$max_over_time(n>$MAX$4#16, FROMAGGREGATEMETRICDOUBLE(network.eth0.tx{f}#20,3[INTEGER]) AS $$count_over_time>$SUM$5#17, FROMAGGREGATEMETRICDOUBLE(network.eth0.tx{f}#20,2[INTEGER]) AS $$avg_over_time(n>$SUM$6#18]]
            \_EsRelation[k8s-downsampled][@timestamp{f}#19, client.ip{f}#21, cluster{f}#22, event{f}#23, event_city{f}#24, event_city_boundary{f}#25, event_location{f}#26, event_log{f}#27, event_shape{f}#28, events_received{f}#29, network.bytes_in{f}#30, network.cost{f}#31, network.eth0.currently_connected_clients{f}#32, network.eth0.firmware_version{f}#33, network.eth0.last_up{f}#34, network.eth0.rx{f}#35, network.eth0.tx{f}#20, network.eth0.up{f}#36, network.total_bytes_in{f}#37, network.total_cost{f}#38, pod{f}#3, _tsid{m}#15]
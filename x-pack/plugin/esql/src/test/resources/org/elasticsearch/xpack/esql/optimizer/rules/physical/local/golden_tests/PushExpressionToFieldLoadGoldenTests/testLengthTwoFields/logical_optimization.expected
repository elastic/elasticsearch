Limit[1000[INTEGER],false,false]
\_Aggregate[[],[SUM($$LENGTH(last_nam>$SUM$0{r$}#0,true[BOOLEAN],PT0S[TIME_DURATION],compensated[KEYWORD]) AS last_name#1, SUM($$LENGTH(first_na>$SUM$1{r$}#2,true[BOOLEAN],PT0S[TIME_DURATION],compensated[KEYWORD]) AS first_name#3]]
